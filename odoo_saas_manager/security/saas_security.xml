<odoo>
    <record id="module_category_saas_manager" model="ir.module.category">
        <field name="name">SaaS Manager</field>
        <field name="description">Manage hosted Odoo SaaS tenants.</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_saas_support" model="res.groups">
        <field name="name">SaaS Support</field>
        <field name="category_id" ref="module_category_saas_manager"/>
    </record>

    <record id="group_saas_accountant" model="res.groups">
        <field name="name">SaaS Accountant</field>
        <field name="category_id" ref="module_category_saas_manager"/>
    </record>

    <record id="group_saas_manager" model="res.groups">
        <field name="name">SaaS Manager</field>
        <field name="category_id" ref="module_category_saas_manager"/>
        <field name="implied_ids" eval="[(4, ref('group_saas_support')), (4, ref('group_saas_accountant'))]"/>
    </record>

    <record id="group_saas_admin" model="res.groups">
        <field name="name">SaaS Admin</field>
        <field name="category_id" ref="module_category_saas_manager"/>
        <field name="implied_ids" eval="[(4, ref('group_saas_manager'))]"/>
    </record>

    <record id="rule_saas_tenant_group_users" model="ir.rule">
        <field name="name">SaaS tenant records for SaaS users</field>
        <field name="model_id" ref="model_saas_tenant"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_saas_support')), (4, ref('group_saas_accountant')), (4, ref('group_saas_manager')), (4, ref('group_saas_admin'))]"/>
    </record>

    <record id="rule_saas_plan_group_users" model="ir.rule">
        <field name="name">SaaS plan records for SaaS users</field>
        <field name="model_id" ref="model_saas_plan"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_saas_support')), (4, ref('group_saas_accountant')), (4, ref('group_saas_manager')), (4, ref('group_saas_admin'))]"/>
    </record>

    <record id="rule_saas_subscription_group_users" model="ir.rule">
        <field name="name">SaaS subscription records for SaaS users</field>
        <field name="model_id" ref="model_saas_subscription"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_saas_support')), (4, ref('group_saas_accountant')), (4, ref('group_saas_manager')), (4, ref('group_saas_admin'))]"/>
    </record>

    <record id="rule_saas_payment_group_users" model="ir.rule">
        <field name="name">SaaS payment records for SaaS users</field>
        <field name="model_id" ref="model_saas_payment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_saas_accountant')), (4, ref('group_saas_manager')), (4, ref('group_saas_admin'))]"/>
    </record>

    <record id="rule_saas_provisioning_log_group_users" model="ir.rule">
        <field name="name">SaaS provisioning logs for SaaS users</field>
        <field name="model_id" ref="model_saas_provisioning_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_saas_support')), (4, ref('group_saas_manager')), (4, ref('group_saas_admin'))]"/>
    </record>
</odoo>

        <field name="template_database">tenant_template_3pl</field>
        <field name="description">Delivery and logistics SaaS plan for riders, contracts, pricing, settlements, and performance dashboards.</field>
    </record>

    <record id="saas_plan_real_estate_business" model="saas.plan">
        <field name="name">Real Estate Business</field>
        <field name="code">REAL_ESTATE_BUSINESS</field>
        <field name="monthly_price">229.0</field>
        <field name="yearly_price">2290.0</field>
        <field name="max_users">25</field>
        <field name="storage_limit">50.0</field>

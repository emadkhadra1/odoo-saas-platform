    <record id="saas_plan_saudi_hr_business" model="saas.plan">
        <field name="name">Saudi HR Business</field>
        <field name="code">SAUDI_HR_BUSINESS</field>
        <field name="monthly_price">179.0</field>
        <field name="yearly_price">1790.0</field>
        <field name="max_users">40</field>
        <field name="storage_limit">40.0</field>
        <field name="trial_days">14</field>
        <field name="included_modules">base,mail,hr,hr_payroll,attendances_structure_base,attendance_rules,contract_work_hour,employee_bonuses,employee_penalty,hr_custody,ohrms_loan,ohrms_loan_accounting,ohrms_loan_custom,saudi_hr_eos,saudi_hr_iqama,social_insurance,saas_tenant_agent</field>

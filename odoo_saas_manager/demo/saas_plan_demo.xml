<odoo>
    <record id="saas_plan_starter" model="saas.plan">
        <field name="name">Starter</field>
        <field name="code">STARTER</field>
        <field name="monthly_price">49.0</field>
        <field name="yearly_price">499.0</field>
        <field name="max_users">5</field>
        <field name="storage_limit">5.0</field>
        <field name="trial_days">14</field>
        <field name="included_modules">base,mail,contacts</field>
        <field name="description">Small tenant package for early SaaS onboarding.</field>
    </record>

    <record id="saas_plan_business" model="saas.plan">
        <field name="name">Business</field>
        <field name="code">BUSINESS</field>
        <field name="monthly_price">149.0</field>
        <field name="yearly_price">1499.0</field>
        <field name="max_users">25</field>
        <field name="storage_limit">25.0</field>
        <field name="trial_days">14</field>
        <field name="included_modules">base,mail,contacts,account,project,hr</field>
        <field name="description">General business package for vertical Odoo solutions.</field>
    </record>

    <record id="saas_plan_enterprise" model="saas.plan">
        <field name="name">Enterprise</field>
        <field name="code">ENTERPRISE</field>
        <field name="monthly_price">399.0</field>
        <field name="yearly_price">3990.0</field>
        <field name="max_users">100</field>
        <field name="storage_limit">100.0</field>

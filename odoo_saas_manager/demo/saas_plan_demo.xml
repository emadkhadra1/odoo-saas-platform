        <field name="description">Construction SaaS plan for BOQ, projects, progress bills, budgeting, custody, and reports.</field>
    </record>

    <record id="saas_plan_3pl_business" model="saas.plan">
        <field name="name">3PL Business</field>
        <field name="code">THREE_PL_BUSINESS</field>

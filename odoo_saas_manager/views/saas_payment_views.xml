<odoo>
    <record id="view_saas_payment_tree" model="ir.ui.view">
        <field name="name">saas.payment.tree</field>
        <field name="model">saas.payment</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'paid'" decoration-danger="status == 'failed'">
                <field name="payment_date"/>
                <field name="tenant_id"/>
                <field name="subscription_id"/>
                <field name="amount"/>
                <field name="payment_method"/>
                <field name="transaction_reference"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_saas_payment_form" model="ir.ui.view">
        <field name="name">saas.payment.form</field>
        <field name="model">saas.payment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_paid" string="Mark Paid" type="object" class="btn-primary" invisible="status == 'paid'"/>
                    <button name="action_mark_failed" string="Mark Failed" type="object" invisible="status == 'failed'"/>
                    <field name="status" widget="statusbar" statusbar_visible="pending,paid,failed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="tenant_id"/>
                            <field name="subscription_id"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="payment_date"/>
                            <field name="payment_method"/>
                            <field name="transaction_reference"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_saas_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">saas.payment</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

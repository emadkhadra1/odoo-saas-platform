<odoo>
    <record id="view_saas_onboarding_import_wizard_form" model="ir.ui.view">
        <field name="name">saas.onboarding.import.wizard.form</field>
        <field name="model">saas.onboarding.import.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="tenant_id"/>
                        <field name="data_type"/>
                        <field name="filename" invisible="1"/>
                        <field name="upload_file" filename="filename"/>
                    </group>
                    <field name="result" readonly="1" invisible="not result"/>
                </sheet>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Close" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_saas_onboarding_import_wizard" model="ir.actions.act_window">
        <field name="name">Onboarding Import</field>
        <field name="res_model">saas.onboarding.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

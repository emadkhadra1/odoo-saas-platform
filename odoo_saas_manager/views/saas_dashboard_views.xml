<odoo>
    <record id="view_saas_dashboard_form" model="ir.ui.view">
        <field name="name">saas.dashboard.form</field>
        <field name="model">saas.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="Tenants">
                            <field name="active_tenants"/>
                            <field name="suspended_tenants"/>
                            <field name="trial_tenants"/>
                        </group>
                        <group string="Revenue">
                            <field name="currency_id" invisible="1"/>
                            <field name="mrr"/>
                            <field name="arr"/>
                            <field name="expired_subscriptions"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_saas_dashboard" model="ir.actions.server">
        <field name="name">Dashboard</field>
        <field name="model_id" ref="model_saas_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>
</odoo>

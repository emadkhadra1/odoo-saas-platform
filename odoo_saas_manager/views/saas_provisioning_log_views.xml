<odoo>
    <record id="view_saas_provisioning_log_tree" model="ir.ui.view">
        <field name="name">saas.provisioning.log.tree</field>
        <field name="model">saas.provisioning.log</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'success'" decoration-warning="status == 'warning'" decoration-danger="status == 'failed'">
                <field name="create_date"/>
                <field name="tenant_id"/>
                <field name="action"/>
                <field name="status"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <record id="view_saas_provisioning_log_form" model="ir.ui.view">
        <field name="name">saas.provisioning.log.form</field>
        <field name="model">saas.provisioning.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="tenant_id"/>
                        <field name="action"/>
                        <field name="status"/>
                        <field name="message"/>
                    </group>
                    <field name="technical_details"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_saas_provisioning_log" model="ir.actions.act_window">
        <field name="name">Provisioning Logs</field>
        <field name="res_model">saas.provisioning.log</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

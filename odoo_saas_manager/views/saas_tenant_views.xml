<odoo>
    <record id="view_saas_tenant_kanban" model="ir.ui.view">
        <field name="name">saas.tenant.kanban</field>
        <field name="model">saas.tenant</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="company_name"/>
                <field name="subdomain"/>
                <field name="plan_id"/>
                <field name="allowed_users"/>
                <field name="active_users_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="company_name"/></strong>
                            <div><field name="subdomain"/>.<span>mycompany.com</span></div>
                            <div><field name="plan_id"/></div>
                            <div>Users: <field name="active_users_count"/> / <field name="allowed_users"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_saas_tenant_tree" model="ir.ui.view">
        <field name="name">saas.tenant.list</field>
        <field name="model">saas.tenant</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'active'" decoration-warning="status == 'provisioning'" decoration-danger="status in ('suspended', 'expired')">
                <field name="name"/>
                <field name="company_name"/>
                <field name="email"/>
                <field name="subdomain"/>
                <field name="database_name"/>
                <field name="plan_id"/>
                <field name="allowed_users"/>
                <field name="active_users_count"/>
                <field name="status"/>
                <field name="expiry_date"/>
            </list>
        </field>
    </record>

    <record id="view_saas_tenant_form" model="ir.ui.view">
        <field name="name">saas.tenant.form</field>
        <field name="model">saas.tenant</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_provisioning" string="Provision" type="object" class="btn-primary" invisible="status not in ('draft', 'suspended')"/>
                    <button name="action_open_tenant_database" string="Open Tenant" type="object" class="btn-secondary" invisible="status != 'active' or not database_name"/>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="status == 'active'"/>
                    <button name="action_reactivate" string="Reactivate" type="object" class="btn-primary" invisible="status not in ('suspended', 'expired')"/>
                    <button name="action_suspend" string="Suspend" type="object" invisible="status != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="status == 'cancelled'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,provisioning,active,suspended,expired,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="company_name"/>
                        <h1><field name="company_name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="contact_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="plan_id"/>
                            <field name="subscription_id"/>
                        </group>
                        <group>
                            <field name="subdomain"/>
                            <field name="database_name"/>
                            <field name="database_uuid" readonly="1"/>
                            <field name="allowed_users"/>
                            <field name="active_users_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="start_date"/>
                        <field name="expiry_date"/>
                        <field name="last_payment_date"/>
                        <field name="next_invoice_date"/>
                    </group>
                    <notebook>
                        <page string="Subscriptions">
                            <field name="subscription_ids"/>
                        </page>
                        <page string="Payments">
                            <field name="payment_ids"/>
                        </page>
                        <page string="Provisioning Logs">
                            <field name="provisioning_log_ids" readonly="1"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_saas_tenant" model="ir.actions.act_window">
        <field name="name">Tenants</field>
        <field name="res_model">saas.tenant</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>

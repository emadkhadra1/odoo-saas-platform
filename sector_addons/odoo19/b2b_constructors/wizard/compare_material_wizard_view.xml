<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_compare_material_report_wizard_form" model="ir.ui.view">
            <field name="name">view.compare.material.report.wizard.form</field>
            <field name="model">b2b.compare.material.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Compare Material Report Wizard">
                    <sheet>
                        <group name="main">
                            <group>
                                <field name="project_id"/>
                                <field name="from_date"/>
                                <!--<field name="main_item_id" options="{'no_create': True}"/>-->

                            </group>
                            <group>
                                <field name="business_statement_ids" required="1" options="{'no_create': True}" widget="many2many_tags"/>
                                <field name="to_date"/>
                                <!--<field name="sub_item_id" options="{'no_create': True}"/>-->

                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_print" type="object" string="Print" class="oe_highlight"/>
                        or
                        <button special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="b2b_compare_material_report_action" model="ir.actions.act_window">
            <field name="name">Total compare. Material Items Wizard</field>
            <field name="res_model">b2b.compare.material.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <report
                id="b2b_report_sum_compare_material"
                model="b2b.compare.material.report.wizard"
                string="Compare material Report"
                report_type="qweb-pdf"
                file="b2b_constructors.report_b2b_c_material_sum_document"
                name="b2b_constructors.report_b2b_c_material_sum_document"
                attachment_use="False"
                menu="False"
        />
    </data>
</odoo>

            <field name="view_mode">form</field>
            <field name="view_id" ref="assay_import_form_1_wiz"/>
            <field name="target">new</field>
        </record>
        <menuitem id="extract_import_menu" name="Import Business Items" parent="b2b_constructors.construction_boq_menu" action="action_extract_import_wiz_view" sequence="110"/>
        <menuitem id="assay_import_menu" name="Import Construction BOQ" parent="b2b_constructors.construction_boq_menu" action="action_assay_import_wiz_view" sequence="112"/>
    </data>
</odoo>
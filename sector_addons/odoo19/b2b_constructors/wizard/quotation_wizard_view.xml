<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_quotation_report_wizard_form" model="ir.ui.view">
            <field name="name">view.quotation.report.wizard.form</field>
            <field name="model">b2b.quotation.report.wizard</field>
            <field name="arch" type="xml">
                <form string="معالج تقرير عرض السعر">
                  <sheet>
                    <group name="main">
                      <group>
                        <field name="project_id"/>
                        <field name="from_date"/>
                      </group>
                      <group>
                        <field name="business_statement_id"/>
                        <field name="to_date"/>
                      </group>
                    </group>
                  </sheet>
                    <footer>
                        <button name="action_print" type="object" string="طباعة" class="oe_highlight"/>
                        or
                        <button special="cancel" string="إلغاء"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="b2b_quotation_report_action" model="ir.actions.act_window">
          <field name="name">معالج إجمالي بنود الأعمال</field>
          <field name="res_model">b2b.quotation.report.wizard</field>
          <field name="view_mode">form</field>
          <field name="target">new</field>
        </record>


    </data>
</openerp>

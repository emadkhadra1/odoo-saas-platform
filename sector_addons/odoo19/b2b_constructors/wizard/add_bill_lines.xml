<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
       <record id="view_add_bill_lines_form" model="ir.ui.view">
           <field name="name">view.add.bill.lines.form</field>
           <field name="model">add.bill.lines</field>
           <field name="arch" type="xml">
               <form string="Add Bill Lines Form">
                   <sheet>
                       <field name="name" invisible="1"/>
                       <field name="project_id" invisible="1"/>
                       <field name="bill_id" invisible="1"/>
                       <field name="entrepreneurs_ids" domain="[('project_id', '=', project_id)]"/>
                   </sheet>
                   <footer>
                        <button name="action_assign" type="object" string="Assign" class="oe_highlight"/>
                        or
                        <button special="cancel" string="Cancel"/>
                    </footer>
               </form>
           </field>
       </record>
        
        <record id="action_add_bill_lines_view" model="ir.actions.act_window">
            <field name="name">Add Bill Lines</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">add.bill.lines</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_bill_id': active_id}</field>
        </record>
    
    </data>
</odoo>
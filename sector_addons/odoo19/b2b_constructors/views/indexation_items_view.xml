<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <record id="view_indexation_items_form" model="ir.ui.view">
      <field name="name">view.b2b.indexation.items.form</field>
      <field name="model">b2b.indexation.items</field>
      <field name="arch" type="xml">
        <form string="بنود جدول الكميات">
          <sheet>
            <group name="main">
              <group>
                <field name="name"/>
              </group>
              <group>
                <field name="parent_id"/>
              </group>
            </group>
            <notebook>
              <page string="فرعي">
                <field name="child_ids">
                  <list editable="bottom">
                    <field name="name"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_indexation_items_tree" model="ir.ui.view">
      <field name="name">view.indexation_items.tree</field>
      <field name="model">b2b.indexation.items</field>
      <field name="arch" type="xml">
        <list string="بنود جدول الكميات">
          <field name="name"/>
          <field name="parent_id"/>
        </list>
      </field>
    </record>

    <record id="view_indexation_items_search" model="ir.ui.view">
      <field name="name">view.indexation_items.search</field>
      <field name="model">b2b.indexation.items</field>
      <field name="arch" type="xml">
        <search string="بنود جدول الكميات">
          <field name="name"/>
          <field name="parent_id"/>
          <group name="groupby">
            <filter name="parent_id_groupby" string="الأصل" context="{'group_by': 'parent_id'}"/>
          </group>
        </search>
      </field>
    </record>

    <record id="indexation_items_action" model="ir.actions.act_window">
      <field name="name">بنود جدول الكميات</field>
      <field name="res_model">b2b.indexation.items</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[]</field>
      <field name="context">{}</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Click to create a new Construction BOQ Items.
        </p>
      </field>
    </record>

  </data>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <record id="view_b2b_progress_bill_type_form" model="ir.ui.view">
      <field name="name">view.b2b.progress.bill.type.form</field>
      <field name="model">b2b.progress.bill.type</field>
      <field name="arch" type="xml">
        <form string="Construction Quotation Type">
          <sheet>
            <group name="main">
              <group>
                <field name="name"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_b2b_progress_bill_type_tree" model="ir.ui.view">
      <field name="name">view.b2b_progress_bill_type.tree</field>
      <field name="model">b2b.progress.bill.type</field>
      <field name="arch" type="xml">
        <list string="Construction Quotation Type">
          <field name="name"/>
        </list>
      </field>
    </record>

    <record id="view_b2b_progress_bill_type_search" model="ir.ui.view">
      <field name="name">view.b2b_progress_bill_type.search</field>
      <field name="model">b2b.progress.bill.type</field>
      <field name="arch" type="xml">
        <search string="Progress Bill Type">
          <field name="name"/>
        </search>
      </field>
    </record>

    <record id="b2b_progress_bill_type_action" model="ir.actions.act_window">
      <field name="name">Construction Quotation Type</field>
      <field name="res_model">b2b.progress.bill.type</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[]</field>
      <field name="context">{}</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Click to create a new Construction Quotation Type.
        </p>
      </field>
    </record>

  </data>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <record id="view_b2b_indexation_form" model="ir.ui.view">
      <field name="name">view.indexation.form</field>
      <field name="model">b2b.indexation</field>
      <field name="arch" type="xml">
        <form string="Construction BOQ Lines">
          <sheet>
            <group name="main">
              <group>
                <field name="purchase_order_id" context="{'default_is_construction': True}"/>
                <field name="uom_id"/>
                <field name="category"/>
                <field name="required_quantity"/>
                <field name="remaining_quantity"/>
              </group>
              <group>
                <field name="main_item_id"/>
                <field name="sub_item_id" context="{'default_parent_id': main_item_id}"/>
                <field name="business_statement_id" context="{'default_parent_id': sub_item_id}"/>
                <field name="finished_quantity"/>
                <field name="total"/>
              </group>
            </group>
          </sheet>
          <div class="oe_chatter">
              <field name="message_follower_ids" widget="mail_followers"/>
              <field name="message_ids" widget="mail_thread"/>
          </div>
        </form>
      </field>
    </record>

    <record id="view_b2b_indexation_tree" model="ir.ui.view">
      <field name="name">view.b2b_indexation.tree</field>
      <field name="model">b2b.indexation</field>
      <field name="arch" type="xml">
        <list string="Construction BOQ Lines">
          <field name="purchase_order_id"/>
          <field name="uom_id"/>
          <field name="category"/>
          <field name="main_item_id"/>
          <field name="sub_item_id"/>
          <field name="business_statement_id"/>
          <field name="required_quantity"/>
          <field name="remaining_quantity"/>
          <field name="finished_quantity"/>
          <field name="total"/>
        </list>
      </field>
    </record>

    <record id="view_b2b_indexation_search" model="ir.ui.view">
      <field name="name">view.b2b_indexation.search</field>
      <field name="model">b2b.indexation</field>
      <field name="arch" type="xml">
        <search string="Construction BOQ Lines">
          <field name="purchase_order_id" />
          <field name="uom_id"/>
          <field name="category"/>
          <field name="main_item_id"/>
          <field name="sub_item_id"/>
          <field name="business_statement_id"/>
          <field name="required_quantity"/>
          <field name="remaining_quantity"/>
          <field name="finished_quantity"/>
          <field name="total"/>
          <group name="groupby">
            <filter name="purchase_order_id_groupby" string="Constrution BOQ" context="{'group_by': 'purchase_order_id'}"/>
            <filter name="uom_id_groupby" string="Unit" context="{'group_by': 'uom_id'}"/>
            <filter name="main_item_id_groupby" string="Main Item" context="{'group_by': 'main_item_id'}"/>
            <filter name="sub_item_id_groupby" string="Su b Item" context="{'group_by': 'sub_item_id'}"/>
            <filter name="business_statement_id_groupby" string="Business Statement" context="{'group_by': 'business_statement_id'}"/>
          </group>
        </search>
      </field>
    </record>

    <record id="b2b_indexation_action" model="ir.actions.act_window">
      <field name="name">Construction BOQ Lines</field>
      <field name="res_model">b2b.indexation</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[]</field>
      <field name="context">{}</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Click to create a new Construction BOQ Lines.
        </p>
      </field>
    </record>

  </data>
</odoo>

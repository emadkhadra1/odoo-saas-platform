<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <record id="view_b2b_sub_business_item_form" model="ir.ui.view">
      <field name="name">view.b2b.boq.business.items.form</field>
      <field name="model">b2b.sub.business.items</field>
      <field name="arch" type="xml">
        <form string="BOQ Second Sub Item">
          <sheet>
            <group name="main">
              <group>
                <field name="name"/>
                <field name="code" class="oe_edit_only"/>
                <field name="group_code" class="oe_read_only"/>
<!--                <field name="uom_id"/>-->
              </group>
              <group>
                <field name="sub_item_id"/>
                <field name="main_item_id"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_b2b_sub_business_item_tree" model="ir.ui.view">
      <field name="name">view.b2b_sub_business_item.tree</field>
      <field name="model">b2b.sub.business.items</field>
      <field name="arch" type="xml">
        <list string="BOQ Second Sub Item">
          <field name="name"/>
          <field name="code"/>
          <field name="sub_item_id"/>
          <field name="main_item_id"/>
<!--          <field name="uom_id"/>-->
        </list>
      </field>
    </record>

    <record id="view_b2b_sub_business_item_search" model="ir.ui.view">
      <field name="name">view.b2b_sub_business_item.search</field>
      <field name="model">b2b.sub.business.items</field>
      <field name="arch" type="xml">
        <search string="BOQ Second Sub Item">
          <field name="name"/>
          <field name="code"/>
          <field name="sub_item_id"/>
<!--          <field name="uom_id"/>-->
          <group string="Group By" name="groupby">
            <filter name="main_item_id_groupby" string="BOQ Main Item" context="{'group_by': 'main_item_id'}"/>
            <filter name="sub_item_id_groupby" string="BOQ Sub Item" context="{'group_by': 'sub_item_id'}"/>
<!--            <filter name="uom_id_groupby" string="Unit" context="{'group_by': 'uom_id'}"/>-->
          </group>
        </search>
      </field>
    </record>

    <record id="b_2_b_sub_business_items_action" model="ir.actions.act_window">
        <field name="name">Second Sub Items</field>
        <field name="res_model">b2b.sub.business.items</field>
        <field name="view_mode">list,form</field>
    </record>
  </data>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <record id="view_b2b_entrepreneurs_form" model="ir.ui.view">
      <field name="name">view.b2b.entrepreneurs.form</field>
      <field name="model">b2b.entrepreneurs</field>
      <field name="arch" type="xml">
        <form string="Construction BOQ Assigned">
          <sheet>
            <group name="main">
              <group>
                <field name="indexation_id" invisible="0"/>
                <field name="purchase_order_id" readonly="0"/>
                <field name="project_id" readonly="0"/>
                <field name="main_item_id" readonly="0"/>
                <field name="sub_item_id" readonly="0"/>
                <field name="business_statement_id" readonly="0"/>
                <field name="uom_id" readonly="0"/>
              </group>
              <group>
                <field name="consructor_id" readonly="0"/>
                <field name="price" readonly="0"/>
                <field name="required_quantity" readonly="0"/>
                <field name="old_assigned" readonly="0"/>
                <field name="percent" readonly="0"/>
                <field name="total" readonly="0"/>
              </group>
            </group>
          </sheet>
          <div class="oe_chatter">
              <field name="message_follower_ids" widget="mail_followers"/>
              <field name="message_ids" widget="mail_thread"/>
          </div>
        </form>
      </field>
    </record>

    <record id="view_b2b_entrepreneurs_tree" model="ir.ui.view">
      <field name="name">view.b2b_entrepreneurs.tree</field>
      <field name="model">b2b.entrepreneurs</field>
      <field name="arch" type="xml">
        <list string="Construction BOQ Assigned">
          <field name="indexation_id" invisible="1"/>
          <field name="consructor_id"/>
          <field name="purchase_order_id"/>
          <field name="project_id"/>
          <field name="main_item_id"/>
          <field name="sub_item_id"/>
          <field name="business_statement_id"/>
          <field name="uom_id"/>
          <field name="price"/>
          <field name="required_quantity"/>
          <field name="old_assigned"/>
          <field name="percent"/>
          <field name="total"/>
        </list>
      </field>
    </record>

    <record id="view_b2b_entrepreneurs_search" model="ir.ui.view">
      <field name="name">view.b2b_entrepreneurs.search</field>
      <field name="model">b2b.entrepreneurs</field>
      <field name="arch" type="xml">
        <search string="Construction BOQ Assigned">
          <field name="consructor_id"/>
          <field name="purchase_order_id"/>
          <field name="project_id"/>
          <field name="main_item_id"/>
          <field name="sub_item_id"/>
          <field name="business_statement_id"/>
          <field name="uom_id"/>
          <field name="price"/>
          <field name="required_quantity"/>
          <field name="percent"/>
          <field name="total"/>
          <group name="groupby">
            <filter name="purchase_order_id_groupby" string="Construction BOQ" context="{'group_by': 'purchase_order_id'}"/>
            <filter name="project_id_groupby" string="Project" context="{'group_by': 'project_id'}"/>
            <filter name="consructor_id_groupby" string="Constructor" context="{'group_by': 'consructor_id'}"/>
            <filter name="main_item_id_groupby" string="BOQ Main Item" context="{'group_by': 'main_item_id'}"/>
            <filter name="sub_item_id_groupby" string="BOQ Sub Item" context="{'group_by': 'sub_item_id'}"/>
            <filter name="business_statement_id_groupby" string="BOQ Business Item" context="{'group_by': 'business_statement_id'}"/>
            <filter name="uom_id_groupby" string="Unit" context="{'group_by': 'uom_id'}"/>
          </group>
        </search>
      </field>
    </record>

    <record id="b2b_entrepreneurs_action" model="ir.actions.act_window">
      <field name="name">Construction BOQ Assigned</field>
      <field name="res_model">b2b.entrepreneurs</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[]</field>
      <field name="context">{}</field>
      <field name="help" type="html">
        <p class="oe_view_nocontent_create">
          Click to create a new Construction BOQ Assigned.
        </p>
      </field>
    </record>

  </data>
</odoo>

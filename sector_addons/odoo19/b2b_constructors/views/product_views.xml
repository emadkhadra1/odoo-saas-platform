<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_template_property_form" model="ir.ui.view">
            <field name="name">product.template.sub.property.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <data>
                    <field name="list_price" position="after">
                        <field name="main_item_id"  options="{'no_create': True}" />
                        <field name="sub_item_id"  options="{'no_create': True}" />
                    </field>

                </data>
            </field>
        </record>
      <record id="view_move_form" model="ir.ui.view">
            <field name="name">stock.move.sub.property.form.inherit</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_form"/>
            <field name="arch" type="xml">
                <data>
                    <field name="product_id" position="after">
                        <field name="main_item_id"  options="{'no_create': True}" invisible="0" readonly="1"/>
                        <field name="sub_item_id"  options="{'no_create': True}"  invisible="0" readonly="1"/>
                    </field>

                </data>
            </field>
        </record>

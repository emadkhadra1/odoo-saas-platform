        <record id="view_construction_transport_form" model="ir.ui.view">
            <field name="name">construction.transport.form</field>
            <field name="model">construction.transport</field>
            <field name="arch" type="xml">
                <form string="خدمة">
                    <header>
                        <button class="oe_highlight" groups="construction_project.service_manager_group" invisible="state not in ['new']" name="confirm" string="تأكيد" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <!--                        <div class="oe_title">-->
                        <!--                            &lt;!&ndash;<label string="أمر استلام"  />&ndash;&gt;-->
                        <!--                            <h1>-->
                        <!--                                <field name="name" readonly="1"/>-->
                        <!--                            </h1>-->
                        <!--                        </div>-->
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="project_id" readonly="state == 'done'"/>
                                <field name="employment" readonly="state == 'done'"/>
                                <field name="boq_id" readonly="state == 'done'"/>
                                <field invisible="1" name="business_item_ids"/>
                                <field name="business_item_id" readonly="state == 'done'"/>
                            </group>
                            <group>
                                <field name="date" readonly="state == 'done'"/>
                                <field name="total_cost"/>
                                <field name="journal_id"/>
                                <field name="debit_account_id"/>
                                <field name="credit_account_id"/>
                                <field invisible="state == 'new'" name="account_move_id"/>
                            </group>
                        </group>
                        <group string="النقل"/>
                        <field name="line_ids" readonly="state == 'done'">
                            <list editable="bottom">
                                <field name="transport_id"/>
                                <field name="product_uom_id"/>
                                <field invisible="1" name="name"/>
                                <field name="order_qty" sum="الكمية"/>
                                <field name="qty" sum="الكمية"/>
                                <field name="unit_cost" sum="تكلفة الوحدة"/>
                                <field name="cost" sum="التكلفة"/>
                                <field name="transportation"/>
                            </list></field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form></field>
        </record>
        <record id="view_construction_transport_tree" model="ir.ui.view">
            <field name="name">construction.transport.tree</field>
            <field name="model">construction.transport</field>
            <field name="arch" type="xml">
                <list string="خدمة">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="date"/>
                    <field name="total_cost"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="view_construction_transport_action" model="ir.actions.act_window">
            <field name="name">نقل</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.transport</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
        <record id="view_construction_transports_form" model="ir.ui.view">
            <field name="name">construction.transports.form</field>
            <field name="model">construction.transports</field>
            <field name="arch" type="xml">
                <form string="النقل">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="product_uom_id"/>
                            <field name="unit_cost"/>
                        </group>
                    </sheet>
                </form></field>
        </record>
        <record id="view_construction_transports_tree" model="ir.ui.view">
            <field name="name">construction.transports.tree</field>
            <field name="model">construction.transports</field>
            <field name="arch" type="xml">
                <list string="النقل">
                    <field name="name"/>
                    <field name="product_uom_id"/>
                    <field name="unit_cost"/>
                </list></field>
        </record>
        <record id="view_transports_action" model="ir.actions.act_window">
            <field name="name">النقل</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.transports</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>

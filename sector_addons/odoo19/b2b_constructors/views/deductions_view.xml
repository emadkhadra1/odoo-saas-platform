<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_b2b_deduction_form" model="ir.ui.view">
            <field name="name">view.b2b.deductions.form</field>
            <field name="model">b2b.deductions</field>
            <field name="arch" type="xml">
                <form string="الخصومات">
                    <sheet>
                        <group name="main">
                            <group>
                                <field name="name"/>
                                <field name="type"/>

                            </group>
                            <group>
                                <field name="account_id" required='1'/>

                                <field name="amount"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="ملاحظات">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_b2b_deduction_tree" model="ir.ui.view">
            <field name="name">view.b2b_deduction.tree</field>
            <field name="model">b2b.deductions</field>
            <field name="arch" type="xml">
                <list string="الخصومات">
                    <field name="name"/>
                                        <field name="type"/>

                    <field name="amount" sum="الإجمالي"/>
                                        <field name="account_id"/>

                </list>
            </field>
        </record>

        <record id="view_b2b_deduction_search" model="ir.ui.view">
            <field name="name">view.b2b_deduction.search</field>
            <field name="model">b2b.deductions</field>
            <field name="arch" type="xml">
                <search string="الخصومات">
                    <field name="name"/>
                    <field name="type"/>

                    <field name="amount"/>
                    <field name="account_id"/>

                </search>
            </field>
        </record>

        <record id="b2b_deduction_action" model="ir.actions.act_window">
            <field name="name">الخصومات</field>
            <field name="res_model">b2b.deductions</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to create a new Deductions.
                </p>
            </field>
        </record>

    </data>
</odoo>

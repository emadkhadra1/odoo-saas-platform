<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_construction_project_form" model="ir.ui.view">
            <field name="name">construction.project.form</field>
            <field name="model">construction.project</field>
            <field name="inherit_id" ref="construction_project.view_construction_project_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='primary_insurance']" position="after">
                    <field name="owner_downpayment"/>
                </xpath>
                <xpath expr="//sheet/group[1]" position="after">
                    <group string="المقاولون"></group>
                    <field name="project_constructor_ids">
                        <list editable="bottom">
                            <field name="constructor_id"/>
                            <field name="project_id" invisible="1"/>
                            <field name="downpayment"/>
                        </list>
                    </field>
                </xpath>
            </field>
        </record>
        
    </data>
</odoo>
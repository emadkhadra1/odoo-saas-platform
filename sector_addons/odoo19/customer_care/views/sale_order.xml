<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="sale_order_view_tree_inherit_crm_inherit" model="ir.ui.view">
        <field name="name">sale_order_view_tree_inherit_crm_inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="real_estate.sale_order_view_tree_inherit_crm" />
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button class="oe_highlight" name="confirm_reschedule" string="Confirm Reschedule" type="object" />

            </xpath>
            <xpath expr="//field[@name='unit_delivery_date']" position="after">
                <field invisible="1" name="request_downgrade" />
                <field invisible="1" name="request_upgrade" />
                <field invisible="1" name="request_reschedule" />
                <field invisible="1" name="contract_rescheduled" />
                <field invisible="1" name="reschedule_confirmed" />
                <field context="{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}" force_save="1" name="original_contract_id" readonly="1" />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <widget bg_color="bg-info" name="web_ribbon" text="Downgraded" />
                <widget bg_color="bg-info" name="web_ribbon" text="Upgraded" />
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field context="{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}" name="rescheduled_contract_id" />
            </xpath>

        </field>
    </record>

    <record id="contract_form_view" model="ir.ui.view">
        <field name="name">sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="real_estate.sale_order_view_tree_inherit_crm" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">0</attribute>
                
            </xpath>
            <xpath expr="//header" position="replace">
                <header>
                    <button class="btn btn-info" groups="archer_realestate_notification.group_sale_director" name="action_sales_director_cancel" string="Sale director Approve" type="object" />
                    
                    
                    

                    
                    <button class="btn btn-info" groups="real_estate_security.group_manager,account.group_account_invoice,account.group_account_manager,account.group_account_user" name="action_accounting_approve" string="Accounting Approve" type="object" />
                    <button name="action_cancel_request" string="Cancel Request" type="object" />





                    <button class="btn btn-primary" groups="archer_realestate_notification.group_cfo_director" name="action_cfo_approve_upgrade" string="CFO Approve" type="object" />
                    <button class="btn-danger" groups="real_estate_security.group_manager,account.group_account_invoice,account.group_account_manager,account.group_account_user" name="action_rufus_cancel" string="Rufus Cancel" type="object" />

                    <button name="action_downgrade" string="Downgrade" type="object" />


                    <button class="oe_highlight" name="action_upgrade" string="Upgrade" type="object" />
                    
                    
                    
                    
                    <field name="state" statusbar_visible="draft,sent,sale" widget="statusbar" />
                </header>
            </xpath>
            <xpath expr="//field[@name='unit_delivery_date']" position="after">
                <field invisible="1" name="is_upgrade" />
                <field invisible="1" name="is_downgrade" />
                <field name="penalty_id" />
                <field name="new_unit_id" />
                <field name="penalty_type" />
                <field name="penalty_percentage" />
                <field name="penalty_amount" />
                <field name="total_penality" />
                <field force_save="1" name="cancellation_reason_id" readonly="1" />
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cancellation_credit_note_id" />
            </xpath>
        </field>
    </record>

    <record id="contract_tree_view" model="ir.ui.view">
        <field name="name">sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="real_estate.sale_order_view_tree2" />
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="edit">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_contract_menu" model="ir.actions.act_window">
        <field name="name">Contract</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'form_view_ref': 'customer_care.contract_form_view'}</field>
        <field name="view_id" ref="customer_care.contract_tree_view" />
        <field name="domain">[('state', 'in', ['sale', 'reservation', 'upgraded', 'downgraded', 'rescheduled', 'cancel',
                                               'cancel_request','accounting_approve','cfo_cancel','sales_director_cancel']), ('unit_id', '!=',
                                                                    False)]
        </field>
    </record>

    <menuitem id="customer_care_root" name="Customer Care" sequence="7" web_icon="customer_care,static/description/icon.png" />

    <menuitem action="customer_care.action_contract_menu" id="contract_menu" name="Contracts" parent="customer_care.customer_care_root" sequence="1" />

    <menuitem id="customer_care_config" name="Configuration" parent="customer_care_root" sequence="100" />


</odoo>
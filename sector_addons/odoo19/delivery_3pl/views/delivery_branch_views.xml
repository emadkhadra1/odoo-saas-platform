<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_branch_tree" model="ir.ui.view">
        <field name="name">delivery.company.branch.tree</field>
        <field name="model">delivery.company.branch</field>
        <field name="arch" type="xml">
            <list string="الفروع" decoration-success="is_active == True" decoration-muted="is_active == False">
                <field name="branch_code" string="كود الفرع" optional="show"/>
                <field name="name" string="اسم الفرع"/>
                <field name="company_id" string="الشركة"/>
                <field name="city_id" string="المدينة"/>
                <field name="contact_person" string="مسؤول التواصل" optional="show"/>
                <field name="contact_phone" string="هاتف التواصل" optional="hide"/>
                <field name="contract_count" string="العقود"/>
                <field name="rider_count" string="المناديب"/>
                <field name="is_active" string="نشط؟" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_delivery_branch_form" model="ir.ui.view">
        <field name="name">delivery.company.branch.form</field>
        <field name="model">delivery.company.branch</field>
        <field name="arch" type="xml">
            <form string="فرع الشركة">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contracts" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="contract_count" widget="statinfo" string="العقود"/>
                        </button>
                        <button name="action_view_riders" type="object"
                                class="oe_stat_button" icon="fa-motorcycle">
                            <field name="rider_count" widget="statinfo" string="المناديب"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم الفرع بالإنجليزية"/></h1>
                    </div>
                    <group>
                        <group string="بيانات عامة">
                            <field name="company_id" string="الشركة"/>
                            <field name="city_id" string="المدينة"/>
                            <field name="branch_code" string="كود الفرع"/>
                            <field name="name_ar" string="اسم الفرع بالعربية" placeholder="اسم الفرع بالعربية"/>
                            <field name="is_active" string="نشط؟"/>
                        </group>
                        <group string="بيانات التواصل">
                            <field name="contact_person" string="مسؤول التواصل"/>
                            <field name="contact_phone" string="رقم الهاتف"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="العقود" name="contracts">
                            <field name="contract_ids" mode="list" readonly="1">
                                <list string="العقود">
                                    <field name="contract_number" string="رقم العقد"/>
                                    <field name="version" string="الإصدار"/>
                                    <field name="status" string="الحالة" widget="badge"
                                           decoration-success="status == 'active'"
                                           decoration-info="status == 'draft'"
                                           decoration-muted="status == 'expired'"/>
                                    <field name="start_date" string="تاريخ البدء"/>
                                    <field name="end_date" string="تاريخ الانتهاء"/>
                                </list>
                            </field>
                        </page>
                        <page string="قواعد التسعير" name="pricing">
                            <field name="pricing_rule_ids" mode="list" readonly="1">
                                <list string="قواعد التسعير">
                                    <field name="name" string="اسم القاعدة"/>
                                    <field name="pricing_type" string="نوع التسعير" widget="badge"/>
                                    <field name="base_amount" string="المبلغ الأساسي"/>
                                    <field name="is_active" string="نشط؟"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_delivery_branch_search" model="ir.ui.view">
        <field name="name">delivery.company.branch.search</field>
        <field name="model">delivery.company.branch</field>
        <field name="arch" type="xml">
            <search string="بحث في الفروع">
                <field name="name"/>
                <field name="branch_code"/>
                <field name="company_id"/>
                <field name="city_id"/>
                <filter name="active_branches" string="نشطة" domain="[('is_active', '=', True)]"/>
                <filter name="inactive_branches" string="غير نشطة" domain="[('is_active', '=', False)]"/>
                <group>
                    <filter name="group_company" string="الشركة" context="{'group_by': 'company_id'}"/>
                    <filter name="group_city" string="المدينة" context="{'group_by': 'city_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_delivery_branch" model="ir.actions.act_window">
        <field name="name">الفروع</field>
        <field name="res_model">delivery.company.branch</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active_branches': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">أضف أول فرع</p>
            <p>الفروع تمثل المناطق الجغرافية التشغيلية لكل شركة توصيل.</p>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════════
         العقود — قائمة
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_delivery_contract_tree" model="ir.ui.view">
        <field name="name">delivery.contract.tree</field>
        <field name="model">delivery.contract</field>
        <field name="arch" type="xml">
            <list string="العقود"
                  decoration-success="status == 'active'"
                  decoration-muted="status in ('expired', 'terminated')">
                <field name="company_id" string="الشركة"/>
                <field name="branch_id" string="الفرع" optional="show"/>
                <field name="contract_number" string="رقم العقد"/>
                <field name="version" string="الإصدار"/>
                <field name="rider_type" string="نوع المندوبين" widget="badge"
                       decoration-primary="rider_type == 'kafala'"
                       decoration-info="rider_type == 'freelance'"
                       decoration-muted="rider_type == 'all'"/>
                <field name="pricing_mode" string="نمط التسعير" widget="badge"
                       decoration-success="pricing_mode == 'fixed_fee'"
                       decoration-info="pricing_mode in ('tier_per_order', 'keeta')"
                       decoration-warning="pricing_mode == 'standard'"
                       decoration-primary="pricing_mode == 'hungerstation_internal'"/>
                <field name="status" string="الحالة" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-info="status == 'draft'"
                       decoration-warning="status == 'expired'"
                       decoration-danger="status == 'terminated'"/>
                <field name="start_date" string="تاريخ البدء"/>
                <field name="end_date" string="تاريخ الانتهاء"/>
                <field name="settlement_cycle" string="دورة التسوية"/>
                <field name="rider_monthly_fee" string="رسوم شهرية (ريال)" optional="show"/>
                <field name="service_provider_id" string="الشركة المزودة" optional="show"/>
                <field name="auto_renew" string="تجديد تلقائي؟" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         العقود — نموذج
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_delivery_contract_form" model="ir.ui.view">
        <field name="name">delivery.contract.form</field>
        <field name="model">delivery.contract</field>
        <field name="arch" type="xml">
            <form string="عقد">
                <header>
                    <button name="action_activate" type="object" string="تفعيل"
                            class="oe_highlight"
                            invisible="status != 'draft'"/>
                    <button name="action_terminate" type="object" string="إنهاء العقد"
                            class="btn-danger"
                            invisible="status != 'active'"
                            confirm="هل أنت متأكد من إنهاء هذا العقد؟"/>
                    <button name="action_reactivate" type="object" string="↩ إعادة تفعيل"
                            invisible="status not in ('terminated', 'expired')"
                            confirm="سيتم إرجاع العقد إلى حالة مسودة. يمكنك مراجعته ثم الضغط على &quot;تفعيل&quot;. هل تريد المتابعة؟"/>
                    <button name="action_renew" type="object" string="تجديد"
                            invisible="status not in ('active', 'expired')"/>
                    <button name="action_create_default_rules" type="object"
                            string="⚙ إنشاء قواعد التسعير الافتراضية"
                            invisible="pricing_mode != 'standard' or (status != 'draft' and status != 'active')"
                            confirm="سيتم إنشاء قواعد التسعير والصلاحية الافتراضية. القواعد الموجودة لن تتأثر. هل تريد المتابعة؟"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,active,expired,terminated"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="contract_number" placeholder="رقم العقد"/>
                            <span class="text-muted"> v</span>
                            <field name="version" class="oe_inline"/>
                        </h1>
                    </div>

                    <!-- الإعدادات الأساسية -->
                    <group>
                        <group string="الشركة والفرع">
                            <field name="company_id" string="الشركة"/>
                            <field name="branch_id" string="الفرع"/>
                            <field name="rider_type" string="نوع المندوبين"
                                   widget="radio" options="{'horizontal': true}"/>
                            <field name="start_date" string="تاريخ البدء"/>
                            <field name="end_date" string="تاريخ الانتهاء"/>
                        </group>
                        <group string="دورة التسوية">
                            <field name="settlement_cycle" string="دورة التسوية"/>
                            <field name="payment_terms_days" string="أيام شروط الدفع"/>
                            <field name="auto_renew" string="تجديد تلقائي؟"/>
                        </group>
                    </group>

                    <!-- اختيار نمط التسعير -->
                    <group string="🔧 نمط التسعير">
                        <field name="pricing_mode" widget="radio" nolabel="1"
                               style="font-size: 14px;"/>
                    </group>

                    <!-- نمط: رسوم شهرية ثابتة (هنقر فرى / جاهز / توجو) -->
                    <group string="💰 رسوم شهرية ثابتة — هنقر فرى / جاهز / توجو"
                           invisible="pricing_mode != 'fixed_fee'">
                        <div class="alert alert-success" role="alert">
                            <strong>🟢 رسوم شهرية ثابتة</strong><br/>
                            الشركة تستقطع مبلغاً ثابتاً من كل مندوب شهرياً وتُسلّم الباقي للمزود.
                            <em>صافي مزود الخدمة = إجمالي من التطبيق − (الرسوم × عدد المناديب)</em>
                        </div>
                        <group>
                            <field name="rider_monthly_fee" string="الرسوم الشهرية الثابتة للمندوب (ريال)"/>
                            <field name="service_provider_id" string="الشركة المزودة للخدمة"/>
                        </group>
                    </group>

                    <!-- نمط: كفالة هنقر -->
                    <group string="🟡 كفالة هنقر — تارجيت + راتب"
                           invisible="pricing_mode != 'hungerstation_internal'">
                        <div class="alert alert-warning" role="alert">
                            <strong>🟡 كفالة هنقرستيشين</strong><br/>
                            <strong>≥ تارجيت:</strong> راتب أساسي + (طلبات إضافية × سعر الطلب)
                            <br/>
                            <strong>أقل من التارجيت:</strong> عدد الطلبات × سعر ثابت
                        </div>
                        <group string="التارجيت والراتب">
                            <field name="hs_target_orders" string="تارجيت الطلبات"/>
                            <field name="hs_base_salary" string="الراتب الأساسي عند التارجيت (ريال)"/>
                            <field name="hs_rate_above_target" string="سعر الطلب الإضافي فوق التارجيت (ريال/طلب)"/>
                            <field name="hs_rate_below_target" string="سعر الطلب عند عدم التارجيت (ريال/طلب)"/>
                        </group>
                    </group>

                    <!-- نمط: كيتا — 4 حالات -->
                    <group string="🔵 كيتا — 4 حالات (صالح/غير صالح × تارجيت/بدون)"
                           invisible="pricing_mode != 'keeta'">
                        <div class="alert alert-info" role="alert">
                            <strong>🔵 كيتا — 4 حالات</strong><br/>
                            <strong>ح1 — صالح + تارجيت:</strong> أساسي + إضافي + بونص الشركة + تعديل A/B/C/D<br/>
                            <strong>ح2 — صالح + بلا تارجيت:</strong> طلبات × سعر ثابت<br/>
                            <strong>ح3 — غير صالح + تارجيت:</strong> طلبات × سعر ثابت<br/>
                            <strong>ح4 — غير صالح + بلا تارجيت:</strong> طلبات × سعر ثابت
                        </div>
                        <group string="التارجيت والراتب الأساسي">
                            <field name="keeta_target_orders" string="تارجيت الطلبات الشخصي"/>
                            <field name="keeta_base_salary" string="الراتب الأساسي عند التارجيت (ريال)"/>
                        </group>
                        <group string="الطلبات الإضافية فوق التارجيت">
                            <field name="keeta_extra_threshold" string="الحد الثاني (مثال: 400 طلب)"/>
                            <field name="keeta_rate_extra_1" string="سعر الطلب (التارجيت ← الحد الثاني) ريال/طلب"/>
                            <field name="keeta_rate_extra_2" string="سعر الطلب (فوق الحد الثاني) ريال/طلب"/>
                        </group>
                        <group string="بونص تارجيت الشركة">
                            <field name="keeta_company_bonus_pct" string="نسبة بونص الشركة للمندوب (%)"/>
                        </group>
                        <group string="تعديلات شرائح الأداء A/B/C/D">
                            <field name="keeta_tier_a_bonus" string="بونص A (ريال)"/>
                            <field name="keeta_tier_b_penalty" string="خصم B (ريال)"/>
                            <field name="keeta_tier_c_penalty" string="خصم C (ريال)"/>
                            <field name="keeta_tier_d_penalty" string="خصم D (ريال)"/>
                        </group>
                        <group string="أسعار الحالات الأخرى">
                            <field name="keeta_valid_no_target_rate" string="ح2 — صالح + بلا تارجيت (ريال/طلب)"/>
                            <field name="keeta_invalid_target_rate" string="ح3 — غير صالح + تارجيت (ريال/طلب)"/>
                            <field name="keeta_invalid_no_target_rate" string="ح4 — غير صالح + بلا تارجيت (ريال/طلب)"/>
                        </group>
                    </group>

                    <!-- نمط: شرائح لكل طلب (النمط القديم) — معلومات فقط -->
                    <group string="📊 شرائح التسعير (النمط القديم)"
                           invisible="pricing_mode != 'tier_per_order'">
                        <div class="alert alert-secondary" role="alert">
                            <strong>📊 النمط القديم:</strong>
                            عدد المناديب الصالحين يحدد الشريحة → سعر الطلب × طلبات كل مندوب صالح.
                            أضف الشرائح في تبويب "شرائح التسعير" أدناه.
                        </div>
                    </group>

                    <notebook>
                        <!-- ✅ شروط صلاحية المندوب — تظهر دائماً لجميع الأنماط -->
                        <page string="✅ شروط صلاحية المندوب" name="validity">
                            <div class="alert alert-warning mb-2" role="alert">
                                <strong>شروط الصلاحية (Valid DA):</strong>
                                المندوب "صالح" إذا حقق هذه الشروط الشهرية — مطلوب لاستحقاق الحوافز والتسوية.
                                <span invisible="pricing_mode == 'standard' or pricing_mode == 'tier_per_order'">
                                    <br/><strong>ملاحظة:</strong> في نمطي كيتا وكفالة هنقر، تُحدد صلاحية المندوب من هنا لحساب الحالة الصحيحة في التسوية.
                                </span>
                            </div>
                            <field name="validity_criteria_ids">
                                <list string="شروط الصلاحية" editable="bottom">
                                    <field name="name" string="اسم الشرط"
                                           placeholder="مثال: شروط الصلاحية الافتراضية"/>
                                    <field name="min_daily_online_hours" string="الحد الأدنى للساعات اليومية"/>
                                    <field name="min_valid_days" string="الحد الأدنى للأيام الصالحة شهرياً"/>
                                    <field name="min_monthly_orders" string="الحد الأدنى للطلبات شهرياً"/>
                                    <field name="must_attend_first_days" string="حضور أول N يوم" optional="show"/>
                                    <field name="must_attend_last_days" string="حضور آخر N يوم" optional="show"/>
                                    <field name="must_attend_min_valid" string="الحد الأدنى للحضور الإلزامي" optional="show"/>
                                    <field name="is_active" widget="boolean_toggle" string="نشط؟"/>
                                </list>
                            </field>
                        </page>

                        <!-- 🎯 تارجيت الشركة الشهري — تظهر دائماً -->
                        <page string="🎯 تارجيت الشركة الشهري" name="targets">
                            <div class="alert alert-info mb-2" role="alert">
                                <strong>تارجيت الشركة الشهري:</strong>
                                سجّل الأرقام الفعلية لكل شهر.
                                <span invisible="pricing_mode != 'keeta'">
                                    <br/><strong>📌 مهم لكيتا:</strong>
                                    حقل "إجمالي الشركة (بدون ضريبة)" يُستخدم لحساب بونص
                                    <strong><field name="keeta_company_bonus_pct" class="oe_inline" readonly="1"/>%</strong>
                                    الموزع على المناديب الصالحين الذين حققوا التارجيت.
                                </span>
                            </div>
                            <field name="company_target_ids">
                                <list string="تارجيتات الشركة"
                                      decoration-success="target_met == True"
                                      decoration-danger="target_met == False">
                                    <field name="period_display" string="الفترة"/>
                                    <field name="actual_valid_das" string="المناديب الصالحون الفعليون"/>
                                    <field name="achieved_level" string="الشريحة المحققة"/>
                                    <field name="target_met" string="تحقق التارجيت؟" widget="boolean"/>
                                    <field name="tga_excl_vat" string="إجمالي الشركة (بدون ضريبة)"/>
                                    <field name="total_due" string="المبلغ المستحق"/>
                                    <field name="notes" string="ملاحظات" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <!-- 📊 شرائح التسعير (النمط القديم) -->
                        <page string="📊 شرائح التسعير" name="tiers"
                              invisible="pricing_mode != 'tier_per_order'">
                            <div class="alert alert-warning mb-2" role="alert">
                                <strong>كيفية ضبط الشرائح:</strong>
                                أضف شريحة لكل مستوى من مستويات التارجيت.
                            </div>
                            <field name="tier_ids">
                                <list string="شرائح التسعير" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="اسم الشريحة" placeholder="مثال: شريحة A"/>
                                    <field name="min_company_valid_das" string="الحد الأدنى من المناديب الصالحين"/>
                                    <field name="max_company_valid_das" string="الحد الأقصى (0 = غير محدود)"/>
                                    <field name="price_per_order_bike" string="سعر الطلب — دراجة (ريال)"/>
                                    <field name="price_per_order_car" string="سعر الطلب — سيارة (ريال)"/>
                                    <field name="notes" string="ملاحظات" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <!-- ⚙ قواعد التسعير المتقدمة — تظهر دائماً -->
                        <page string="⚙ قواعد التسعير" name="pricing">
                            <div invisible="pricing_mode == 'standard'">
                                <div class="alert alert-info mb-2" role="alert">
                                    <strong>ملاحظة:</strong>
                                    هذا العقد يستخدم نمط <strong>
                                    <field name="pricing_mode" class="oe_inline" readonly="1"/>
                                    </strong> — التسوية تُحسب تلقائياً من إعدادات النمط أعلاه.
                                    <br/>يمكن إضافة قواعد هنا كمرجع فقط دون تأثير على الحساب.
                                </div>
                            </div>
                            <div invisible="pricing_mode != 'standard'">
                                <div class="alert alert-secondary mb-2" role="alert">
                                    <strong>النمط المتقدم:</strong>
                                    فعّل القاعدة المناسبة (لكل طلب / شرائح / راتب ثابت / لكل كم).
                                    اضغط <strong>"إنشاء القواعد الافتراضية"</strong> أعلاه للبدء السريع.
                                </div>
                            </div>
                            <field name="pricing_rule_ids">
                                <list string="قواعد التسعير"
                                      decoration-success="is_active == True"
                                      decoration-muted="is_active == False">
                                    <field name="name" string="اسم القاعدة"/>
                                    <field name="company_id" column_invisible="1"/>
                                    <field name="branch_id" column_invisible="1"/>
                                    <field name="pricing_type" string="نوع التسعير" widget="badge"/>
                                    <field name="vehicle_type" string="نوع المركبة"/>
                                    <field name="base_amount" string="المبلغ الأساسي (ريال)"/>
                                    <field name="per_km_amount" string="لكل كم" optional="show"/>
                                    <field name="daily_rate" string="المعدل اليومي" optional="show"/>
                                    <field name="monthly_total" string="الإجمالي الشهري" optional="show"/>
                                    <field name="slab_count" string="شرائح"/>
                                    <field name="effective_from" string="تاريخ التطبيق"/>
                                    <field name="effective_to" string="تاريخ الانتهاء" optional="show"/>
                                    <field name="is_active" string="نشطة؟" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>

                        <!-- ⭐ نقاط الخبرة — تظهر دائماً -->
                        <page string="⭐ نقاط الخبرة" name="experience">
                            <div invisible="pricing_mode not in ('standard', 'keeta')">
                                <div class="alert alert-secondary mb-2" role="alert">
                                    <strong>إعداد نقاط الخبرة:</strong>
                                    يُحدد كيفية ترتيب المناديب في مستويات A/B/C/D بناءً على مؤشرات الأداء.
                                    <span invisible="pricing_mode != 'keeta'">
                                        <br/>📌 <strong>لكيتا:</strong> المستوى يؤثر على التعديل في الحالة 1 (صالح + تارجيت).
                                    </span>
                                </div>
                            </div>
                            <field name="experience_config_ids">
                                <list string="إعداد نقاط الخبرة" editable="bottom">
                                    <field name="name" string="الاسم"/>
                                    <field name="on_time_delivery_weight" string="وزن الالتزام بالوقت (%)"/>
                                    <field name="cancellation_rate_weight" string="وزن نسبة الإلغاء (%)"/>
                                    <field name="advance_delivery_weight" string="وزن التوصيل المبكر (%)"/>
                                    <field name="min_orders_for_ranking" string="الحد الأدنى للطلبات"/>
                                    <field name="only_valid_da_eligible" string="للصالحين فقط؟"/>
                                    <field name="is_active" widget="boolean_toggle" string="نشط؟"/>
                                </list>
                            </field>
                        </page>

                        <!-- 💰 التسويات -->
                        <page string="💰 التسويات" name="settlements">
                            <field name="settlement_ids">
                                <list string="التسويات"
                                      decoration-success="status == 'approved'"
                                      decoration-info="status == 'draft'"
                                      decoration-warning="status == 'pending_approval'">
                                    <field name="settlement_number" string="رقم التسوية"/>
                                    <field name="period_start" string="بداية الفترة"/>
                                    <field name="period_end" string="نهاية الفترة"/>
                                    <field name="total_orders" string="إجمالي الطلبات"/>
                                    <field name="gross_amount" string="الإجمالي"/>
                                    <field name="net_amount" string="الصافي"/>
                                    <field name="valid_rider_count" string="مناديب صالحون"/>
                                    <field name="status" string="الحالة" widget="badge"/>
                                </list>
                            </field>
                        </page>

                        <!-- 📥 جلسات الاستيراد -->
                        <page string="📥 جلسات الاستيراد" name="imports">
                            <field name="import_session_ids">
                                <list string="جلسات الاستيراد">
                                    <field name="file_name" string="اسم الملف"/>
                                    <field name="import_date" string="تاريخ الاستيراد"/>
                                    <field name="total_rows" string="إجمالي الصفوف"/>
                                    <field name="valid_rows" string="صفوف صحيحة"/>
                                    <field name="error_rows" string="صفوف بها خطأ"/>
                                    <field name="status" string="الحالة" widget="badge"/>
                                </list>
                            </field>
                        </page>

                        <!-- 📜 السياسات والملاحظات -->
                        <page string="📜 السياسات والملاحظات" name="policies">
                            <group>
                                <group string="سياسة الجزاءات">
                                    <field name="penalty_policy" nolabel="1"
                                           placeholder="أدخل سياسة الجزاءات هنا..."/>
                                </group>
                                <group string="سياسة التأمين">
                                    <field name="deposit_policy" nolabel="1"
                                           placeholder="أدخل سياسة التأمين هنا..."/>
                                </group>
                            </group>
                            <field name="notes" placeholder="ملاحظات إضافية..."/>
                        </page>

                        <!-- 🗺️ خريطة أعمدة Excel -->
                        <page string="🗺️ خريطة أعمدة Excel" name="mapping">
                            <field name="column_map_ids">
                                <list editable="bottom" string="خريطة الأعمدة">
                                    <field name="sequence" widget="handle"/>
                                    <field name="excel_column" string="عمود Excel"/>
                                    <field name="system_field" string="الحقل في النظام"/>
                                    <field name="custom_key" string="مفتاح إضافي"
                                           invisible="system_field != '_extra_'"/>
                                    <field name="notes" string="ملاحظة" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         بحث العقود
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_delivery_contract_search" model="ir.ui.view">
        <field name="name">delivery.contract.search</field>
        <field name="model">delivery.contract</field>
        <field name="arch" type="xml">
            <search string="بحث في العقود">
                <field name="contract_number" string="رقم العقد"/>
                <field name="company_id" string="الشركة"/>
                <field name="branch_id" string="الفرع"/>
                <filter name="active_status" string="نشطة" domain="[('status', '=', 'active')]"/>
                <filter name="draft_status" string="مسودة" domain="[('status', '=', 'draft')]"/>
                <filter name="expired_status" string="منتهية" domain="[('status', '=', 'expired')]"/>
                <separator/>
                <filter name="mode_fixed_fee" string="رسوم ثابتة (هنقر فرى/جاهز/توجو)"
                        domain="[('pricing_mode', '=', 'fixed_fee')]"/>
                <filter name="mode_hs_internal" string="كفالة هنقر"
                        domain="[('pricing_mode', '=', 'hungerstation_internal')]"/>
                <filter name="mode_keeta" string="كيتا (4 حالات)"
                        domain="[('pricing_mode', '=', 'keeta')]"/>
                <filter name="mode_tier" string="شرائح لكل طلب (قديم)"
                        domain="[('pricing_mode', '=', 'tier_per_order')]"/>
                <filter name="mode_standard" string="النمط المتقدم"
                        domain="[('pricing_mode', '=', 'standard')]"/>
                <group expand="0" string="تجميع بـ">
                    <filter name="group_company" string="الشركة" context="{'group_by': 'company_id'}"/>
                    <filter name="group_branch" string="الفرع" context="{'group_by': 'branch_id'}"/>
                    <filter name="group_status" string="الحالة" context="{'group_by': 'status'}"/>
                    <filter name="group_mode" string="نمط التسعير" context="{'group_by': 'pricing_mode'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_delivery_contract" model="ir.actions.act_window">
        <field name="name">العقود</field>

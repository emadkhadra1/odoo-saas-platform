<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_hr_custody" model="ir.ui.view">
        <field name="name">hr.employee.form.hr.custody</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_custodies" type="object" class="oe_stat_button" icon="fa-briefcase">
                    <field name="custody_count" widget="statinfo" string="Custodies"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

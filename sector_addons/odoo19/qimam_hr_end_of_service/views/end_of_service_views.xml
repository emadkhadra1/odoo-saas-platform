<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qimam_hr_end_service_list" model="ir.ui.view">
        <field name="name">qimam.hr.end.service.list</field>
        <field name="model">qimam.hr.end.service</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'paid'" decoration-info="state in ('confirmed', 'approved')" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="termination_type"/>
                <field name="termination_date"/>
                <field name="service_years"/>
                <field name="net_amount" sum="الإجمالي"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_qimam_hr_end_service_form" model="ir.ui.view">
        <field name="name">qimam.hr.end.service.form</field>
        <field name="model">qimam.hr.end.service</field>
        <field name="arch" type="xml">
            <form string="تسوية نهاية الخدمة">
                <header>
                    <button name="action_confirm" string="تأكيد" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="اعتماد" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_mark_paid" string="تسجيل الصرف" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_cancel" string="إلغاء" type="object" invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_reset_to_draft" string="إرجاع إلى مسودة" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                            <field name="termination_type" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date_start" readonly="state != 'draft'"/>
                            <field name="termination_date" readonly="state != 'draft'"/>
                            <field name="wage" readonly="state != 'draft'"/>
                            <field name="service_years"/>
                        </group>
                    </group>
                    <group string="مبالغ التسوية">
                        <group>
                            <field name="gratuity_amount"/>
                            <field name="leave_balance_amount" readonly="state != 'draft'"/>
                            <field name="other_allowances" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="deductions" readonly="state != 'draft'"/>
                            <field name="net_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="ملاحظات">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_qimam_hr_end_service" model="ir.actions.act_window">
        <field name="name">نهاية الخدمة</field>
        <field name="res_model">qimam.hr.end.service</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qimam_hr_end_service" name="نهاية الخدمة" parent="hr.menu_hr_root" action="action_qimam_hr_end_service" sequence="42"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qimam_hr_medical_policy_list" model="ir.ui.view">
        <field name="name">qimam.hr.medical.policy.list</field>
        <field name="model">qimam.hr.medical.policy</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'" decoration-muted="state in ('expired', 'cancelled')">
                <field name="name"/>
                <field name="provider"/>
                <field name="policy_number"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="member_count"/>
                <field name="annual_premium" sum="Total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_qimam_hr_medical_policy_form" model="ir.ui.view">
        <field name="name">qimam.hr.medical.policy.form</field>
        <field name="model">qimam.hr.medical.policy</field>
        <field name="arch" type="xml">
            <form string="Medical Insurance Policy">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_expire" string="Expire" type="object" invisible="state != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'active')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="provider"/>
                            <field name="policy_number"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="annual_premium"/>
                        </group>
                    </group>
                    <field name="member_ids">
                        <list editable="bottom">
                            <field name="employee_id"/>
                            <field name="insurance_class"/>
                            <field name="membership_number"/>
                            <field name="dependent_count"/>
                            <field name="premium_amount"/>
                            <field name="state"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qimam_hr_medical_member_list" model="ir.ui.view">
        <field name="name">qimam.hr.medical.member.list</field>
        <field name="model">qimam.hr.medical.member</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'" decoration-muted="state != 'active'">
                <field name="employee_id"/>
                <field name="provider"/>
                <field name="policy_number"/>
                <field name="insurance_class"/>
                <field name="membership_number"/>
                <field name="date_end"/>
                <field name="premium_amount" sum="Total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_qimam_hr_medical_member_form" model="ir.ui.view">
        <field name="name">qimam.hr.medical.member.form</field>
        <field name="model">qimam.hr.medical.member</field>
        <field name="arch" type="xml">
            <form string="Employee Medical Insurance">
                <header>
                    <button name="action_activate" string="Activate" type="object" invisible="state != 'suspended'"/>
                    <button name="action_suspend" string="Suspend" type="object" invisible="state != 'active'"/>
                    <button name="action_expire" string="Expire" type="object" invisible="state == 'expired'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,suspended,expired"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="policy_id"/>
                            <field name="provider"/>
                            <field name="policy_number"/>
                        </group>
                        <group>
                            <field name="insurance_class"/>
                            <field name="membership_number"/>
                            <field name="dependent_count"/>
                            <field name="premium_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_qimam_hr_medical_policy" model="ir.actions.act_window">
        <field name="name">Medical Policies</field>
        <field name="res_model">qimam.hr.medical.policy</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qimam_hr_medical_member" model="ir.actions.act_window">
        <field name="name">Employee Medical Insurance</field>
        <field name="res_model">qimam.hr.medical.member</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qimam_hr_medical_root" name="Medical Insurance" parent="hr.menu_hr_root" sequence="44"/>
    <menuitem id="menu_qimam_hr_medical_member" name="Covered Employees" parent="menu_qimam_hr_medical_root" action="action_qimam_hr_medical_member" sequence="10"/>
    <menuitem id="menu_qimam_hr_medical_policy" name="Policies" parent="menu_qimam_hr_medical_root" action="action_qimam_hr_medical_policy" sequence="20"/>
</odoo>

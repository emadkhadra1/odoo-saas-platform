    </data>
    <data>
        <record id="view_construction_tool_form" model="ir.ui.view">
            <field name="name">construction.tool.form</field>
            <field name="model">construction.tool</field>
            <field name="arch" type="xml">
                <form string="خدمة">
                    <header>
                        <button class="oe_highlight" groups="construction_project.service_manager_group" invisible="state not in ['new']" name="confirm" string="تأكيد" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <!--                        <div class="oe_title">-->
                        <!--                            &lt;!&ndash;<label string="أمر استلام"  />&ndash;&gt;-->
                        <!--                            <h1>-->
                        <!--                                <field name="name" readonly="1"/>-->
                        <!--                            </h1>-->
                        <!--                        </div>-->
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="project_id" readonly="state == 'done'"/>
                            </group>
                            <group>
                                <field name="date" readonly="state == 'done'"/>
                                <field name="total_cost"/>
                                <field name="journal_id"/>
                                <field name="debit_account_id"/>
                                <field name="credit_account_id"/>
                                <field invisible="state == 'new'" name="account_move_id"/>
                            </group>
                        </group>
                        <group string="الأدوات"/>
                        <field name="line_ids" readonly="state == 'done'">
                            <list editable="bottom">
                                <field name="tool_id"/>
                                <field name="product_uom_id"/>
                                <field invisible="1" name="name"/>
                                <field name="order_qty" sum="الكمية"/>
                                <field name="qty" sum="الكمية"/>
                                <field name="unit_cost" sum="تكلفة الوحدة"/>
                                <field name="cost" sum="التكلفة"/>
                            </list></field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form></field>
        </record>
        <record id="view_construction_tool_tree" model="ir.ui.view">
            <field name="name">construction.tool.tree</field>
            <field name="model">construction.tool</field>
            <field name="arch" type="xml">
                <list string="خدمة">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="date"/>
                    <field name="total_cost"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="view_construction_tool_action" model="ir.actions.act_window">
            <field name="name">الأدوات</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.tool</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
        <record id="view_construction_tools_form" model="ir.ui.view">
            <field name="name">construction.tools.form</field>
            <field name="model">construction.tools</field>
            <field name="arch" type="xml">
                <form string="الأدوات">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="product_uom_id"/>
                            <field name="unit_cost"/>
                        </group>
                    </sheet>
                </form></field>
        </record>
        <record id="view_construction_tools_tree" model="ir.ui.view">
            <field name="name">construction.tools.tree</field>
            <field name="model">construction.tools</field>
            <field name="arch" type="xml">
                <list string="الأدوات">
                    <field name="name"/>
                    <field name="product_uom_id"/>
                    <field name="unit_cost"/>
                </list></field>
        </record>
        <record id="view_tools_action" model="ir.actions.act_window">
            <field name="name">الأدوات</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.tools</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
    </data>
</odoo>

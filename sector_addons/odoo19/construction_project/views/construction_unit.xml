    <data>


        <record id="view_project_unit_form" model="ir.ui.view">
            <field name="name">project.unit.form</field>
            <field name="model">project.unit</field>
            <field name="arch" type="xml">
                <form string="Project Unit">

                    <sheet>
                        <group>
                            <group>
                                <field name="project_id"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="unit_location"/>
                                <field name="unit_description"/>
                                <field name="total_unit_cost"/>
                            </group>
                        </group>
                        <field name="project_item_ids"/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_project_unit_tree" model="ir.ui.view">
            <field name="name">project.unit.tree</field>
            <field name="model">project.unit</field>
            <field name="arch" type="xml">
                <list string="Project Unit">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="unit_location"/>
                    <field name="unit_description"/>
                    <field name="total_unit_cost"/>
                    <field name="project_item_ids"/>
                </list>
            </field>
        </record>

        <record id="view_project_unit_action" model="ir.actions.act_window">
            <field name="name">Project Unit</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">project.unit</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">

    <data>

        <!--construction.project-->

        <record id="view_construction_project_form" model="ir.ui.view">
            <field name="name">construction.project.form</field>
            <field name="model">construction.project</field>
            <field name="arch" type="xml">
                <form string="Construction Project">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="partner_id" context="{'default_customer_rank': 1}"/>
                                <field name="location_dest_id" invisible="0"/>
                                <field name="location_create" invisible="1"/>

                                <field name="purpose_of_the_project"/>
                                <field name="project_description"/>
                                <field name="analytic_account_id" readonly="1"/>

                            </group>

                            <group>
                                <field name="company_id" invisible="0"/>
                                <field name="warehouse_id" invisible="0" readonly="0"/>
                                <field name="location_id" invisible="0"/>
                                <field name="picking_type_id" invisible="0"/>
                                <field name="total_cost"/>
                                <field name="selling_price"/>
                                <field name="estimated_costs"/>
                                <field name="estimated_net_profit"/>
                                <field name="estimated_profit_margin_ratio"/>
                                <field name="net_profit"/>
                                <field name="net_profit_ratio"/>
                                <field name="primary_insurance"/>

                            </group>
                        </group>
                        <group string="Units"></group>
                        <field name="project_unit_ids">
                            <list editable="bottom">

                                <field name="name"/>
                                <field name="project_id" invisible="1"/>
                                <field name="unit_location"/>
                                <field name="unit_description"/>
                                <field name="total_unit_cost"/>

                            </list>

                        </field>
                        <group string="Items"></group>
                        <field name="project_item_ids" readonly="1">
                            <list editable="bottom">


                                <field name="unit_id" domain="[('project_id','=',parent.id)]"/>

                                <field name="product_id"/>
                                <field name="product_uom"/>
                                <field name="total_item_cost"/>
                                <field name="item_qty"/>
                                <field name="item_description"/>


                                <field name="state"/>
                            </list>
                        </field>

                        <group string="Components"></group>
                        <field name="project_component_ids" readonly="1">
                            <list editable="bottom">


                                <field name="item_id" domain="[('project_id','=',parent.id)]"/>


                                <field name="product_id"/>
                                <field name="product_uom"/>
                                <field name="component_qty"/>
                                <field name="component_cost" readonly="1"/>
                                <field name="component_description"/>
                                <field name="state"/>
                            </list>
                        </field>


                        <group string="Reciver Orders"></group>
                        <field name="receive_order_ids" nolable="1">
                            <!--editable="bottom"-->
                            <list>

                                <field name="name"/>
                                <field name="date"/>

                                <field name="total_cost" sum="cost"/>
                                <field name="total_amount" sum="amount"/>

                                <field name="state"/>
                            </list>
                        </field>

                        <group string="Labors"></group>
                        <field name="labor_ids" nolable="1">
                            <!--editable="bottom"-->
                            <list>

                                <field name="name"/>
                                <field name="date"/>

                                <field name="total_cost" sum="cost"/>

                                <field name="state"/>
                            </list>
                        </field>

                        <group string="Machines"></group>
                        <field name="machine_ids" nolable="1">
                            <!--editable="bottom"-->
                            <list>

                                <field name="name"/>
                                <field name="date"/>

                                <field name="total_cost" sum="cost"/>

                                <field name="state"/>
                            </list>
                        </field>
                        <group string="Tools"></group>
                        <field name="tool_ids" nolable="1">
                            <!--editable="bottom"-->
                            <list>

                                <field name="name"/>
                                <field name="date"/>

                                <field name="total_cost" sum="cost"/>

                                <field name="state"/>
                            </list>
                        </field>


                    </sheet>
                </form>
            </field>
        </record>


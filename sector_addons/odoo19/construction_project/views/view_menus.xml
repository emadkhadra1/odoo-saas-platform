        <menuitem id="menu_project_component" name="Construction Component"
                  parent="menu_cp_categ" groups="construction_project.construction_project_group"
                  action="view_project_component_action" sequence="24"/>


        <menuitem id="menu_construction_receive_order" name="Receive Orders"
                  parent="menu_cp_categ"
                  groups="construction_project.receive_order_user_group,construction_project.receive_order_manager_group"
                  action="view_receive_order_action" sequence="31"/>


        <menuitem id="menu_construction_delay_order" name="Delay Orders"
                  parent="menu_cp_categ"
                  groups="construction_project.receive_order_user_group,construction_project.receive_order_manager_group"
                  action="view_construction_receive_order_line_delay_acction" sequence="31"/>


        <menuitem id="menu_construction_labor_order" name="Order Labors"
                  parent="menu_cp_categ" groups="construction_project.service_user_group"
                  action="view_construction_labor_action" sequence="41"/>


        <menuitem id="menu_construction_machine_order" name="Order Machines"
                  parent="menu_cp_categ" groups="construction_project.service_user_group"
                  action="view_construction_machine_action" sequence="42"/>
        <menuitem id="menu_construction_tool_order" name="Order Tools"
                  parent="menu_cp_categ" groups="construction_project.service_user_group"
                  action="view_construction_tool_action" sequence="43"/>


        <menuitem id="menu_cp_configuration_categ" name="Construction Configuration" parent="cp_root" sequence="100"
                  groups="construction_project.construction_project_group,construction_project.receive_order_manager_group,construction_project.service_manager_group"/>


        <record id="view_product_normal_action" model="ir.actions.act_window">
            <field name="name">Products</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_filter_to_purchase":0}</field>
            <field name="search_view_id" eval="False"/> <!-- Force empty -->
            <field name="view_id" eval="False"/> <!-- Force empty -->
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">

                </p>
            </field>
        </record>
        <menuitem name="Products" id="menu_product_view" action="view_product_normal_action"
                  parent="menu_cp_configuration_categ" sequence="20"/>


        <menuitem id="menu_project_process" name="Construction Process"
                  parent="menu_cp_configuration_categ"
                  action="view_construction_process_action" sequence="20"/>


        <menuitem id="menu_project_labors" name="Labors"
                  parent="menu_cp_configuration_categ"
                  action="view_labors_action" sequence="11"/>


        <menuitem id="menu_project_machines" name="Machines"
                  parent="menu_cp_configuration_categ"
                  action="view_machines_action" sequence="12"/>


        <menuitem id="menu_project_tools" name="Tools"
                  parent="menu_cp_configuration_categ"
                  action="view_tools_action" sequence="13"/>

        <menuitem id="contract_type_menu" name="Contract Type" parent="menu_cp_configuration_categ"
                  action="contract_type_action" sequence="14"/>



        <record id="construction_receive_order_sequence_madina" model="ir.sequence">
            <field name="name">construction.receive.order.madina</field>
            <field name="code">construction.receive.order.madina</field>
            <!--%(year)s%(month)s/-->
            <field name="active">TRUE</field>
            <field name="prefix">اذن صرف</field>
            <field name="padding">4</field>
            <field eval="1" name="company_id"/>
            <field name="number_increment">1</field>
        </record>
        <record id="construction_receive_order_line_sequence_madina" model="ir.sequence">
            <field name="name">construction.receive.order.line.madina</field>
            <field name="code">construction.receive.order.line.madina</field>
            <!--%(year)s%(month)s/-->
            <field name="active">TRUE</field>
            <field name="prefix">اذن صرف</field>
            <field name="padding">4</field>
            <field eval="1" name="company_id"/>
            <field name="number_increment">1</field>
        </record>
    </data>
    <data>
        <record id="view_construction_receive_order_form" model="ir.ui.view">
            <field name="name">construction.receive.order.form</field>
            <field name="model">construction.receive.order</field>
            <field name="arch" type="xml">
                <form string="Receive Order">
                    <header>
                        <button class="oe_highlight" groups="construction_project.receive_order_manager_group" invisible="state not in ['new']" name="confirm" string="Confirm" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <!--                        <div class="oe_title">-->
                        <!--                            &lt;!&ndash;<label string="Receive Order"  />&ndash;&gt;-->
                        <!--                            <h1>-->
                        <!--                                <field name="name" readonly="1"/>-->
                        <!--                                &lt;!&ndash;                                <field name="name2" readonly="1"/>&ndash;&gt;-->
                        <!--                            </h1>-->
                        <!--                        </div>-->
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="order_number" readonly="state in ['done', 'delivered']"/>
                                <field name="project_id" readonly="state in ['done', 'delivered']"/>
                                <field name="user_id" readonly="state in ['done', 'delivered']"/>
                                <field invisible="1" name="location_id"/>
                                <field invisible="1" name="location_dest_id"/>
                                <field invisible="1" name="picking_type_id"/>
                                <field invisible="1" name="warehouse_id"/>
                                <field invisible="1" name="company_id"/>
                                <field invisible="1" name="delegate"/>
                                <field name="reason" readonly="state in ['done', 'delivered']"/>
                                <!--                                <field name="procurement_id" invisible="1"/>-->
                                <field invisible="state != 'done'" name="group_id" readonly="state in ['done', 'delivered']" string="Delivery Order"/>
                                <field invisible="state == 'new'" name="stock_picking_ref" readonly="state in ['done', 'delivered']" string="Delivery Order"/>
                            </group>
                            <group>
                                <field name="date" readonly="state in ['done', 'delivered']"/>
                                <field name="total_cost"/>
                                <field invisible="1" name="total_amount"/>
                                <field name="notes" readonly="state in ['done', 'delivered']"/>
                            </group>
                        </group>
                        <field groups="construction_project.receive_order_user_group" name="receive_order_user_ids" nolable="1" readonly="state == 'done'">
                            <list decoration-danger="qty_state == 'red'" decoration-success="qty_state == 'green'" editable="bottom">
                                <!--<field name="project_id" invisible="1"/>-->
                                <field invisible="1" name="name"/>
                                <!--<field name="ref" string="Code"/>-->
                                <field name="product_category_id" options="{'no_create_edit': True}" readonly="state == 'delivered'"/>
                                <field domain="[('categ_id','=', product_category_id), ('constration_product','=', True)]" name="product_id" options="{'no_create_edit': True}" readonly="state == 'delivered'"/>
                                <field name="product_uom_id" readonly="1"/>
                                <field name="qty_available" readonly="1"/>
                                <field name="order_qty" readonly="state == 'delivered'"/>
                                <field invisible="1" name="qty"/>
                                <field name="qty2" readonly="1"/>
                                <field force_save="1" name="unit_cost" readonly="state == 'delivered'"/>
                                <field invisible="1" name="unit_price" readonly="state == 'delivered'" string="Sale Unit Price"/>
                                <field name="price" readonly="state == 'delivered'" string="Amount"/>
                                <field invisible="1" name="cost"/>
                                <field invisible="1" name="picking_id"/>
                                <field invisible="1" name="purchase_line_id"/>
                                <field invisible="1" name="accept" readonly="1"/>
                                <field invisible="1" name="delay_order" readonly="1"/>
                                <field invisible="1" name="state"/>
                                <field invisible="1" name="qty_state"/>
                                <field invisible="1" name="order_number"/>
                            </list></field>
                        <field groups="construction_project.receive_order_manager_group" name="receive_order_ids" nolable="1" options="{'no_create': True}" readonly="state == 'done'">
                            <list create="false" delete="false" editable="bottom">
                                <!--<field name="project_id" invisible="1"/>-->
                                <field invisible="1" name="name"/>
                                <!--<field name="ref" string="Code"/>-->
                                <field name="product_category_id" options="{'no_create_edit': True}" readonly="1"/>
                                <field domain="[('categ_id','=', product_category_id), ('constration_product','=', False)]" name="product_id" options="{'no_create_edit': True}" readonly="1"/>
                                <field name="product_uom_id" readonly="1"/>
                                <field name="qty_available" readonly="1"/>
                                <field name="order_qty" readonly="1"/>
                                <!-- -->
                                <!--<field name="qty_user" readonly="1"-->
                                <!--groups="construction_project.receive_order_user_group"/>-->
                                <field name="qty"/>
                                <field name="unit_cost" readonly="1"/>
                                <field invisible="1" name="unit_price" string="Sale Unit Price"/>
                                <field name="price" string="Amount"/>
                                <field invisible="1" name="cost"/>
                                <field invisible="1" name="picking_id"/>
                                <field invisible="1" name="purchase_line_id"/>
                                <field invisible="1" name="accept" readonly="1"/>
                                <field invisible="1" name="delay_order" readonly="1"/>
                                <field invisible="1" name="state"/>
                                <field invisible="1" name="location_id"/>
                                <field invisible="1" name="picking_type_id"/>
                                <field invisible="1" name="location_dest_id"/>
                                <field invisible="1" name="warehouse_id"/>
                                <field invisible="1" name="company_id"/>
                                <button invisible="accept != False or delay_order != False" name="accept_line" string="Accept" type="object"/>
                                <button groups="construction_project.receive_order_manager_group" invisible="accept != False or delay_order != False" name="make_delay_line" string="Delay" type="object"/>
                                <button groups="construction_project.receive_order_manager_group" name="make_purchase_order" string="Purchase Order" type="object"/>
                                <!--                                        attrs="{'invisible': [('state', '!=', False)]}"-->
                            </list></field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form></field>
        </record>
        <record id="view_construction_receive_order_tree" model="ir.ui.view">
            <field name="name">construction.receive.order.tree</field>
            <field name="model">construction.receive.order</field>
            <field name="arch" type="xml">
                <list string="Receive Order">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="user_id"/>
                    <field name="date"/>
                    <field name="total_cost"/>
                    <field invisible="1" name="total_amount"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="view_receive_order_action" model="ir.actions.act_window">
            <field name="name">Receive Order</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.receive.order</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
        <!-- Inherit Form View to Modify it -->
        <record id="view_picking_form_update" model="ir.ui.view">
            <field name="name">stock.picking.form.update</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <!-- Add your fields or attributes here -->
                    <field invisible="receive_order_line_id == False" name="order_number"/>
                    <field invisible="receive_order_line_id == False" name="project_id"/>
                    <field invisible="receive_order_line_id == False" name="receive_order_line_id"/>
                    <!--zakaria start-->
                    <field invisible="receive_order_line_id == False" name="receive_order_id"/>
                    <!--zakaria end -->
                    <field invisible="receive_order_line_id == False" name="change_receive_order"/>
                </xpath>
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field invisible="1" name="receive_order_id_ref"/>
                </xpath></field>
        </record>
        <!-- Inherit Form View to Modify it -->
        <record id="view_picking_tree_update" model="ir.ui.view">
            <field name="name">stock.picking.tree.update</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <!-- Add your fields or attributes here -->
                    <field name="order_number"/>
                </xpath></field>
        </record>
        <record id="view_construction_receive_order_line_from_delay" model="ir.ui.view">
            <field name="name">construction.receive.order.line.from.delay</field>
            <field name="model">construction.receive.order.line</field>
            <field name="arch" type="xml">
                <form string="Delay Order Line">
                    <sheet>
                        <group>
                            <field domain="[('state','=','new')]" name="receive_order_id"/>
                            <field invisible="1" name="delay_order"/>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="qty_available"/>
                            <field name="order_qty"/>
                            <field name="qty"/>
                            <field name="unit_cost"/>
                            <field name="unit_price"/>
                            <field name="price"/>
                            <field name="cost"/>
                            <field invisible="1" name="state"/>
                            <field name="picking_id"/>
                        </group>
                    </sheet>
                </form></field>
        </record>
        <record id="view_construction_receive_order_line_tree_delay" model="ir.ui.view">
            <field name="name">construction.receive.order.line.tree.delay</field>
            <field name="model">construction.receive.order.line</field>
            <field name="arch" type="xml">
                <list string="Delay Order Line">
                    <!--<field name="project_id" invisible="1"/>-->
                    <field invisible="1" name="name"/>
                    <field name="receive_order_id"/>
                    <!--<field name="ref" string="Code"/>-->
                    <field name="product_id"/>
                    <field name="qty_available" readonly="1"/>
                    <field name="order_qty"/>
                    <field name="qty"/>
                    <field name="unit_cost"/>
                    <field name="unit_price" string="Sale Unit Price"/>
                    <field name="price" string="Amount"/>
                    <field invisible="1" name="cost"/>
                    <field name="picking_id"/>
                    <field invisible="1" name="purchase_line_id"/>
                    <field invisible="1" name="accept"/>
                    <field invisible="1" name="state"/>
                    <!--<button name="accept_line" string="Accept" type="object"-->
                    <!--attrs="{'invisible': [('accept', '!=', False)]}"/>-->
                    <!--<button name="delay_line" string="Delay" type="object"  />-->
                    <!--<button name="make_purchase_order" string="Purchase Order"  type="object"-->
                    <!--attrs="{'invisible': [('purchase_line_id', '!=', False)]}"-->
                    <!--/>-->
                </list></field>
        </record>
        <record id="view_construction_receive_order_line_delay_acction" model="ir.actions.act_window">
            <field name="name">Delay Order</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.receive.order.line</field>
            <field name="domain">[('delay_order','=',True)]</field>
            <field name="view_id" ref="view_construction_receive_order_line_tree_delay"/>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
        <record id="inherit_procurement_group_form_view" model="ir.ui.view">
            <field name="name">procurement group</field>
            <field name="model">procurement.group</field>
            <field name="inherit_id" ref="stock.procurement_group_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='move_type']" position="after">
                    <!--<field name="project_id"/>-->
                </xpath></field>
        </record>
        <record id="inherit_stock_move_form_view" model="ir.ui.view">
            <field name="name">stock.move</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='group_id']" position="after">
                    <field name="project_id"/>
                </xpath></field>
        </record>
        <record id="inherit_stock_move_tree_view" model="ir.ui.view">
            <field name="name">stock.move</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_type_id']" position="after">
                    <field name="project_id"/>
                </xpath></field>
        </record>
    </data>
</odoo>

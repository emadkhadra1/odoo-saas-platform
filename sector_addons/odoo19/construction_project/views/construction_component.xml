    <data>
        <!--project.component-->
        <record id="view_project_component_form" model="ir.ui.view">
            <field name="name">project.component.form</field>
            <field name="model">project.component</field>
            <field name="arch" type="xml">
                <form string="Project Component">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="project_id"/>
                                <field name="unit_id"/>
                                <field name="item_id" readonly="state != 'new'"/>
                                <field name="product_id" readonly="state != 'new'"/>
                                <field name="product_uom"/>
                                <field name="component_qty" readonly="state != 'new'"/>
                            </group>
                            <group>
                                <!--invisible="1" readonly="1" -->
                                <field name="name"/>
                                <field name="component_cost" readonly="1"/>
                                <field name="component_description" readonly="state != 'new'"/>
                                <!--                                <field name="procurement_id" readonly="1"/>-->
                                <field name="picking_id" readonly="1"/>
                                <field name="picking_state" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form></field>
        </record>
        <record id="view_project_component_tree" model="ir.ui.view">
            <field name="name">project.component.tree</field>
            <field name="model">project.component</field>
            <field name="arch" type="xml">
                <list string="Project Component">
                    <field name="project_id"/>
                    <field name="unit_id"/>
                    <field name="name"/>
                    <field name="item_id"/>
                    <field name="product_id"/>
                    <field name="product_uom"/>
                    <field name="component_qty"/>
                    <field name="component_cost" readonly="1"/>
                    <field name="component_description"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="view_project_component_action" model="ir.actions.act_window">
            <field name="name">Project Component</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">project.component</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
    </data>
</odoo>

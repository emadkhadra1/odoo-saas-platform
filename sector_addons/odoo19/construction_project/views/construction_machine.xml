        <record id="construction_machine_order_sequence_madina" model="ir.sequence">
            <field name="name">construction.machine.order.madina</field>
            <field name="code">construction.machine.order.madina</field>
            <!--%(year)s%(month)s/-->
            <field name="active">TRUE</field>
            <field name="prefix">Machine-</field>
            <field name="padding">4</field>
            <field eval="1" name="company_id"/>
            <field name="number_increment">1</field>
        </record>
    </data>
    <data>
        <record id="view_construction_machine_form" model="ir.ui.view">
            <field name="name">construction.machine.form</field>
            <field name="model">construction.machine</field>
            <field name="arch" type="xml">
                <form string="خدمة">
                    <header>
                        <button class="oe_highlight" groups="construction_project.service_manager_group" invisible="state not in ['new']" name="confirm" string="تأكيد" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <!--                        <div class="oe_title">-->
                        <!--                            &lt;!&ndash;<label string="أمر استلام"  />&ndash;&gt;-->
                        <!--                            <h1>-->
                        <!--                                <field name="name" readonly="1"/>-->
                        <!--                            </h1>-->
                        <!--                        </div>-->
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="project_id" readonly="state == 'done'"/>
                            </group>
                            <group>
                                <field name="date" readonly="state == 'done'"/>
                                <field name="total_cost"/>
                                <field name="journal_id"/>
                                <field name="debit_account_id"/>
                                <field name="credit_account_id"/>
                                <field invisible="state == 'new'" name="account_move_id"/>
                            </group>
                        </group>
                        <group string="المعدات"/>
                        <field name="line_ids" readonly="state == 'done'">
                            <list editable="bottom">
                                <field name="machine_id"/>
                                <field name="product_uom_id"/>
                                <field invisible="1" name="name"/>
                                <field name="order_qty" sum="الكمية"/>
                                <field name="qty" sum="الكمية"/>
                                <field name="unit_cost" sum="تكلفة الوحدة"/>
                                <field name="cost" sum="التكلفة"/>
                            </list></field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form></field>
        </record>
        <record id="view_construction_machine_tree" model="ir.ui.view">
            <field name="name">construction.machine.tree</field>
            <field name="model">construction.machine</field>
            <field name="arch" type="xml">
                <list string="خدمة">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="date"/>
                    <field name="total_cost"/>
                    <field name="state"/>
                </list></field>
        </record>
        <record id="view_construction_machine_action" model="ir.actions.act_window">
            <field name="name">معدة</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.machine</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
        <record id="view_construction_machines_form" model="ir.ui.view">
            <field name="name">construction.machines.form</field>
            <field name="model">construction.machines</field>
            <field name="arch" type="xml">
                <form string="المعدات">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="product_uom_id"/>
                            <field name="unit_cost"/>
                        </group>
                    </sheet>
                </form></field>
        </record>
        <record id="view_construction_machines_tree" model="ir.ui.view">
            <field name="name">construction.machines.tree</field>
            <field name="model">construction.machines</field>
            <field name="arch" type="xml">
                <list string="المعدات">
                    <field name="name"/>
                    <field name="product_uom_id"/>
                    <field name="unit_cost"/>
                </list></field>
        </record>
        <record id="view_machines_action" model="ir.actions.act_window">
            <field name="name">المعدات</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.machines</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
    </data>
</odoo>

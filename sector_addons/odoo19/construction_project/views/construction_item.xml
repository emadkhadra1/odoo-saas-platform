    <data>
        <!--project.item-->
        <record id="view_project_item_form" model="ir.ui.view">
            <field name="name">project.item.form</field>
            <field name="model">project.item</field>
            <field name="arch" type="xml">
                <form string="بند المشروع">
                    <header>
                        <button class="oe_highlight" invisible="state not in ['new']" name="cp_item_confirm" string="تأكيد" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field invisible="1" name="name"/>
                                <field invisible="1" name="project_id"/>
                                <field name="unit_id"/>
                                <field name="process_id"/>
                                <field context="{'search_default_constration_product':1, 'default_constration_product':1}" domain="[('constration_product','=',True)]" name="product_id"/>
                                <field name="product_uom"/>
                                <field name="item_qty"/>
                            </group>
                            <group>
                                <field invisible="1" name="company_id" readonly="1"/>
                                <field invisible="1" name="warehouse_id" readonly="1"/>
                                <field name="date"/>
                                <field invisible="1" name="picking_type_id"/>
                                <field invisible="1" name="location_id"/>
                                <field invisible="1" name="location_dest_id"/>
                                <field name="total_item_cost"/>
                                <field invisible="1" name="group_id" readonly="1"/>
                                <field name="item_cost"/>
                                <field name="item_description"/>
                            </group>
                        </group>
                        <field name="project_component_ids"><list editable="bottom">
                                <field name="product_id"/>
                                <field name="product_uom"/>
                                <field name="component_qty"/>
                                <field name="component_cost" readonly="1"/>
                                <field name="component_description"/>
                                <!--                                <field name="procurement_id" invisible="1"/>-->
                                <field invisible="1" name="picking_id"/>
                                <field invisible="1" name="picking_state"/>
                            </list></field>
                    </sheet>
                </form></field>
        </record>
        <record id="view_project_item_tree" model="ir.ui.view">
            <field name="name">project.item.tree</field>
            <field name="model">project.item</field>
            <field name="arch" type="xml">
                <list string="بند المشروع">
                    <field name="project_id"/>
                    <field name="unit_id"/>
                    <field name="name"/>
                    <field name="product_id"/>
                    <field name="product_uom"/>
                    <field name="total_item_cost"/>
                    <field name="item_qty"/>
                    <field name="item_description"/>
                    <field name="state"/>
                    <field name="project_component_ids"/>
                </list></field>
        </record>
        <record id="view_project_item_action" model="ir.actions.act_window">
            <field name="name">بند المشروع</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">project.item</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
        <record id="view_construction_process_form" model="ir.ui.view">
            <field name="name">construction.process.form</field>
            <field name="model">construction.process</field>
            <field name="arch" type="xml">
                <form string="مراحل التنفيذ">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form></field>
        </record>
        <record id="view_construction_process_tree" model="ir.ui.view">
            <field name="name">construction.process.tree</field>
            <field name="model">construction.process</field>
            <field name="arch" type="xml">
                <list string="مراحل التنفيذ">
                    <field name="name"/>
                </list></field>
        </record>
        <record id="view_construction_process_action" model="ir.actions.act_window">
            <field name="name">مراحل التنفيذ</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">construction.process</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p>
                <p>
                    <!-- More details about what a user can do with this object will be OK -->
                </p></field>
        </record>
    </data>
</odoo>

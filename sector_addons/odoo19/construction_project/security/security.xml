<odoo>

        <record id="construction_project_category" model="ir.module.category">
            <field name="name">مشاريع المقاولات</field>
            <field name="sequence" eval="0"/>
        </record>
        <!--construction_project.construction_project_group-->
        <record id="construction_project_group" model="res.groups">
            <field name="name">`صلاحيات المقاولات`</field>
            <field name="implied_ids"
                   eval="[(4, ref('sales_team.group_sale_manager')), (4, ref('stock.group_stock_manager'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

            <!--<field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>-->
        </record>


        <record id="show_receive_order_category" model="ir.module.category">
            <field name="name">عرض أمر الاستلام</field>
            <field name="sequence" eval="1"/>
        </record>

        <record id="user_own_receive_order_group" model="res.groups">
            <field name="name">المستخدم: أوامر الاستلام الخاصة فقط</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
                    <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

        </record>

        <record id="manager_receive_order_group" model="res.groups">
            <field name="name">المدير: كل أوامر الاستلام</field>
            <field name="implied_ids" eval="[(4, ref('user_own_receive_order_group'))]"/>
                    <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

        </record>

        <record id="user_own_receive_order_rule" model="ir.rule">
            <field name="name">أوامر الاستلام الخاصة بي</field>
            <field ref="model_construction_receive_order" name="model_id"/>
            <field name="domain_force">['|',('user_id','=',user.id),('user_id','=',False)]</field>
            <field name="groups" eval="[(4, ref('construction_project.user_own_receive_order_group'))]"/>
        </record>

        <record id="manager_receive_order_rule" model="ir.rule">
            <field name="name">كل أوامر الاستلام</field>
            <field ref="model_construction_receive_order" name="model_id"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('construction_project.manager_receive_order_group'))]"/>
        </record>

        <record id="receive_order_category" model="ir.module.category">
            <field name="name">أمر استلام</field>
            <field name="sequence" eval="1"/>
        </record>
        <!--construction_project.receive_order_user_group-->
        <record id="receive_order_user_group" model="res.groups">
            <field name="name">مستخدم أوامر الاستلام</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
                    <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

        </record>
        <!--construction_project.receive_order_manager_group-->
        <record id="receive_order_manager_group" model="res.groups">
            <field name="name">مدير أوامر الاستلام</field>
                        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

            <!--<field name="implied_ids" eval="[(4, ref('construction_project.receive_order_user_group'))]"/>-->
        </record>

        <record id="receive_order_user_group_show_only" model="ir.rule">
            <field name="name">عرض أوامر الاستلام فقط</field>
            <field ref="model_construction_receive_order" name="model_id"/>
            <field name="domain_force">[('user_id', '=',user.id )]</field>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <!-- You can attach this rule to a specific group, Or make it Global -->
            <field name="groups" eval="[(4, ref('construction_project.receive_order_user_group'))]"/>
            <!--<field name="global" eval="1"/> -->
        </record>
        <record id="receive_order_user_group_show_only_lines" model="ir.rule">
            <field name="name">عرض بنود أوامر الاستلام فقط</field>
            <field ref="model_construction_receive_order_line" name="model_id"/>
<!--            <field name="domain_force">[('user_id', '=',user.id)]</field>-->
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <!-- You can attach this rule to a specific group, Or make it Global -->
            <field name="groups" eval="[(4, ref('construction_project.receive_order_user_group'))]"/>
            <!--<field name="global" eval="1"/> -->
        </record>
        <record id="receive_order_manager_group_show_all" model="ir.rule">
            <field name="name">عرض كل أوامر الاستلام</field>
            <field ref="model_construction_receive_order" name="model_id"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <!-- You can attach this rule to a specific group, Or make it Global -->
            <field name="groups" eval="[(4, ref('construction_project.receive_order_manager_group'))]"/>
            <!--<field name="global" eval="1"/> -->
        </record>

        <record id="receive_order_manager_group_show_all_lines" model="ir.rule">
            <field name="name">عرض كل بنود أوامر الاستلام</field>
            <field ref="model_construction_receive_order_line" name="model_id"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <!-- You can attach this rule to a specific group, Or make it Global -->
            <field name="groups" eval="[(4, ref('construction_project.receive_order_manager_group'))]"/>
            <!--<field name="global" eval="1"/> -->
        </record>


        <record id="service_category" model="ir.module.category">
            <field name="name">عمالة/معدات/أدوات الخدمة</field>
            <field name="sequence" eval="1"/>
        </record>


        <!--  construction_project.service_labor_user_group       -->
        <record id="service_user_group" model="res.groups">
            <field name="name">مستخدم الخدمات</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
                    <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

        </record>
        <record id="service_manager_group" model="res.groups">
            <field name="name">مدير الخدمات</field>
            <field name="implied_ids" eval="[(4, ref('construction_project.service_user_group'))]"/>
                    <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>

        </record>


        <!--View Menus-->


        <!--Actions-->

    <data noupdate="0">
        <!-- Multi - Company Rules -->
        <record model="ir.rule" id="construction_project_comp_rule">
            <field name="name">مشاريع المقاولات متعددة الشركات</field>
            <field name="model_id" ref="model_construction_project"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]</field>
        </record>
    </data>
</odoo>

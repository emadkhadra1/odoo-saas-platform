<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="property_type_form" model="ir.ui.view">
            <field name="name">property.types.form.view</field>
            <field name="model">unit.type</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="project_category_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="property_type_tree" model="ir.ui.view">
            <field name="name">property.types.tree.view</field>
            <field name="model">unit.type</field>
            <field name="arch" type="xml">
                <list string="Unit Types">
                    <field name="name"/>
                    <field name="project_category_id"/>
                </list>
            </field>
        </record>

        <record id="property_type_action" model="ir.actions.act_window">
            <field name="name">Unit Types</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">unit.type</field>
            <field name="view_mode">list,form</field>
            <field name="target">current</field>
        </record>

        <menuitem id="property_type_menu"
                  name="Unit Types"
                  action="property_type_action"
                  parent="realestate_project.real_estate_configuration_menu"
                  sequence="3"
        />

    </data>
</odoo>
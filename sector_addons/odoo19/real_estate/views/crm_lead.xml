<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <record id="crm_view_form2" model="ir.ui.view">
            <field name="name">crm.lead</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="sale_crm.crm_case_form_view_oppor" />
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_sale_quotations_new']" position="attributes">
                    <attribute name="string">Create Offer</attribute>
                </xpath>
                <xpath expr="//button[@name='action_sale_quotations_new']" position="after">
                    <field invisible="1" name="converted_to_opp" />
                </xpath>

            </field>
        </record>

        <record id="crm_case_form_view_leads_inherited" model="ir.ui.view">
            <field name="name">crm.lead</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="after">
                    <widget bg_color="bg-danger" name="web_ribbon" title="Unit Booked" />

                </xpath>
                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="force_save">1</attribute>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="before">
                    <field name="partner_national_id" />
                    <field name="partner_international_id" />
                </xpath>
                <xpath expr="//field[@name='tag_ids']" position="after">
                    <field domain="[('broker_id_company_type','=','company'),('broker','=',True)]" name="broker_id" options="{'no_create':1}" />
                    <field domain="[('parent_id','=',broker_id)]" name="broker_manager_id" options="{'no_create':1}" />
                    <field domain="[('parent_id','=',broker_id)]" name="broker_sales_id" options="{'no_create':1}" />
                    <field name="CloseDateState" />
                    <field invisible="1" name="converted_to_opp" />
                </xpath>
                <xpath expr="//group[@name='lead_priority']" position="inside">

                    <field domain="[('broker_id_company_type','=','company'),('broker','=',True)]" name="broker_id" options="{'no_create':1}" />
                    <field domain="[('parent_id','=',broker_id)]" name="broker_manager_id" options="{'no_create':1}" />
                    <field domain="[('parent_id','=',broker_id)]" name="broker_sales_id" options="{'no_create':1}" />
                    <field invisible="1" name="CloseDateState" />
                    <field invisible="1" name="is_booked_unit" />


                </xpath>
                <xpath expr="//page[1]" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//page[@name='extra']" position="replace">
                    
                    <page name="extra" string="Extra Info">
                        <group>
                            <group string="Email">
                                <field groups="base.group_no_one" name="message_bounce" readonly="1" />
                            </group>
                            <group name="categorization" string="Tracking">
                                <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}" />
                                <field name="campaign_id" />
                                <field name="medium_id" />
                                <field name="source_id" />
                                <field name="referred" />
                                <field force_save="1" name="convert_opp_reason" readonly="1" />
                            </group>
                            <group string="Analysis">
                                <field name="date_open" />
                                <field name="date_closed" />
                                <field name="probability" />
                            </group>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>

        <record id="crm_lead_view_form_inherit" model="ir.ui.view">
            <field name="name">crm.lead.view.form.inherit</field>
            <field name="model">crm.lead</field>
            <field eval="1" name="priority" />
            <field eval="[(4, ref('real_estate_security.restrict_edit_in_lead_group'))]" name="groups_id" />
            <field name="inherit_id" ref="crm.crm_lead_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//group[1]/group[2]//field[@name='partner_id']" position="after">
                    <field invisible="1" name="id" />
                    <field invisible="0" name="CloseDateState" />
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="attrs">{'readonly': [('id', '!=', False), ('partner_id', '!=', False)]}</attribute>
                </xpath>
                <xpath expr="//group[1]/group[2]//field[@name='partner_id']" position="attributes">
                    <attribute name="attrs">{'readonly': [('id', '!=', False), ('partner_id', '!=', False)]}</attribute>
                </xpath>
                <xpath expr="//group[1]/group[3]//field[@name='phone']" position="attributes">
                    <attribute name="attrs">{'readonly': [('id', '!=', False)]}</attribute>
                </xpath>
                <xpath expr="//group[1]/group[3]//field[@name='mobile']" position="attributes">
                    <attribute name="attrs">{'readonly': [('id', '!=', False)]}</attribute>
                </xpath>
                <xpath expr="//field[@name='phone']" position="attributes">
                    <attribute name="attrs">{'readonly': [('id', '!=', False)]}</attribute>
                </xpath>
            </field>
        </record>


    </data>
</odoo>
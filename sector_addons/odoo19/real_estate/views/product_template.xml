<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="real_estate.reset_payment_plan_id" model="ir.actions.server">
            <field name="name">Reset Payment Plans</field>
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="model_id" ref="product.model_product_template" />
            <field name="binding_model_id" ref="product.model_product_template" />
            <field name="code">
                records.reset_payment_plan_id()
            </field>
        </record>
        <record id="product_template_tree_view_inherit" model="ir.ui.view">
            <field name="name">product.template.product.tree</field>
            <field name="model">product.template</field>
            <field name="priority">30</field>
            <field name="arch" type="xml">
                <list string="Ø§Ù„ÙˆØ­Ø¯Ø§Øª">
                    <field name="sequence" widget="handle" />
                    <field name="name" string="Code" />
                    <field name="unit_type_id" />
                    <field name="project_id" />
                    <field name="customer_id" />
                    <field name="total_Area" />
                    <field name="meter_price" />
                    <field name="floor" />
                    <field name="attached_area_frist" />
                    <field name="attached_area_frist_price" />
                    <field name="state" />
                    <field name="price_before_discount" optional="hide" string="Before Discount" />
                    <field name="list_price" string="Price" sum="Total" width="300px" />

                    <field name="product_areas" optional="hide" string="Location" />
                    <field name="delivery_date" optional="hide" />
                    <field name="finishing_type_id" optional="hide" />
                </list>
            </field>
        </record>

        <record id="sale_product_cede_form" model="ir.ui.view">
            <field name="name">product.cede.form</field>
            <field name="model">product.cede</field>
            <field name="arch" type="xml">
                <form string="Hold Request">
                    <sheet>
                        <group>
                            <group>
                                <field name="customer_id" />
                            </group>
                            <group>
                                <field name="attachment_id" widget="many2many_binary" />
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <group>
                            <span>
                                <button class="oe_highlight" name="action_cede_button" string="Confirm" type="object" />
                                <button class="oe_link" special="cancel" string="Cancel" />
                                

                            </span>
                        </group>
                    </footer>
                </form>
            </field>
        </record>

        <record id="product_real_estate_filter" model="ir.ui.view">
            <field name="name">product.template.inherited.filter</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_search_view" />
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='filter_to_sell']" position="after">
                    <filter domain="[('is_residential','=',1)]" name="is_residential" string="Is Unit" />
                    <filter domain="[('is_land','=',1)]" name="is_land" string="Is Land" />
                    <filter domain="[('is_composite','=',1)]" name="is_land" string="Is Composite" />

                </xpath>
            </field>
        </record>

        <record id="product_template_form_view_real_estate" model="ir.ui.view">
            <field name="name">product.template</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="account.product_template_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='accounting']" position="after">
                    <group>
                        
                        <field name="analytic_account_id" string="Analytic Account" />

                    </group>
                </xpath>
            </field>
        </record>
        <record id="product_real_estate" model="ir.ui.view">
            <field name="name">product.template.inherited.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_open_label_layout']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <div class="oe_button_box" name="button_box" position="inside">
                    <button class="oe_stat_button" icon="fa-pencil-square-o" invisible="1" name="action_view_hold_units" string="Hold Requests" type="object">
                    </button>
                    <button class="oe_stat_button" icon="fa-pencil-square-o" name="action_view_entry" string="View Entries" type="object">
                    </button>

                </div>
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="attrs">{'readonly': ['|', ('is_land', '=', True), ('is_residential', '=', True)]}
                    </attribute>
                    <attribute name="force_save">True</attribute>
                </xpath>
                <xpath expr="//div[@name='options']" position="replace">
                    <div groups="base.group_user" name="options">
                        <div>
                            <field name="sale_ok" />
                            <label for="sale_ok" />
                        </div>
                        <div>
                            <field name="purchase_ok" />
                            <label for="purchase_ok" />
                        </div>
                        
                        
                        
                        
                        
                        
                        
                        
                        <div>
                            <field force_save="1" name="is_residential" />
                            <label for="is_residential" />
                        </div>
                        <div invisible="1">
                            <field name="is_land" />
                            <label for="is_land" />
                        </div>
                        <div>
                            <field name="is_composite" />
                            <label for="is_composite" />
                        </div>
                        <div>
                            <field name="is_interest" />
                            <label for="is_interest" />
                        </div>
                        <div>
                            <field name="is_penalty" />
                            <label for="is_penalty" />
                        </div>
                    </div>

                </xpath>
                <xpath expr="//field[@name='purchase_ok']" position="attributes">
                    <attribute name="attrs">{'invisible': ['|', ('is_land', '=', True), ('is_residential', '=', True)]}
                    </attribute>
                </xpath>
                <xpath expr="//label[@for='purchase_ok']" position="attributes">
                    <attribute name="attrs">{'invisible': ['|', ('is_land', '=', True), ('is_residential', '=', True)]}
                    </attribute>
                </xpath>
                <xpath expr="//button[@name='open_pricelist_rules']" position="replace">

                </xpath>



                <xpath expr="//sheet" position="before">
                    <header>
                        <button class="btn-primary" groups="real_estate.group_unit_hold_request" name="action_hold_request" string="Hold Request" type="object" />
                        <button class="btn-primary" groups="real_estate_security.group_manager" name="action_create_sale_order_inherited" string="Create Offer" type="object" />
                        
                        
                        
                        
                        

                        <button class="btn-danger" groups="real_estate_security.group_manager" name="action_back_to_sale_product" string="Back To Sale" type="object" />
                        <button class="btn-success" groups="real_estate_security.group_manager" name="action_sold_product" string="Sold" type="object" />



                        <button class="btn-success" groups="real_estate_security.group_manager,real_estate.group_unit_blocked_request" name="action_block_product" string="Blocked" type="object" />
                        <button class="btn-warning" groups="real_estate_security.group_manager" name="action_replace_product" string="Replace" type="object" />
                        <button class="btn-warning" groups="real_estate_security.group_manager" name="action_recovery_product" string="Return" type="object" />

                        
                        
                        
                        <field name="state" statusbar_visible="sale,hold,booked,sold,blocked" widget="statusbar" />
                    </header>
                </xpath>
                <xpath expr="//page[@name='general_information']" position="attributes">
                    <attribute name="attrs">{'invisible': ['|', ('is_land', '=', True), ('is_residential', '=', True)]}
                    </attribute>
                </xpath>
                <xpath expr="//label[@for='name']" position="attributes">
                    <attribute name="string">Property Name</attribute>
                    <attribute name="attrs">{
                        'invisible': ['&amp;', ('is_land', '=', False), ('is_residential', '=', False)]}
                    </attribute>
                </xpath>
                <xpath expr="//label[@for='name']" position="after">
                    <label for="name" string="Product Name" />
                </xpath>
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="placeholder">Name</attribute>
                </xpath>
                <xpath expr="//page[@name='general_information']" position="after">
                    <page name="composite_information" string="Details">
                        <group>
                            <group name="comp_project" string="Project">

                                <field name="project_id" string="Project" />
                                <field domain="[('is_composite','=',False),('project_id','=',project_id)]" name="composite_unit_ids" options="{'no_create':1}" widget="many2many_tags" />
                            </group>
                            <group name="group_general_prop" string="Other">
                                <field name="list_price" options="{'currency_field': 'currency_id', 'field_digits': True}" string="Sales Price" widget="monetary" />
                                <label for="standard_price" groups="base.group_user" invisible="1" />
                                <div groups="base.group_user" invisible="1" name="standard_price_uom">
                                    <field invisible="1" name="standard_price" options="{'currency_field': 'currency_id'}" widget="monetary" />
                                </div>
                                <field name="min_deposit_amount" options="{'currency_field': 'currency_id'}" string="Min Deposit Amount" widget="monetary" />
                                <field invisible="1" name="remain_amount" string="Remaining Amount" />
                                <field invisible="1" name="remain_amount_with_interest" string="Remaining Amount With Interest " />
                                <field invisible="1" name="type" />
                                <field name="categ_id" string="Product Category" />
                                <field name="payment_plan_id" options="{'no_create_edit': True}" widget="many2many_tags" />
                                <field invisible="1" name="payment_plan_ids" widget="many2many_tags" />
                                <field invisible="1" name="floor_num" />
                                <field invisible="1" name="floor_number" />
                                <field name="confirm_date" />
                                <field name="building_license_no" />
                                <field name="delivery_date" />
                                <label for="total_Area" string="Unit Area" />
                                <div class="o_row">
                                    <field force_save="1" name="total_Area" readonly="1" style="width:30%%" />
                                </div>
                                <field name="car_spot" />
                                <field force_save="1" name="car_spot_price" readonly="1" />
                                <field name="parking_code" />
                            </group>
                            <group name="price">


                                <label for="extra_land" invisible="1" string="Extra Land" />
                                <div class="o_row" invisible="1">
                                    <field name="extra_land" style="width:30%%" />
                                    <span>Price/Meter(Extra Land)</span>
                                    <field class="oe_inline" name="extra_land_price" />
                                </div>
                            </group>

                            <group name="group_standard_price">
                                <field name="project_unit_cost" readonly="1" widget="monetary" />
                                <field invisible="1" name="move_ids" widget="many2many_tags" />
                                <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}" />
                                <field groups="uom.group_uom" invisible="1" name="uom_id" options="{'no_create': True}" />
                                <field groups="uom.group_uom" invisible="1" name="uom_po_id" options="{'no_create': True}" />
                                <field invisible="1" name="currency_id" />
                                <field invisible="1" name="product_variant_id" />
                                <field invisible="1" name="min_deposit_amount_temp" />
                            </group>
                            <group name="property_owner" string="Property Owner">
                                <field name="customer_id" readonly="1" string="Property Customer" />
                                <field invisible="1" name="vendor_id" string="Property Owner" />
                            </group>
                        </group>

                        <group string="Finishing Description">
                            <field name="description" nolabel="1" placeholder="This note is only for internal purposes." />
                        </group>
                        <group string="Discount Info">
                            <field name="discount_type" options="{'horizontal': true}" widget="radio" />
                            <field name="discount_amount" />
                            <field name="discount_percentage" />
                        </group>
                    </page>
                    <page name="properity_information" string="Details">
                        <group>
                            <group name="coding" string="Coding">
                                <field invisible="1" name="unit_type_ids" />
                                <field domain="[('id','in',unit_type_ids)]" name="unit_type_id" options="{'no_create':True}" />

                                <field name="project_id" string="Project" />
                                <field domain="[('project_id','=',project_id)]" name="phase_no" />
                                <field domain="[('project_id','=',project_id)]" name="building_code" string="Building" />
                                <field domain="[('building_id','=',building_code)]" name="floor" />
                                <field name="unit_classification" />
                                <field name="unit_code" />
                                <field name="default_code" />
                                <field invisible="1" name="product_areas" string="Area" />
                                <field invisible="1" name="product_project" string="Project" />

                                <field invisible="1" name="requset_id" />
                                <field invisible="1" name="total_amout" />
                                <field invisible="1" name="booked_date" />
                                <field invisible="1" name="hold_date" />


                                <field invisible="1" name="project_utility_ids" widget="many2many_tags" />
                                <field invisible="1" name="filter_privilege_id" widget="many2many_tags" />
                            </group>
                            <group name="price" string="Price">

                                <label for="total_Area" string="Unit Area" />
                                <div class="o_row">
                                    <field name="total_Area" style="width:30%%" />
                                    <span>Price/Meter(Area)</span>
                                    <field class="oe_inline" name="meter_price" />
                                </div>
                                <field name="total_attached_area" />
                                <field invisible="1" name="total_utilities" />
                                <field name="car_spot" />
                                <field name="car_spot_price" />
                                <field name="parking_code" />
                                <label for="extra_land" invisible="1" string="Extra Land" />
                                <div class="o_row" invisible="1">
                                    <field name="extra_land" style="width:30%%" />
                                    <span>Price/Meter(Extra Land)</span>
                                    <field class="oe_inline" name="extra_land_price" />
                                </div>
                            </group>
                            <group name="design" string="Design">
                                <field name="room" />
                                <field name="unit_design_ref" />
                                <field name="finishing_type_id" />

                            </group>

                            <group name="group_general_prop" string="Other">
                                <field force_save="1" name="price_before_discount" options="{'currency_field': 'currency_id', 'field_digits': True}" readonly="1" string="Sales Price Before Discount" widget="monetary" />
                                <field name="list_price" options="{'currency_field': 'currency_id', 'field_digits': True}" string="Sales Price" widget="monetary" />

                                <label for="standard_price" groups="base.group_user" invisible="1" />
                                <div groups="base.group_user" invisible="1" name="standard_price_uom">
                                    <field invisible="1" name="standard_price" options="{'currency_field': 'currency_id'}" widget="monetary" />
                                </div>
                                <field name="min_deposit_amount" options="{'currency_field': 'currency_id'}" string="Min Deposit Amount" widget="monetary" />
                                <field invisible="1" name="remain_amount" string="Remaining Amount" />
                                <field invisible="1" name="remain_amount_with_interest" string="Remaining Amount With Interest " />
                                <field invisible="1" name="type" />
                                <field name="categ_id" string="Product Category" />
                                <field name="payment_plan_id" options="{'no_create_edit': True}" widget="many2many_tags" />
                                <field invisible="1" name="payment_plan_ids" widget="many2many_tags" />
                                <field name="reserve_days_no" readonly="0" />
                                <field invisible="1" name="floor_num" />
                                <field invisible="1" name="floor_number" />
                                <field name="confirm_date" />
                                <field name="building_license_no" />
                                <field name="delivery_date" />
                                <field name="actual_delivery_date" />
                                <field name="delivery_type" />
                            </group>


                            <group name="group_standard_price">
                                <field name="project_unit_cost" readonly="1" widget="monetary" />
                                <field invisible="1" name="move_ids" widget="many2many_tags" />
                                <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}" />
                                <field groups="uom.group_uom" invisible="1" name="uom_id" options="{'no_create': True}" />
                                <field groups="uom.group_uom" invisible="1" name="uom_po_id" options="{'no_create': True}" />
                                <field invisible="1" name="currency_id" />
                                <field invisible="1" name="product_variant_id" />
                                <field invisible="1" name="min_deposit_amount_temp" />
                            </group>
                            <group name="property_owner" string="Property Owner">
                                <field name="customer_id" readonly="1" string="Property Customer" />
                                <field invisible="1" name="vendor_id" string="Property Owner" />
                            </group>
                            <group groups="sales_team.group_sale_manager" string="Discount Info">

                                <field name="apply_discount" />
                                <field name="discount_type" options="{'horizontal': true}" widget="radio" />
                                <field name="discount_amount" />
                                <field name="discount_percentage" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Advantages">
                                <field name="privilege_ids" string="Advantages">
                                    <list editable="bottom">
                                        <field domain="[('id','in',parent.filter_privilege_id)]" name="privilege_id" string="Advantage" />
                                        <field invisible="1" name="description" required="0" />
                                        <field name="percent" string="Price" />
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="total_percent" />
                                    <field invisible="1" name="meter_cash_percent" />
                                </group>
                                <div class="oe_clear" />

                            </page>
                        </notebook>
                        <group string="Finishing Description">
                            <field name="description" nolabel="1" placeholder="This note is only for internal purposes." />
                        </group>
                    </page>

                </xpath>
                <xpath expr="//page[@name='sales']" position="attributes">
                    <attribute name="attrs">{'invisible': ['|', ('is_land', '=', True), ('is_residential', '=', True)]}
                    </attribute>
                </xpath>
                <xpath expr="//page[@name='variants']" position="attributes">
                    <attribute name="attrs">{'invisible': ['|', ('is_land', '=', True), ('is_residential', '=', True)]}
                    </attribute>
                </xpath>
                <xpath expr="//page[@name='properity_information']" position="after">
                    <page name="utility_info" string="Utilities">
                        <field name="product_utility_ids">
                            <list editable="bottom">
                                <field domain="[('id','in',parent.project_utility_ids)]" name="name" />
                                <field name="percent" />
                                <field name="price" />
                                <field name="included_price" />
                                <field domain="[('id','in',parent.payment_plan_id)]" name="payment_plan_id" />
                            </list>
                        </field>
                    </page>
                    <page name="rooms_info" string="Rooms">
                        <field name="product_room_ids">
                            <list editable="bottom">
                                <field name="name" />
                                <field name="length" />
                                <field name="width" />
                                <field name="area" />
                                <field name="notes" />
                            </list>
                        </field>
                    </page>
                    <page string="Images">
                        <button class="btn-success" name="action_image_preview" string="Preview" type="object" />
                        <field name="image_ids" nolabel="1">
                            <kanban data-reload-on-close="true" options="{'no_open':True}">
                                <field name="id" />
                                <field name="image" />
                                <field name="name" />
                                <templates>
                                    <t t-name="card">
                                        <div style="width: 210px;">
                                            <center>
                                                <a type="open">
                                                    <img alt="Product Image" class="zoom" data-reload-on-close="true" height="200px" t-att-src="kanban_image('product.image', 'image', record.id.raw_value)" width="210px" />
                                                </a>
                                            </center>
                                        </div>

                                    </t>
                                </templates>
                            </kanban>
                            <list string="Product Images">
                                <field name="name" />
                                <field name="image" required="True" />
                            </list>
                            <form string="Product Image">
                                <group>
                                    <group>
                                        <field name="name" />
                                    </group>
                                    <group>
                                        <field name="image" />
                                    </group>
                                </group>
                            </form>
                        </field>
                    </page>
                    <page name="other_materials" string="Other Materials">
                        <group>
                            <group>
                                <field name="docs_ids" widget="many2many_binary" />
                            </group>
                        </group>
                    </page>
                    <page name="other_materials" string="Location">
                        <group>
                            <group>
                                <field name="map_url" widget="url" />
                            </group>
                        </group>
                    </page>
                    <page name="history_info" string="Unit Status ">
                        <group>
                            <group>
                                <field name="maintenance_deposit" />
                                <field name="unit_deleivery" readonly="1" />
                                <field name="building_deleivery" />
                            </group>
                            <group>
                                <field name="key_deleivery" />
                                <field name="electricity_deleivery" />
                                <field name="planet" />
                                <field name="planet_date" />
                            </group>
                        </group>

                    </page>
                    <page name="history_info" string="Activity Log ">
                        <field name="product_history_ids">
                            <list create="0" delete="0" editable="bottom">
                                <field name="state" />
                                <field name="confirm_date" />
                                <field name="hist_date" />
                                <field name="sales_person_id" />
                                <field name="attachment_id" widget="many2many_binary" />
                            </list>
                        </field>
                        <group>
                            <field name="product_last_state_date" />
                        </group>
                    </page>
                    <page name="attached_areas" string="Attached Areas">
                        <field name="attached_area_ids">
                            <list create="1" delete="1" editable="bottom">
                                <field domain="[('unit_type_id','=',parent.unit_type_id)]" name="attached_area_id" required="1" />
                                <field name="area" required="1" />
                                <field name="price" required="1" />
                                <field force_save="1" name="total" readonly="1" required="1" sum="Total" />
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="product.product_template_action" model="ir.actions.act_window">
            <field name="name">Property</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="view_id" ref="product.product_template_kanban_view" />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to define a new product.
                </p>
                <p>
                    You must define a product for everything you sell, whether it's a physical product, a consumable or
                    a service you offer to customers.
                </p>
                <p>
                    The product form contains information to simplify the sale process: price, notes in the quotation,
                    accounting data, procurement methods, etc.
                </p>
            </field>
        </record>

        <record id="sale_hold_request_form" model="ir.ui.view">
            <field name="name">product.request.form</field>
            <field name="model">product.request</field>
            <field name="arch" type="xml">
                <form string="Hold Request">
                    <header>
                        <button class="btn-primary" groups="real_estate_security.group_manager" name="action_approve_request" string="Approve" type="object" />
                        <button class="btn-primary" groups="real_estate_security.group_manager" name="action_reject_request" string="Reject" type="object" />
                        <field name="state" statusbar_visible="request,approve,reject" widget="statusbar" />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" groups="real_estate_security.group_manager" icon="fa-archive" name="toggle_active" type="object">
                                <field name="active" options="{&quot;terminology&quot;: &quot;archive&quot;}" widget="boolean_button" />
                            </button>
                            
                            
                            
                            
                            
                        </div>
                        <div class="oe_title">
                            <field class="oe_edit_only" name="hold_type" options="{'horizontal': true}" style="color:teal;" widget="radio" />
                            <h1>
                                <field name="name" readonly="1" />
                            </h1>

                        </div>
                        <group>
                            <group>
                                <field name="product_id" />
                                <field name="customer_id" />
                            </group>
                            <group>
                                <field name="sales_person_id" />
                                <label for="hold_days" />

                                <div class="o_row">
                                    <field name="hold_days" string="Hold Days" />
                                    <font color="teal">Days</font>
                                </div>

                                <field invisible="1" name="header_inv" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Hold Reason">
                                <field name="hold_reason" />

                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" />
                        <field name="activity_ids" widget="mail_activity" />
                        <field name="message_ids" widget="mail_thread" />
                    </div>
                </form>
            </field>
        </record>

        <record id="sale_hold_request_wizard" model="ir.ui.view">
            <field name="name">product.request.wizard</field>
            <field name="model">product.request</field>
            <field name="arch" type="xml">
                <form string="Hold Request">
                    <sheet>
                        <group>
                            <group>
                                <field name="product_id" />
                                <field name="customer_id" />
                            </group>
                            <group>
                                <field name="sales_person_id" />
                                <field name="hold_reason" />

                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button class="btn-primary" name="close_dialog" string="Create" type="object" />
                        <button class="btn-secondary" special="cancel" string="Discard" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="sale_hold_request_tree" model="ir.ui.view">
            <field name="name">product.request.tree</field>
            <field name="model">product.request</field>
            <field name="arch" type="xml">
                <list string="Hold Request">
                    <field name="name" />
                    <field name="product_id" />
                    <field name="customer_id" />
                    <field name="sales_person_id" />
                    <field name="hold_reason" />
                </list>
            </field>
        </record>

        <record id="action_hold_request_all" model="ir.actions.act_window">
            <field name="name">Hold Requests</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'create': 0}</field>
            <field name="view_id" ref="sale_hold_request_tree" />
        </record>
        <record id="action_hold_request_approved" model="ir.actions.act_window">
            <field name="name">Hold Requests</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.request</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'approve')]</field>
            <field name="context">{'create': 0}</field>
            <field name="view_id" ref="sale_hold_request_tree" />
        </record>
        <record id="product_template_kanban_view_inherit" model="ir.ui.view">
            <field name="name">product.template.kanban.view.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_kanban_view" />
            <field name="arch" type="xml">

                <xpath expr="//div[@name='product_lst_price']" position="before">

                    <ul>
                        <li>Project: <field name="project_id" /></li>
                    </ul>
                    <ul>
                        <li>Area: <field name="total_Area" /></li>
                    </ul>
                    <ul>
                        <li>Status: <field name="state" /></li>
                    </ul>

                </xpath>
            </field>
        </record>


        <record id="unit_template_action" model="ir.actions.act_window">
            <field name="name">Units</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form,kanban,activity</field>
            <field eval="[(5, 0, 0),                           (0, 0, {'view_mode': 'kanban', 'view_id': ref('product.product_template_kanban_view')}),                           (0, 0, {'view_mode': 'list', 'view_id': ref('real_estate.product_template_list_view_inherit')})]" name="view_ids" />
            <field name="search_view_id" ref="product.product_template_search_view" />
            <field name="context">{'default_is_residential': True, 'search_default_is_residential': 1,
                                   'search_default_is_land': 1}</field>
            
        </record>
        <menuitem action="unit_template_action" groups="sales_team.group_sale_salesman" id="property_menu_catalog" name="Properties" parent="realestate_project.real_estate_root_menu" sequence="-99" />
        <menuitem id="sale.prod_config_main" name="Properties" parent="sale.menu_sale_config" sequence="5" />
        <menuitem action="unit_template_action" id="sale.menu_product_template_action" name="Units" parent="property_menu_catalog" sequence="1" />


        <menuitem active="False" id="menu_hold_request" name="Hold Requests" parent="crm.crm_menu_root" sequence="7" />
        <menuitem action="action_hold_request_all" id="menu_all_hold_request" name="All requests" parent="menu_hold_request" sequence="1" />
        <menuitem action="action_hold_request_approved" id="menu_approved_hold_request" name="Approved requests" parent="menu_hold_request" sequence="2" />


    </data>
</odoo>
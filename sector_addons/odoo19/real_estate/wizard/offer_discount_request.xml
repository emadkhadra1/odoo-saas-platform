<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="discount_request_wizard_view" model="ir.ui.view">
        <field name="name">discount.request.wizard.view</field>
        <field name="model">discount.request.wizard</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <group>
                            <field force_save="1" name="offer_id" readonly="1" />
                            <field force_save="1" name="unit_id" readonly="1" />
                            <field name="unit_price" />
                        </group>
                        <group>
                            <field name="discount_type" />
                            <field name="discount_percentage" />
                            <field name="discount_amount" />
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button class="oe_highlight" name="confirm" string="Confirm" type="object" />
                    <button class="oe_link" special="cancel" string="Cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="offer_discount_request_view" model="ir.ui.view">
        <field name="name">offer.discount.request.view</field>
        <field name="model">discount.request</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" string="">
                <header>
                    <button class="oe_highlight" groups="real_estate.discount_first_approve" name="action_first_approve" string="First Approve" type="object" />
                    <button class="oe_highlight" groups="real_estate.discount_second_approve" name="action_second_approval" string="Second Approve" type="object" />
                    <button class="oe_highlight" groups="real_estate.discount_final_approve" name="action_approved" string="Approve" type="object" />
                    <button groups="real_estate.discount_first_approve,real_estate.discount_second_approve,real_estate.discount_final_approve" name="action_reject" string="Reject" type="object" />
                    <field name="state" statusbar_visible="draft,first_approval,second_approval,approved" widget="statusbar" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field force_save="1" name="offer_id" readonly="1" />
                            <field force_save="1" name="unit_id" readonly="1" />
                            <field name="unit_price" />
                        </group>
                        <group>
                            <field name="discount_type" />
                            <field name="discount_percentage" />
                            <field name="discount_amount" />
                            <field name="price_after_disc" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="offer_discount_request_tree" model="ir.ui.view">
        <field name="name">offer.discount.request.tree</field>
        <field name="model">discount.request</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="offer_id" />
                <field name="unit_id" />
                <field name="unit_price" />
            </list>
        </field>
    </record>

    <record id="offer_discount_request_action" model="ir.actions.act_window">
        <field name="name">Discount Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">discount.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem action="offer_discount_request_action" id="discount_request_menu" name="Discount Requests" parent="real_estate.contracts_menu_categ" />
</odoo>
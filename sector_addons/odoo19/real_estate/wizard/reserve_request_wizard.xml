<odoo>
    <record id="reserve_request_wizard_from" model="ir.ui.view">
        <field name="name">reserve.request.wizard.form</field>
        <field name="model">reserve.request.wizard</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <group>
                            <field name="offer_id" readonly="True" force_save="1"/>
                            <field name="unit_id" readonly="True" force_save="1"/>
                        </group>
                        <group>
                            <field name="amount"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="confirm" string="Confirm" class="oe_highlight" type="object"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
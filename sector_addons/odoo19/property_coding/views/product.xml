<?xml version='1.0' encoding='utf-8'?>
<odoo>
    
    <record id="product_real_estate_ineherit" model="ir.ui.view">
        <field name="name">product.template.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="real_estate.product_real_estate" />
        <field name="arch" type="xml">

            <xpath expr="//div[@name='options']" position="inside">
                <div>
                    <field force_save="1" name="manual_creation_name" />
                    <label for="manual_creation_name" />
                </div>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="attrs">
                    {'readonly':['&amp;',('manual_creation_name','=',False),'|',('is_land','=',True),('is_residential','=',True)]}
                </attribute>
            </xpath>

        </field>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resource_calendar_form_qimam_attendance" model="ir.ui.view">
        <field name="name">resource.calendar.form.qimam.attendance</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="سياسة الحضور والانصراف">
                    <field name="qimam_attendance_policy_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

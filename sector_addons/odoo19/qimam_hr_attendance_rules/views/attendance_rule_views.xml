<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qimam_attendance_policy_list" model="ir.ui.view">
        <field name="name">qimam.attendance.policy.list</field>
        <field name="model">qimam.attendance.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="grace_minutes"/>
                <field name="monthly_permission_minutes"/>
                <field name="overtime_start_after_minutes"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_qimam_attendance_policy_form" model="ir.ui.view">
        <field name="name">qimam.attendance.policy.form</field>
        <field name="model">qimam.attendance.policy</field>
        <field name="arch" type="xml">
            <form string="Attendance Policy">
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="grace_minutes"/>
                            <field name="monthly_permission_minutes"/>
                        </group>
                        <group>
                            <field name="overtime_start_after_minutes"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="rule_type"/>
                            <field name="from_minutes"/>
                            <field name="to_minutes"/>
                            <field name="deduction_hours"/>
                            <field name="deduction_days"/>
                            <field name="overtime_rate"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qimam_attendance_policy_line_list" model="ir.ui.view">
        <field name="name">qimam.attendance.policy.line.list</field>
        <field name="model">qimam.attendance.policy.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="policy_id"/>
                <field name="rule_type"/>
                <field name="from_minutes"/>
                <field name="to_minutes"/>
                <field name="deduction_hours"/>
                <field name="deduction_days"/>
                <field name="overtime_rate"/>
            </list>
        </field>
    </record>

    <record id="action_qimam_attendance_policy" model="ir.actions.act_window">
        <field name="name">Attendance Policies</field>
        <field name="res_model">qimam.attendance.policy</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qimam_attendance_policy_line" model="ir.actions.act_window">
        <field name="name">Attendance Rules</field>
        <field name="res_model">qimam.attendance.policy.line</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_qimam_attendance_rules_root" name="Attendance Rules" parent="hr_attendance.menu_hr_attendance_root" sequence="55"/>
    <menuitem id="menu_qimam_attendance_policies" name="Attendance Policies" parent="menu_qimam_attendance_rules_root" action="action_qimam_attendance_policy" sequence="10"/>
    <menuitem id="menu_qimam_attendance_rules" name="Rule Lines" parent="menu_qimam_attendance_rules_root" action="action_qimam_attendance_policy_line" sequence="20"/>
</odoo>

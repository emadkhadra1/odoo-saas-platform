<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qimam_hr_document_type_list" model="ir.ui.view">
        <field name="name">qimam.hr.document.type.list</field>
        <field name="model">qimam.hr.document.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="requires_expiry"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_qimam_hr_document_type_form" model="ir.ui.view">
        <field name="name">qimam.hr.document.type.form</field>
        <field name="model">qimam.hr.document.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="requires_expiry"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_qimam_hr_document_list" model="ir.ui.view">
        <field name="name">qimam.hr.document.list</field>
        <field name="model">qimam.hr.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="expiry_status == 'expired'" decoration-warning="expiry_status == 'expiring'" decoration-success="expiry_status == 'valid'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="document_type_id"/>
                <field name="document_number"/>
                <field name="expiry_date"/>
                <field name="days_to_expire"/>
                <field name="expiry_status"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_qimam_hr_document_form" model="ir.ui.view">
        <field name="name">qimam.hr.document.form</field>
        <field name="model">qimam.hr.document</field>
        <field name="arch" type="xml">
            <form string="وثيقة موظف">
                <header>
                    <button name="action_confirm" string="تأكيد" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_mark_expired" string="تسجيل كمنتهية" type="object" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="إلغاء" type="object" invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_reset_to_draft" string="إرجاع إلى مسودة" type="object" invisible="state not in ('expired', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="document_type_id" readonly="state != 'draft'"/>
                            <field name="document_number"/>
                            <field name="issue_place"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expire"/>
                            <field name="expiry_status"/>
                        </group>
                    </group>
                    <group>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                    <notebook>
                        <page string="ملاحظات">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qimam_hr_document_search" model="ir.ui.view">
        <field name="name">qimam.hr.document.search</field>
        <field name="model">qimam.hr.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="document_type_id"/>
                <filter name="expiring" string="قريبة الانتهاء" domain="[('expiry_status','=','expiring')]"/>
                <filter name="expired" string="منتهية" domain="[('expiry_status','=','expired')]"/>
            </search>
        </field>
    </record>

    <record id="action_qimam_hr_document" model="ir.actions.act_window">
        <field name="name">وثائق الموظفين</field>
        <field name="res_model">qimam.hr.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_qimam_hr_document_type" model="ir.actions.act_window">
        <field name="name">أنواع الوثائق</field>
        <field name="res_model">qimam.hr.document.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qimam_hr_document_root" name="وثائق الموظفين" parent="hr.menu_hr_root" sequence="43"/>
    <menuitem id="menu_qimam_hr_document" name="الوثائق" parent="menu_qimam_hr_document_root" action="action_qimam_hr_document" sequence="10"/>
    <menuitem id="menu_qimam_hr_document_type" name="أنواع الوثائق" parent="menu_qimam_hr_document_root" action="action_qimam_hr_document_type" sequence="20"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_qimam_hr_loan" model="ir.ui.view">
        <field name="name">hr.employee.form.qimam.hr.loan</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_qimam_loans" type="object" class="oe_stat_button" icon="fa-money">
                    <field name="loan_count" widget="statinfo" string="Loans"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>

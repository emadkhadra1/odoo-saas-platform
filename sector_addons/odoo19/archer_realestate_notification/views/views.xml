<odoo>
    <data>
        <record id="sale.view_order_form" model="ir.ui.view">
            <field name="active" eval="False"/>
        </record>

        <record id="sale.action_orders_to_invoice" model="ir.actions.act_window">
            <field name="name">Orders to Invoice</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form,calendar,graph,pivot,kanban,activity</field>
            <field name="context">{'create': False,
                                   'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>
            <field name="domain">[('invoice_status', '=', 'to invoice')]</field>
            <field name="search_view_id" ref="sale.view_sales_order_filter"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No orders to invoice found
                </p>
                <p>
                    You can select all orders and invoice them in batch,
                    <br/>
                    or check every order and invoice them one by one.
                </p>
            </field>
        </record>
        <record id="sale.action_orders_upselling" model="ir.actions.act_window">
            <field name="name">Orders to Upsell</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form,calendar,graph,pivot,kanban,activity</field>
            <field name="domain">[('invoice_status', '=', 'upselling')]</field>
            <field name="context">{'create': False,
                                   'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>
            <field name="search_view_id" ref="sale.view_sales_order_filter"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No orders to upsell found.
                </p>
                <p>
                    An order is to upsell when delivered quantities are above initially
                    ordered quantities, and the invoicing policy is based on ordered quantities.
                </p>
                <p>
                    As an example, if you sell pre-paid hours of services, Odoo recommends you
                    to sell extra hours when all ordered hours have been consumed.
                </p>
            </field>
        </record>
        <record id="sale.action_sale_order_form_view" model="ir.actions.act_window">
            <field name="name">Sales Order</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">form,list,kanban,calendar,pivot,graph,activity</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
            <field name="context">{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>

            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation, the first step of a new sale!
                </p>
                <p>
                    Once the quotation is confirmed, it becomes a sales order.
                    <br/>
                    You will be able to create an invoice and collect the payment.
                </p>
            </field>
        </record>
        <record id="sale.action_orders" model="ir.actions.act_window">
            <field name="name">Sales Orders</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
            <field name="context">{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>
            <field name="domain">[('state', 'not in', ('draft', 'sent', 'cancel'))]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation, the first step of a new sale!
                </p>
                <p>
                    Once the quotation is confirmed, it becomes a sales order.
                    <br/>
                    You will be able to create an invoice and collect the payment.
                </p>
            </field>
        </record>
        <record id="sale.action_quotations" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
            <field name="context">{'search_default_my_quotation': 1,
                                   'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation, the first step of a new sale!
                </p>
                <p>
                    Once the quotation is confirmed by the customer, it becomes a sales order.
                    <br/>
                    You will be able to create an invoice and collect the payment.
                </p>
            </field>
        </record>
        <record id="sale.sale_order_action_view_order_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="101"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
            <field name="act_window_id" ref="sale.action_orders"/>
        </record>
        <record id="sale_action_sale_order_form_view_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="200"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
            <field name="act_window_id" ref="sale.action_sale_order_form_view"/>
        </record>
        <record id="sale.sale_order_action_view_order_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="3"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
            <field name="act_window_id" ref="sale.action_orders"/>
        </record>
        <record id="sale.sale_order_action_view_quotation_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="1000"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
            <field name="act_window_id" ref="sale.action_quotations"/>
        </record>
        <record id="real_estate_action_quotation_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="100"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
            <field name="act_window_id" ref="sale.action_quotation_form"/>
        </record>
        <record id="sale_crm.sale_action_quotations_new" model="ir.actions.act_window">
            <field name="name">Quotation</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">form,list,graph</field>
            <field name="domain">[('opportunity_id', '=', active_id)]</field>
            <field name="context">{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>

            <field name="context">{'search_default_opportunity_id': active_id,
                                   'default_opportunity_id': active_id}</field>
        </record>


        <record id="sale.action_orders_to_invoice" model="ir.actions.act_window">
            <field name="name">Orders to Invoice</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form,calendar,graph,pivot,kanban,activity</field>
            <field name="context">{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm',
                                   'create': False}</field>

            <field name="domain">[('invoice_status', '=', 'to invoice')]</field>
            <field name="search_view_id" ref="sale.view_sales_order_filter"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No orders to invoice found
                </p>
                <p>
                    You can select all orders and invoice them in batch,
                    <br/>
                    or check every order and invoice them one by one.
                </p>
            </field>
        </record>
        <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.order</field>
            <field name="view_id" ref="sale.view_quotation_tree_with_onboarding"/>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
            <field name="context">{'search_default_my_quotation': 1,
                                   'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation, the first step of a new sale!
                </p>
                <p>
                    Once the quotation is confirmed by the customer, it becomes a sales order.
                    <br/>
                    You will be able to create an invoice and collect the payment.
                </p>
            </field>
        </record>


    </data>
</odoo>
<odoo>
    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">view_employee_form_inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//h1" position="after">
                <h2>
                    <field name="arabic_name" placeholder="Arabic Name"/>
                </h2>
            </xpath>
            <xpath expr="//field[@name='certificate']" position="after">
                    <field name="graduation_date"/>
            </xpath>

        </field>
    </record>
    <record id="view_employee_payroll_form_inherit" model="ir.ui.view">
        <field name="name">view_employee_form_inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_payroll.payroll_hr_employee_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='registration_number']" position="replace">
                    <field name="salary_structure_id"/>
            </xpath>

        </field>
    </record>
</odoo>
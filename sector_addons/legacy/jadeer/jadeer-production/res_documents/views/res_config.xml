<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@data-key='hr']" position="inside">
                    <h2>Employee Document</h2>
                    <div class="row mt16 o_settings_container">
                        <div name="emp_docs" class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="egyptian_employee_document_ids"/>
                                <span class="fa fa-lg fa-building-o" title="Values set here are company-specific."
                                      role="img" aria-label="Values set here are company-specific."
                                      groups="base.group_multi_company"/>
                                <div class="row">
                                    <div class="text-muted col-lg-8">
                                        set egyptian employee required documents.
                                    </div>
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <field name="egyptian_employee_document_ids"
                                               class="o_light_label"
                                               widget="many2many_tags"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
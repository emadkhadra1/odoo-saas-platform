<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rules -->
    <record id="document_emp_multi_company_rule" model="ir.rule">
        <field name="name">Employee Document Multi Company</field>
        <field name="model_id" ref="model_res_documents"/>
        <field name="domain_force">
            ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
        </field>
    </record>

    <record id="document_emp_rule" model="ir.rule">
        <field name="name">Employee</field>
        <field name="model_id" ref="model_res_documents"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">['|', ('message_partner_ids', '=', user.partner_id.id),
            ('employee_id.user_id','=',user.id)]
        </field>
    </record>

    <record id="document_emp_rule" model="ir.rule">
        <field name="name">Employee</field>
        <field name="model_id" ref="model_res_documents"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">['|', ('message_partner_ids', '=', user.partner_id.id),
            ('employee_id.user_id','=',user.id)]
        </field>
    </record>

    <record id="employee_officer_rule" model="ir.rule">
        <field name="name">Officer</field>
        <field name="model_id" ref="model_res_documents"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="domain_force">['|', ('message_partner_ids', 'child_of', [user.partner_id.id]), '|',
            ('manager_id','=',False), ('manager_id.user_id','=', user.id)]
        </field>
    </record>

    <record id="employee_manager_rule" model="ir.rule">
        <field name="name">Manager</field>
        <field name="model_id" ref="model_res_documents"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        <field name="domain_force">[]</field>
    </record>
</odoo>
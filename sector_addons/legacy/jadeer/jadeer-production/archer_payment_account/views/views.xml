<odoo>
    <record id="view_account_payment_form_inherit" model="ir.ui.view">
        <field name="name">account.payment.form</field>
        <field name="model">account.payment</field>
        <field name="priority" eval="99"/>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header//button[@name='action_post']" position="after">
                <button name="approve_payment_transfer" string="Approve" type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('state', '!=', 'draft')]}"
                        groups="archer_payment_account.group_approve_payment"
                />
            </xpath>
            <xpath expr="//header//button[@name='action_post']" position="replace">
                <button name="action_post" string="Confirm" type="object" class="oe_highlight"
                        attrs="{'invisible': [('state', '!=', 'approved')]}" data-hotkey="v"/>
            </xpath>

            <xpath expr="//header//button[@name='action_cancel']" position="attributes">
                <attribute name="attrs">{'invisible': [('state', '!=', 'approved')]}
                </attribute>
            </xpath>

        </field>
    </record>
</odoo>
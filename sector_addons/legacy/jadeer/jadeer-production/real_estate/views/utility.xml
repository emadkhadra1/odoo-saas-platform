<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="utility_form" model="ir.ui.view">
            <field name="name">utility.utility.form.view</field>
            <field name="model">utility.utility</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="code" required="1"/>
                                <field name="percent" required="0" invisible="1"/>
                                <field name="journal_id" required="1"/>
                            </group>
                            <group>
                                <field name="account_id" required="1" options="{'no_create':True}"/>
                                <field name="receivable_account_id" required="1" options="{'no_create':True}"/>

                                <field name="company_id"
                                       groups="base.group_multi_company"
                                       options="{'no_create': True}"/>

                            </group>
                        </group>
                    </sheet>


                </form>
            </field>
        </record>
        <record id="utility_tree" model="ir.ui.view">
            <field name="name">utility.utility.tree.view</field>
            <field name="model">utility.utility</field>
            <field name="arch" type="xml">
                <tree string="">
                   <field name="name" />
                    <field name="code" />
                    <field name="account_id" />
                </tree>
            </field>
        </record>
        <record id="utility_action" model="ir.actions.act_window">
            <field name="name">Utility</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">utility.utility</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
        </record>
        <menuitem id="utility_categ" name="Utilities" action="utility_action"
                  parent="realestate_project.real_estate_configuration_menu" sequence="6"/>

    </data>
</odoo>

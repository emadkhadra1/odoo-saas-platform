<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="real_estate_project_view_kanban" model="ir.ui.view">
            <field name="name">real.estate.project</field>
            <field name="model">real.estate.project</field>
            <field name="inherit_id" ref="realestate_project.real_estate_project_view_kanban"/>

            <field name="arch" type="xml">
                  <xpath expr="//div[@name='tags2']" position="before">
                    <ul>
                        <li>Location: <field name="product_areas" /></li>
                    </ul>
                  </xpath>
            </field>
        </record>
        <record id="real_estate_project_view_form" model="ir.ui.view">
            <field name="name">real.estate.project.form</field>
            <field name="model">real.estate.project</field>
            <field name="inherit_id" ref="realestate_project.real_estate_project_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="button_delivery" string="Delivery" type="object" class="oe_highlight" groups="real_estate_security.group_manager"
                            attrs="{'invisible':[('is_delivered','=',True)]}"/>
                    <button name="button_accounting_entry" string="Accounting Entry" type="object" class="oe_highlight" groups="real_estate_security.group_manager"
                            attrs="{'invisible':[('is_delivered','=',False)]}"/>
                </xpath>
                <xpath expr="//div[@class='oe_button_box']" position="inside">
                    <button type="object" string="Costing Entries" class="oe_stat_button" icon="fa-list"
                            name="action_open_costing_entry">
                    </button>
                </xpath>
                <xpath expr="//field[@name='analytic_account_id']" position="after">
                    <field name="payment_plan_ids" widget="many2many_tags"/>
                    <field name="reserve_days_no"/>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="product_areas"/>
                     <field name="total_meter"/>
                    <field name="is_delivered" readonly="1"/>

<!--                    <field name="singularity_ids" widget="many2many_tags"/>-->
                </xpath>
               <xpath expr="//page[@name='images']" position="before">
                    <page string="Units">
                        <group>
                            <group>
                                <field name="unit_type_ids" widget="many2many_tags"/>
                                <field name="filter_attached_areas_ids" widget="many2many_tags" invisible="1"/>
                                <field name="attached_areas_ids" widget="many2many_tags"
                                       domain="[('id','in',filter_attached_areas_ids)]"/>
                            </group>
                        </group>
                    </page>
                    <page string="Singularities">
                        <field name="project_singularity_ids">
                                <tree editable="bottom">
                                    <field name="privilege_id" required="1"/>
                                    <field name="percent"/>
                                </tree>
                            </field>
                    </page>
                    <page string="Utilities">
                        <field name="project_utility_ids">
                                <tree editable="bottom">
                                    <field name="utility_id" required="1"/>
                                    <field name="type"/>
                                    <field name="percent"/>
                                </tree>
                            </field>
                    </page>
                </xpath>
                <xpath expr="//page[last()]" position="after">
                    <page string="Car Spot">
                        <group>
                            <group>
                                <field name="car_spot"/>
                                <field name="car_spot_price"  force_save="1" attrs="{'invisible':[('car_spot','=',False)],
                                                                    'required':[('car_spot','=',True)]}"/>
                                <field name="parking_code" attrs="{'invisible':[('car_spot','=',False)],
                                                                   'required':[('car_spot','=',True)]}"/>

                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
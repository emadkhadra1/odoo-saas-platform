<odoo>
    <record model="ir.ui.view" id="view_account_payment_inv_tree">
        <field name="name">view.account.payment.inv.tree</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="unit_id"/>
                <field name="unit_state"/>
            </xpath>
        </field>
    </record>
    <record model="ir.ui.view" id="view_account_payment_inv_form_inh_l10n_mx_realstate">
        <field name="name">view.account.payment.inv.form.inh.l10n.mx</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="offer_id" domain="[('partner_id','=',partner_id)]"/>
                </xpath>
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="so_id" attrs="{'readonly':[('state','!=','draft')]}" invisible="1"/>
                    <field name="install_id" readonly="1" force_save="1"/>
                </xpath>
            </data>
        </field>
    </record>
    <!-- Inherit Form View to Modify it -->
    <record id="view_account_journal_form_inherit_deposit" model="ir.ui.view">
        <field name="name">account.journal.form</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="is_blank" attrs="{'invisible':[('type', 'not in', ['bank', 'cash'])]}"/>
            </xpath>
        </field>
    </record>
</odoo>
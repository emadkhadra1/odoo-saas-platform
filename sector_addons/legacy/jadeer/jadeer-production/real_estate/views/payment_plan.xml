<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="real_payment_plan_form">
            <field name="name">payment_plan_form</field>
            <field name="model">payment.plan</field>
            <field name="arch" type="xml">
                <form string="Payment plan">
                    <sheet>
                       <div class="oe_title">
                            <h1 style="color:teal;">
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="discount_type" widget="radio" options="{'horizontal': true}"/>
                                <field name="discount_amount" attrs="{'invisible': [('discount_type','!=','amount')]}"/>
                                <field name="discount_percentage"
                                       attrs="{'invisible': [('discount_type','!=','percentage')]}"/>
                            </group>
<!--                            <group>-->
<!--                                <field name="sales_person" widget="many2many_tags" required="1"/>-->
<!--                            </group>-->
                        </group>
                        <notebook>
                            <page string="Distribution">
                                <field name="payment_line_ids">
                                    <tree editable="bottom">
                                        <field name="pricing_unit" invisible="1"/>
                                        <field name="percentage"/>
                                        <field name="duration"/>
                                        <field name="value" invisible="1"/>
                                        <field name="schedule_period" invisible="1"/>
                                        <field name="pay_type"/>
                                        <field name="start_date" invisible="1"/>
                                        <field name="is_product" invisible="1"/>
                                        <field name="amount" invisible="1"/>
                                        <field name="no_of_installements"
                                               attrs="{'readonly':[('pay_type','not in',['installment','maintenance'])]}"/>
                                        <field name="line_interset" invisible="1"/>
                                        <field name="non_return" invisible="1"/>

                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="real_payment_plan_tree">
            <field name="name">payment_plan_tree</field>
            <field name="model">payment.plan</field>
            <field name="arch" type="xml">
                <tree string="Payment plan">
                    <field name="name"/>
                </tree>
            </field>
        </record>


        <record id="payment_plan_form_view" model="ir.actions.act_window">
            <field name="name">Payment plan</field>
            <field name="res_model">payment.plan</field>
            <field name="view_mode">tree,form</field>


            <field eval="False" name="view_id"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">Click to create a customer invoice.</p>
                <p>Odoo's electronic invoicing allows to ease and fasten the collection of customer payments.
                    Your customer receives the invoice by email and he can pay online and/or import
                    it in his own system.
                </p>
                <p>The discussions with your customer are automatically displayed at the bottom of each
                    invoice.
                </p>
            </field>
        </record>
        <record id="payment_plan_form_view1" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="real_payment_plan_tree"/>
            <field name="act_window_id" ref="payment_plan_form_view"/>
        </record>
        <record id="payment_plan_tree_view" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_payment_plan_form"/>
            <field name="act_window_id" ref="payment_plan_form_view"/>
        </record>


        <menuitem name="Payment Plans" id="real_estate_payment_plan"
                  parent="realestate_project.real_estate_configuration_menu"
                  action="payment_plan_form_view"/>

    </data>
</odoo>
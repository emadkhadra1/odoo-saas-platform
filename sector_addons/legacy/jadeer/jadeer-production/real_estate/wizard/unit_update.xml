<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="unit_update_view_form" model="ir.ui.view">
            <field name="name">unit.update.name</field>
            <field name="model">unit.update</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <field name="type" widget="radio"/>
                        </group>
                        <group>
                            <group attrs="{'invisible':[('type','=','direct')]}">
                                <label for="unit_area" string="Unit Area"/>
                                <div class="o_row">
                                    <field name="unit_area" style="width:30%"/>
                                    <span>Price/Meter</span>
                                    <field name="unit_meter_price" class="oe_inline" widget="monetary"/>
                                </div>
<!--                                <label for="land_area" string="Land Area"/>-->
<!--                                <div class="o_row" id="land_area">-->
<!--                                    <field name="land_area" style="width:30%"/>-->
<!--                                    <span>Price/Meter</span>-->
<!--                                    <field name="land_meter_price" class="oe_inline" widget="monetary"/>-->
<!--                                </div>-->
<!--                                <label for="extra_land_area" string="Extra Land"/>-->
<!--                                <div class="o_row">-->
<!--                                    <field name="extra_land_area" style="width:30%"/>-->
<!--                                    <span>Price/Meter</span>-->
<!--                                    <field name="extra_land_meter_price" class="oe_inline" widget="monetary"/>-->
<!--                                </div>-->
                                <field name="min_deposit_amount"/>
                            </group>
                            <group attrs="{'invisible':[('type','=','not_direct')]}">
                                <field name="sale_price"/>
                            </group>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <div attrs="{'invisible':[('type','=','direct')]}">
                            <field name="privilege_ids">
                                <tree editable="top">
                                    <field name="privilege_id"/>
                                    <field name="percent"/>
                                </tree>
                            </field>
                        </div>
                        <div attrs="{'invisible':[('type','=','direct')]}">
                            <field name="utility_ids">
                                <tree editable="top">
                                    <field name="utility_id"/>
                                    <field name="price"/>
                                </tree>
                            </field>
                        </div>

                        <notebook>
                            <page string="Units">
                                <field name="product_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Update" name="action_update_unit_data" class="btn-primary" type="object"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="unit_update_window_action" model="ir.actions.act_window">
            <field name="name">Unit Update</field>
            <field name="res_model">unit.update</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="unit_update_menu"
                  name="Unit Update"
                  parent="realestate_project.real_estate_configuration_menu"
                  action="unit_update_window_action"
                  sequence="10"
        />

    </data>
</odoo>
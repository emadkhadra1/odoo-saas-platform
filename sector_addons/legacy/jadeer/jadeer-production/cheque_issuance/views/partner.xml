<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="view_partner_property_form" model="ir.ui.view">
            <field name="name">res.partner</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.view_partner_property_form"/>
            <field name="arch" type="xml">

                <xpath expr="//group[@name='accounting_entries']" position="inside">
                    <field name="is_advance_payment_client"/>
                    <field name="advance_payment_account_id" domain="[('user_type_id.type','=','payable')]"
                           attrs="{'invisible':[('is_advance_payment_client','=',False)],'required':[('is_advance_payment_client','=',True)]}"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
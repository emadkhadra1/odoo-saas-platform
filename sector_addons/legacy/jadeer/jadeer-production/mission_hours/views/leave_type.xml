<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="edit_holiday_status_form" model="ir.ui.view">
            <field name="name">hr.leave.type.form</field>
            <field name="model">hr.leave.type</field>
            <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='responsible_id']" position="attributes">
                    <attribute name="string">HR Department</attribute>
                </xpath>
                <xpath expr="//field[@name='request_unit']" position="after">
                    <field name="mission_hours"/>
                    <field name="occurrence_number"
                           attrs="{'invisible':[('mission_hours','=',False)],'required':[('mission_hours','=',True)]}"/>
                    <field name="min_hour_per_time"
                           attrs="{'invisible':[('mission_hours','=',False)],'required':[('mission_hours','=',True)]}"/>
                    <field name="max_hour_per_time"
                           attrs="{'invisible':[('mission_hours','=',False)],'required':[('mission_hours','=',True)]}"/>
                </xpath>

            </field>
        </record>
    <menuitem
        id="hr_holidays.menu_open_allocation"
        name="My leaves"
        parent="hr_holidays.menu_hr_holidays_my_leaves"
        action="hr_holidays.hr_leave_allocation_action_my"
        sequence="3"/>
            <record id="hr_holidays.hr_leave_allocation_action_my" model="ir.actions.act_window">
        <field name="name">My leave</field>
            </record>
        <record id="hr_holidays.hr_leave_allocation_action_approve_department" model="ir.actions.act_window">
        <field name="name">leave</field>
            </record>

       <menuitem
        id="hr_holidays.hr_holidays_menu_manager_approve_allocations"
        name="leaves"
        parent="hr_holidays.menu_hr_holidays_approvals"
        action="hr_holidays.hr_leave_allocation_action_approve_department"
        sequence="2"/>

    </data>
</odoo>

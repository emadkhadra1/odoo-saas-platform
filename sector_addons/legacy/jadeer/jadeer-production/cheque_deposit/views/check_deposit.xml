<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="account_check_cash" model="ir.ui.view">
        <field name="name">account.check.cash.Form</field>
        <field name="model">account.check.cash</field>
        <field name="arch" type="xml">
            <form string="Cash Cheques">
                <group>
                    <group>
                        <field name="cash_journal_id"/>
                        <field name="payment_id" invisible="1"/>
                    </group>
                    <group></group>
                </group>
                <footer>
                    <button name="create_cash_move" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="account_check_deposit_view_form" model="ir.ui.view">
        <field name="name">account.Cheque.deposit.form</field>
        <field name="model">account.check.deposit</field>
        <field name="arch" type="xml">
            <form string="Cheques Deposit">
                <header>
                    <button name="validate_deposit" states="draft"
                            string="Validate"
                            type="object" class="oe_highlight"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done,close"/>
                </header>
                <sheet>
                    <h1>
                        <field name="name" string="Cheque Deposit" class="oe_inline"/>
                    </h1>
                    <group name="main">
                        <group name="left">
                            <field name="deposit_date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="journal_id" attrs="{'readonly': [('state', '!=', 'draft')]}"
                            />
                            <field name="currency_id" groups="base.group_multi_currency" attrs="{'readonly': [('state', '!=', 'draft')]}"
                            />
                            <field name="bank_journal_id" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        </group>
                        <group name="right">
                            <field name="company_id" attrs="{'readonly': [('state', '!=', 'draft')]}"
                                   groups="base.group_multi_company"/>
                            <field name="check_count"/>
                            <field name="total_amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="move_id"/>
                        </group>
                    </group>
                    <group string="Cheque Payments" name="check_payments">
                        <field name="check_payment_ids" nolabel="1" attrs="{'readonly': [('state', '!=', 'draft')]}"
                               widget="many2many"

                               domain="[
                                            ('payment_type_check', '=', 'check'),
                                            ('check_deposit_id', '=', False),
                                            ('state', '=', 'posted'),('payment_status', '=', 'posted'),('journal_id', '=', journal_id)
                                            ]"
                               context="{'currency': currency_id,
                                        'journal_id': journal_id}">
                            <tree editable="bottom" delete="0"
                                  decoration-info="payment_status=='deposit'"
                                  decoration-danger="payment_status=='returned'"
                                  decoration-success="payment_status=='collected'">
                                <field name="date" readonly="1"/>
                                <field name="due_date" readonly="1"/>
                                <field name="journal_id" readonly="1"/>
                                <field name="name" readonly="1"/>
                                <field name="ref" readonly="1"/>
                                <field name="partner_id" readonly="1"/>
                                <field name="amount" sum="Total Amount" readonly="1"/>
                                <field name="currency_id" readonly="True" groups="base.group_multi_currency"/>
                                <field name="payment_status" readonly="1"/>
                                <button name="unlink_move_line" type="object"
                                        icon="fa-trash-o"
                                />
                            </tree>
                        </field>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="account_check_deposit_view_tree" model="ir.ui.view">
        <field name="name">account.check.deposit.tree</field>
        <field name="model">account.check.deposit</field>
        <field name="arch" type="xml">
            <tree string="Cheques Deposits" decoration-info="state=='draft'">
                <field name="name"/>
                <field name="deposit_date"/>
                <field name="journal_id"/>
                <field name="bank_journal_id"/>
                <field name="check_count"/>
                <field name="total_amount"/>
                <field name="currency_id" groups="base.group_multi_currency"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_check_deposit_search" model="ir.ui.view">
        <field name="name">account.check.deposit.search</field>
        <field name="model">account.check.deposit</field>
        <field name="arch" type="xml">
            <search string="Cheques Deposit Search">
                <field name="name" string="Cheques Deposit"/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="done" string="Done"
                        domain="[('state', '=', 'done')]"/>
                <group string="Group By" name="groupby">
                    <filter name="date_groupby" string="Deposit Date"
                            context="{'group_by': 'deposit_date'}"/>
                    <filter name="journal_groupby" string="Journal"
                            context="{'group_by': 'journal_id'}"/>
                    <filter name="currency_groupby" string="Currency"
                            context="{'group_by': 'currency_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_check_deposit_tree" model="ir.actions.act_window">
        <field name="name">Cheques Deposits</field>
        <field name="res_model">account.check.deposit</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="account_check_deposit_view_tree"/>
    </record>

    <menuitem action="action_check_deposit_tree"
              id="menu_check_deposit_tree"
              parent="payment_cheques_menu"
              sequence="0"/>
</odoo>
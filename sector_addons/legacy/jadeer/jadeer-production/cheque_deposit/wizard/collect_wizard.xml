<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="collect_wizard_form" model="ir.ui.view">
            <field name="name">collect.wiz.form</field>
            <field name="model">collect.wizard</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="account_payment_id" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lines">
                                <field name="line_ids">
                                    <tree editable="bottom" create="0" edit="1" delete="0">
                                        <field name="payment_id" />
                                        <field name="analytic_account_id" invisible="1"/>
                                        <field name="fee_percent" attrs="{'readonly':[('is_no_fee','=',True)]}"/>
                                        <field name="fee_amount" attrs="{'readonly':[('is_no_fee','=',True)]}"/>
                                        <field name="apply_fee" attrs="{'readonly':[('is_no_fee','=',True)]}"/>
                                        <field name="is_no_fee" invisible="1"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Collect" name="collect" class="btn-primary" type="object"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_account_payment_form" model="ir.ui.view">
            <field name="name">account.payment.form.inherit</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
<!--                    <button name="transfer_check" type="object" string="Transfer"-->
<!--                            class="btn-success"-->
<!--                            attrs="{'invisible': ['|','|',('transfer_move_id', '!=', False),('state','!=','posted'),('payment_type_check','!=','check')]}"/>-->
<!--                    -->
                    <button name="return_check" type="object" string="Refund Check"
                            class="btn-success"
                            attrs="{'invisible': ['|','|','|',('transfer_move_id', '=', False),('return_move_id', '!=', False),('state','!=','posted'),('payment_type_check','!=','check')]}"/>
                </xpath>
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="exclude_from_deposit"/>

                    <field name="transfer_move_id"
                           attrs="{'invisible': [('transfer_move_id', '=', False)]}" readonly="1"
                           options="{'no_open':1}"/>
                    <field name="return_move_id"
                           attrs="{'invisible': [('return_move_id', '=', False)]}" readonly="1"
                           options="{'no_open':1}"/>
                </xpath>
            </field>
        </record>


    </data>
</odoo>
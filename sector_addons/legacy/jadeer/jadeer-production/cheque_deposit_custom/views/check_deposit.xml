<?xml version="1.0" encoding="utf-8"?>

<odoo>


    <record id="account_check_deposit_view_form" model="ir.ui.view">
        <field name="name">account.Cheque.deposit.form</field>
        <field name="model">account.check.deposit</field>
        <field name="inherit_id" ref="cheque_deposit.account_check_deposit_view_form"/>
        <field name="arch" type="xml">
            <field name="check_payment_ids" position="attributes">
                <attribute name="domain">
                    [

                    ('exclude_from_deposit', '=', False),
                    ('payment_type_check', '=', 'check'),
                    ('check_deposit_id', '=', False),
                    ('state', '=', 'posted'),('payment_status', '=', 'posted'),('journal_id', '=', journal_id)
                ]
                </attribute>
            </field>
        </field>
    </record>

</odoo>
<data>
    <record id="payslip_attendance_form" model="ir.ui.view">
        <field name="name">payslip.attendance.form</field>
        <field name="model">payslip.attendance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" required="1"/>
                        </group>
                        <group>
                            <field name="hr_payslip_id"
                                   domain="[('employee_id', '=', employee_id),
                                             ('state', '=', 'done')]"
                                    required="1"/>
                        </group>
                    </group>

                    <footer>
                        <button string="View Onscreen" name="action_view_onscreen" type="object" class="oe_highlight" />
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="payslip_attendance_action" model="ir.actions.act_window">
        <field name="name">Payslip Attendance</field>
        <field name="res_model">payslip.attendance</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="payslip_attendance_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="payslip_attendance_menu"
              name="Check Payslip Attendance"
              action="payslip_attendance_action"
              parent="hr.menu_hr_root"
              sequence="40"/>

</data>
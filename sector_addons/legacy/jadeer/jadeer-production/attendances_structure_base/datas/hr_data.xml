<?xml version="1.0"?>
<odoo>
    <data noupdate="0">

        <record id="hr_attend_rule_over_time" model="hr.salary.rule">
            <field name="name">Over Time</field>
            <field name="sequence" eval="50"/>
            <field name="code">OVT</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = payslip.work_day_over_time + payslip.work_night_over_time + payslip.public_leave_over_time
            </field>
            <field name="struct_id" ref="salary_structure_demo.structure_worker1_001"/>
        </record>

        <record id="hr_attend_rule_ded" model="hr.salary.rule">
            <field name="name">Deduction</field>
            <field name="sequence" eval="150"/>
            <field name="code">DED</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result=bool(payslip.deduction_amount)</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = -(payslip.deduction_amount)</field>
            <field name="struct_id" ref="salary_structure_demo.structure_worker1_001"/>
        </record>

        <record id="hr_attend_rule_absent" model="hr.salary.rule">
            <field name="name">Absent</field>
            <field name="sequence" eval="155"/>
            <field name="code">ABS</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result=bool(payslip.absent_amount)</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = -(payslip.absent_amount)
            </field>
            <field name="struct_id" ref="salary_structure_demo.structure_worker1_001"/>
        </record>


        <record id="hr_attend_rule_no_checkout" model="hr.salary.rule">
            <field name="name">No Checkout</field>
            <field name="sequence" eval="160"/>
            <field name="code">OCH</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = - payslip.no_checkout_amount
            </field>
            <field name="struct_id" ref="salary_structure_demo.structure_worker1_001"/>
        </record>

        <record id="hr_attend_rule_not_in_contract" model="hr.salary.rule">
            <field name="name">Salary Adjustment</field>
            <field name="sequence" eval="165"/>
            <field name="code">SADJ</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = - payslip.not_in_contract_amount
            </field>
            <field name="struct_id" ref="salary_structure_demo.structure_worker1_001"/>
        </record>

    </data>
</odoo>
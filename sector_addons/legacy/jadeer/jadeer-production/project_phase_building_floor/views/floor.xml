<odoo>
    <data>
        <record id="project_floor_form" model="ir.ui.view">
            <field name="name">Floor Form</field>
            <field name="model">building.floor</field>
            <field name="arch" type="xml">
                <form string="Floor">
                    <sheet>
                        <group>
                            <group>
                                <field name="project_id" required="1"/>

                                <field name="building_id" required="1" domain="[('project_id','=',project_id)]"/>
                                <field name="name" required="1"/>
                                <field name="code" required="1" readonly="0" invisible="0" force_save="1"/>
                                <field name="cost" readonly="1" invisible="1"/>
                                <field name="analytic_tag_id" invisible="1" options="{'no_create':True}"/>
                                <field name="company_id"
                                       groups="base.group_multi_company"
                                       options="{'no_create': True}" invisible="1"/>
                                <field name="description" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="project_floor_tree" model="ir.ui.view">
            <field name="name">project_floor_tree</field>
            <field name="model">building.floor</field>
            <field name="arch" type="xml">
                <tree string="">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="building_id"/>
                    <field name="analytic_tag_id" invisible="1"/>
                                        <field name="project_id"/>

                </tree>
            </field>
        </record>
        <record id="view_floor_search" model="ir.ui.view">
            <field name="name">building.floor.search</field>
            <field name="model">building.floor</field>
            <field name="arch" type="xml">
                <search string="Floor">
                    <separator/>
                    <field name="building_id"/>
                    <field name="name"/>
                    <field name="analytic_tag_id"/>
                    <separator/>
                    <filter string="Building" name="building_id" domain="[]" context="{'group_by': 'building_id'}"/>
                    <filter string="Tag" name="analytic_tag_id" domain="[]" context="{'group_by': 'analytic_tag_id'}"/>
                </search>
            </field>
        </record>
        <record id="view_building_floor_kanban" model="ir.ui.view">
            <field name="name">building.floor.kanban</field>
            <field name="model">building.floor</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile">
                    <field name="building_id"/>
                    <field name="name"/>
                    <field name="analytic_tag_id"/>
                    <field name="id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span>
                                                name:
                                                <t t-esc="record.name.value"/>
                                            </span>
                                        </strong>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-12">
                                        Building:
                                        <t t-esc="record.building_id.value"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-12">
                                        Tag:
                                        <t t-esc="record.analytic_tag_id.value"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>

            </field>
        </record>

        <!--TODO the most powerfull window action-->
        <record id="project_floor_tree_window_action" model="ir.actions.act_window">
            <field name="name">Floor</field>
            <field name="res_model">building.floor</field>
            <field name="view_mode">tree,form,search,kanban</field>
            <field name="target">current</field>
        </record>


    </data>
</odoo>
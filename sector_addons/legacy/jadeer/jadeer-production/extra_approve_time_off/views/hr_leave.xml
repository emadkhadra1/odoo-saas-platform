<data>
    <record id="inherit_hr_leave_form" model="ir.ui.view">
        <field name="name">inherit.hr.leave.form</field>
        <field name="model">hr.leave</field>
        <!--<field name="groups_id" eval="[(4, ref(''))]"/>-->
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_refuse']" position="before">
                <button name="action_first_approve" string="Approve"
                        attrs="{'invisible':['|','|',('direct_manager','=',False),('extra_approve','=',False),('state','!=','confirm')]}"
                        type="object" class="oe_highlight"/>
                <button name="action_first_refuse" string="Refuse"
                        attrs="{'invisible':['|','|',('direct_manager','=',False),('extra_approve','=',False),('state','!=','confirm')]}"
                        type="object"/>
                <field name="manager_time_off_there" invisible="1"/>
                <field name="extra_approve" invisible="1"/>
                <field name="direct_manager" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_draft']" position="attributes">
                <attribute name="attrs">{'invisible': ['|', ('can_reset', '=', False), ('state', 'not in', ['confirm',
                    'validate2', 'refuse'])]}
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_approve']" position="attributes">
                <attribute name="attrs">{'invisible': ['|','|',('extra_approve','=',True),('direct_manager','=',True),
                                              ('state','not in',['confirm','first_refuse'])]}
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_approve']" position="after">
                <button string="Approve" name="action_approve" type="object" id="extra_approve"
                        attrs="{'invisible': ['|','|',('extra_approve','=',False),('manager_time_off_there','=',False),
                                              ('state','not in',('validate2','first_refuse'))]}"/>
            </xpath>
            <xpath expr="//button[@name='action_refuse']" position="attributes">
                <attribute name="attrs">{'invisible': ['|','|',('extra_approve','=',True),('direct_manager','=',True),
                                              ('state','not in',['confirm','first_refuse','validate','validate1'])]}
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_refuse']" position="after">
                <button string="Refuse" name="action_refuse" type="object" id="refuse_extra_approve"
                        attrs="{'invisible': ['|','|',('extra_approve','=',False),('manager_time_off_there','=',False),
                                              ('state','not in',('validate2','validate1','first_refuse'))]}"/>
            </xpath>
        </field>
    </record>



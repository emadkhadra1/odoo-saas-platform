<data>
    <record id="inherit_hr_leave_type_form" model="ir.ui.view">
        <field name="name">inherit.hr.leave.type.form</field>
        <field name="model">hr.leave.type</field>
        <!--<field name="groups_id" eval="[(4, ref(''))]"/>-->
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='leave_validation_type']" position="after">
                <field name="extra_approve" widget="boolean_toggle"
                    attrs="{'invisible':[('leave_validation_type','=','no_validation')]}"/>
            </xpath>
        </field>
    </record>
</data>
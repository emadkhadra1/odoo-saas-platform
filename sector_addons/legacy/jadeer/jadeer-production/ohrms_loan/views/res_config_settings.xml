<data>
    <!-- Inherit Form View to Modify it -->
    <record id="inherit_res_config_settings_hr_form" model="ir.ui.view">
        <field name="name">res.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@data-key='hr']" position="inside">
                <h2>Loan Approvals</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">

                        <div>
                            <div class="text-muted">
                                <group>
                                    <field name="loan_hr_manager_id" widget="many2one_avatar_user"/>
                                    <field name="loan_cfo_manager_id" widget="many2one_avatar_user"/>
                                    <field name="loan_ceo_manager_id" widget="many2one_avatar_user"/>
                                </group>
                            </div>
                        </div>
                    </div>
                </div>

            </xpath>
        </field>
    </record>
</data>
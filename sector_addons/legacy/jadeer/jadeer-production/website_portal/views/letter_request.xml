<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--  breadcrumbs template-->
    <template id="portal_my_home_letter_request" name="Portal layout :  menu entries"
              inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'LetterRequest' or page_name == 'NewLetterRequest'"
                t-attf-class="breadcrumb-item #{'active ' if not letter else ''}">
                <a t-if="letter or page_name == 'NewLetterRequest'" t-attf-href="/my/letter-request?{{ keep_query() }}">
                    Letter Request
                </a>
                <t t-else="">Letter Request</t>
            </li>
            <li t-if="page_name == 'NewLetterRequest'" class="breadcrumb-item active">
                <t>Add New</t>
            </li>
            <li t-if="letter" class="breadcrumb-item active">
                <span t-field="letter.display_name"/>

            </li>
        </xpath>
    </template>
    <!--  breadcrumbs template-->
    <!--  list template-->
    <template id="portal_my_letter_request" name="My Quotations">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-set="additional_title">Letter Request</t>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Letter Request</t>
            </t>
            <div class="row mt-2 mb-2">
                <div class="col-12">
                    <a href="/my/letter-request/new" class=" btn bg-primary">
                        <i class="fa  fa-plus-circle"></i> New Letter  Request
                    </a>
                </div>
            </div>
            <t t-if="not letters">
                <p>There are currently no Letter Request for your account.</p>
            </t>
            <t t-if="letters" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>#</th>
                        <th class="text-left">Submit To	</th>
                        <th class="text-left">Reason</th>
                        <th class="text-left">State</th>
                        <th class="text-left">Action</th>
                    </tr>
                </thead>
                <t t-set="count" t-value="1"/>
                <t t-foreach="letters" t-as="letter">
                    <tr>
                        <td class="text-left">
                            <a t-attf-href="/my/letter-request/#{letter.id}">
                                <t t-esc="count"/>
                                <t t-set="count" t-value="count+1"/>
                            </a>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/letter-request/#{letter.id}">
                                <span t-field="letter.submit_to"/>
                            </a>
                        </td>
                        <td class="text-left">
                            <span t-field="letter.reason"/>
                        </td>

                        <td class="text-left">
                            <span t-field="letter.state"/>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/letter-request/#{letter.id}" class="btn btn-primary btn-sm">
                                <i class="fa fa-eye"></i>
                                View
                            </a>
                            <a t-attf-href="/my/letter-request/edit/#{letter.id}" class="btn btn-info btn-sm"  t-if="letter.state == 'draft'">
                                <i class="fa fa-edit"></i>
                                Edit
                            </a>
                            <a t-attf-href="/my/letter-request/submit/#{letter.id}" class="btn btn-success btn-sm" t-if="letter.state == 'draft'">
                                <i class="fa fa-check"></i>
                                Submit
                            </a>
                            <a  onclick="return confirm('Are you sure you want to delete this request?');" t-if="letter.state == 'draft'" t-attf-href="/my/letter-request/delete/#{letter.id}"
                               class="btn btn-warning btn-sm">
                                <i class="fa fa-trash"></i>
                                Delete
                            </a>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>
    <!--  list template-->
    <!--  form template-->
    <template id="website_portal.portal_my_letter_request_new" name="Letter: Submit a Businessletter">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title">New Letter Request</t>
            <br/>
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title">New Letter Request</h3>
                </div>
                <form action="/my/letter-request/new" method="post" class="container-fluid mt32" id="pd_form"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="card-body">
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="submit_to">Submit To
                                    <span style="color:red">*</span>

                                    <span class="label_right">مقدم الى
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="submit_to" required="required"
                                           class="form-control    "/>

                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="reason">Reason
                                    <span style="color:red">*</span>

                                    <span class="label_right">السبب
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="reason" required="required"
                                           class="form-control    "/>

                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="col-md-12 col-form-label">Supporting Document
                                <span style="color:red">*</span>

                                <span class="label_right">المرفقات
                                    <span style="color:red">*</span>
                                </span>
                            </label>
                            <input class="form-control" type="file" name="document" />
                        </div>
                        <div class="col-lg">
                            <label class="col-md-12 col-form-label">Notes

                                <span class="label_right">ملاحظات</span>
                            </label>
                            <textarea class="form-control" name="notes" placeholder="Textarea" rows="3"></textarea>
                        </div>

                    </div>


                    <!-- /.card-body -->
                    <div class="card-footer">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-paper-plane"></i> Save
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="history.go(-1)">
                            <i class="fa fa-arrow-circle-left"></i>Back
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
    <!--  form template-->
    <!--  view template-->
    <template id="portal_my_letter_request_view" name="My  Letter">
        <t t-call="portal.portal_layout">
            <br/>
            <div class="card card-info card-outline">

                <div class="card-body">
                    <div style="padding: 4px;" class="callout callout-info">
                        <h5 style="margin: 0;">Letter Details</h5>
                        <span t-foreach="letter" t-as="tf" class="float-right">
                            <span class="badge badge-light"
                                  t-field="tf.state"/>
                        </span>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="border-bottom d-flex justify-content-between py-2 mb-3 align-items-center">

                            </div>

                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Submit To :</strong>
                                    <span t-if="letter.submit_to" t-field="letter.submit_to"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Reason :</strong>
                                    <span t-if="letter.reason" t-field="letter.reason"/>
                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Supporting Document :</strong>

                                    <a t-if="letter.document" class="btn btn-primary "
                                       t-attf-href="/web/content/letter.request/{{letter.id}}/document?download=1">
                                        <i class="fas fa-download"></i>
                                        Download
                                    </a>

                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-12">
                                    <strong class="col-12">Notes :</strong>
                                    <span t-if="letter.notes" t-field="letter.notes"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>

                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </t>
    </template>
    <!--  view template-->
    <!--  edit template-->
    <template id="website_portal.portal_my_letter_request_edit" name="Letter: Edit a Businessletter">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title">Edit Letter Request</t>
            <br/>
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title">Edit Letter Request</h3>
                </div>
                <form t-att-action="'/my/letter-request/edit/%s' % (letter.id)" method="post" class="container-fluid mt32"
                      id="pd_form"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="card-body">
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="submit_to">Submit To
                                    <span style="color:red">*</span>

                                    <span class="label_right">   مقدم الى
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="submit_to" required="required"
                                           t-att-value="letter.submit_to"
                                           class="form-control    "/>

                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="reason">Reason
                                    <span style="color:red">*</span>

                                    <span class="label_right"> السبب
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="reason" required="required" class="form-control"
                                           t-att-value="letter.reason"/>

                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="col-md-12 col-form-label">Supporting Document
                                <span class="label_right">المرفقات
                                </span>
                            </label>
                            <input class="form-control" type="file" t-att-value="letter.document" name="document"
                                    />
                        </div>
                        <div class="col-lg">
                            <label class="col-md-12 col-form-label">Notes
                                <span class="label_right">ملاحظات</span>
                            </label>
                            <textarea class="form-control" name="notes" placeholder="Textarea" rows="3"><t t-if="letter" t-esc="letter.notes"/></textarea>
                        </div>

                    </div>


                    <!-- /.card-body -->
                    <div class="card-footer">

                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-paper-plane"></i>
                            Save
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="history.go(-1)">
                            <i class="fa fa-arrow-circle-left"></i>Back
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>
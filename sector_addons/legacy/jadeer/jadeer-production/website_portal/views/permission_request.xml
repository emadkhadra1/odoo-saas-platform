<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--  breadcrumbs template-->
    <template id="portal_my_home_permission_request" name="Portal layout :  menu entries"
              inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'permissionRequest' or page_name == 'NewpermissionRequest'"
                t-attf-class="breadcrumb-item #{'active ' if not permission else ''}">
                <a t-if="permission or page_name == 'NewpermissionRequest'" t-attf-href="/my/permission-request?{{ keep_query() }}">
                    Permission Request
                </a>
                <t t-else="">Permission Request</t>
            </li>
            <li t-if="page_name == 'NewpermissionRequest'" class="breadcrumb-item active">
                <t>Add New</t>
            </li>
            <li t-if="permission" class="breadcrumb-item active">
                <span t-field="permission.display_name"/>

            </li>
        </xpath>
    </template>
    <!--  breadcrumbs template-->
    <!--  list template-->
    <template id="portal_my_permission_request" name="My Quotations">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-set="additional_title">permission Request</t>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Permission Request</t>
            </t>
            <div class="row mt-2 mb-2">
                <div class="col-12">
                    <a href="/my/permission-request/new" class=" btn bg-primary">
                        <i class="fa  fa-plus-circle"></i>
                        New Permission Request
                    </a>
                </div>
            </div>
            <t t-if="not permissions">
                <p>There are currently no Permission Request for your account.</p>
            </t>
            <t t-if="permissions" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>#</th>
                        <th class="text-left">Name</th>
                        <th class="text-left">Delegate Employee</th>
                        <th class="text-left">Reason</th>
                        <th class="text-left">From Date</th>
                        <th class="text-left">To Date</th>
                        <th class="text-left">State</th>
                        <th class="text-left">Action</th>
                    </tr>
                </thead>
                <t t-set="count" t-value="1"/>
                <t t-foreach="permissions" t-as="permission">
                    <tr>
                        <td class="text-left">
                            <a t-attf-href="/my/permission-request/#{permission.id}">
                                <t t-esc="count"/>
                                <t t-set="count" t-value="count+1"/>
                            </a>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/permission-request/#{permission.id}">
                                <span t-field="permission.name"/>
                            </a>
                        </td>
                         <td class="text-left">
                            <span t-field="permission.delegate_employee_id"/>
                        </td>
                        <td class="text-left">
                            <span t-field="permission.reason"/>
                        </td>
                        <td class="text-left">
                            <span t-field="permission.date_from"   t-options='{"widget": "date"}'/>
                        </td>
                        <td class="text-left">
                            <span t-field="permission.date_to"   t-options='{"widget": "date"}'/>
                        </td>
                        <td class="text-left">
                            <span t-field="permission.state"/>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/permission-request/#{permission.id}" class="btn btn-primary btn-sm">
                                <i class="fa fa-eye"></i>
                                View
                            </a>
                            <a t-attf-href="/my/permission-request/edit/#{permission.id}" class="btn btn-info btn-sm"
                               t-if="permission.state == 'draft'">
                                <i class="fa fa-edit"></i>
                                Edit
                            </a>
                            <a t-attf-href="/my/permission-request/submit/#{permission.id}" class="btn btn-success btn-sm"
                               t-if="permission.state == 'draft'">
                                <i class="fa fa-check"></i>
                                Submit
                            </a>
                            <a onclick="return confirm('Are you sure you want to delete this request?');"
                               t-if="permission.state == 'draft'" t-attf-href="/my/permission-request/delete/#{permission.id}"
                               class="btn btn-warning btn-sm">
                                <i class="fa fa-trash"></i>
                                Delete
                            </a>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>
    <!--  list template-->
    <!--  form template-->
    <template id="website_portal.portal_my_permission_request_new" name="permission: Submit a Businesspermission">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title">New Permission Request</t>
            <br/>
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title">New Permission Request</h3>
                </div>
                <form action="/my/permission-request/new" method="post" class="container-fluid mt32" id="pd_form"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="card-body">
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label">Delegate Employee
                                    <span style="color:red">*</span>

                                    <span class="label_right">الموظف البديل
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <select class="form-control  " required="required"
                                        name="delegate_employee_id">
                                    <option value="" selected="selected" disabled="disabled">Select Delegate Employee
                                    </option>
                                    <t t-foreach="emps" t-as="emp">
                                        <option
                                                t-att-value="emp.id">
                                            <t t-esc="emp.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="reason">Reason
                                    <span style="color:red">*</span>

                                    <span class="label_right">السبب
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="reason" required="required"
                                           class="form-control    "/>

                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_from">Date From
                                    <span style="color:red">*</span>

                                    <span class="label_right">من تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="date_from" required="required" id="date_from_btrip"
                                           class="form-control"
                                           placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_to">Date To
                                    <span style="color:red">*</span>

                                    <span class="label_right">الى تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input  name="date_to" required="required" id="date_to_btrip"
                                            class="form-control    "
                                            placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>                        <div class="row">

                            <div class="form-group col-md-6">
                                <div class="form-group">
                                    <label class="col-md-12 col-form-label">Supporting Document
                                        <span class="label_right">المرفقات
                                        </span>
                                    </label>
                                    <input class="form-control" type="file" name="document" />
                                </div>
                            </div>
                        </div>
                    </div>


                    <!-- /.card-body -->
                    <div class="card-footer">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-paper-plane"></i>
                            Save
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="history.go(-1)">
                            <i class="fa fa-arrow-circle-left"></i>Back
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
    <!--  form template-->
    <!--  view template-->
    <template id="portal_my_permission_request_view" name="My  permission">
        <t t-call="portal.portal_layout">
            <br/>
            <div class="card card-info card-outline">

                <div class="card-body">
                    <div style="padding: 4px;" class="callout callout-info">
                        <h5 style="margin: 0;">Permission Request Details</h5>
                        <span t-foreach="permission" t-as="tf" class="float-right">
                            <span class="badge badge-light"
                                  t-field="tf.state"/>
                        </span>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="border-bottom d-flex justify-content-between py-2 mb-3 align-items-center">

                            </div>

                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Delegate Employee :</strong>
                                    <span t-if="permission.delegate_employee_id" t-field="permission.delegate_employee_id"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Reason :</strong>
                                    <span t-if="permission.reason" t-field="permission.reason"/>
                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">From Date :</strong>
                                    <span t-if="permission.date_from" t-field="permission.date_from"   t-options='{"widget": "date"}'/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">To Date :</strong>
                                    <span t-if="permission.date_to" t-field="permission.date_to"/>
                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Supporting Document :</strong>

                                    <a t-if="permission.document" class="btn btn-primary "
                                       t-attf-href="/web/content/permission.request/{{hr.permission.request}}/document?download=1">
                                        <i class="fas fa-download"></i>
                                        Download
                                    </a>

                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </t>
    </template>
    <!--  view template-->
    <!--  edit template-->
    <template id="website_portal.portal_my_permission_request_edit" name="permission: Edit a Businesspermission">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title">Edit Permission Request</t>
            <br/>
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title">Edit Permission Request</h3>
                </div>
                <form t-att-action="'/my/permission-request/edit/%s' % (permission.id)" method="post"
                      class="container-fluid mt32"
                      id="pd_form"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="card-body">
                        <div class="row">
                            <div class="form-group col-md-6">

                                    <label class="col-md-12 col-form-label">Delegate Employee
                                        <span style="color:red">*</span>

                                        <span class="label_right">الموظف البديل
                                            <span style="color:red">*</span>
                                        </span>
                                    </label>
                                    <select class="form-control  " required="required"
                                            name="delegate_employee_id">
                                        <option value="" disabled="disabled">Select Delegate Employee
                                        </option>
                                        <t t-foreach="emps" t-as="emp">
                                            <option t-att-selected="emp.id == permission.delegate_employee_id.id"
                                                    t-att-value="emp.id">
                                                <t t-esc="emp.name"/>
                                            </option>
                                        </t>
                                    </select>

                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="reason">Reason
                                    <span style="color:red">*</span>

                                    <span class="label_right">السبب
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="reason" required="required" class="form-control"
                                           t-att-value="permission.reason"/>

                                </div>
                            </div>
                        </div>

                                           <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_from">Date From
                                    <span style="color:red">*</span>

                                    <span class="label_right">من تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="date" name="date_from" required="required"
                                           class="form-control" t-att-value="permission.date_from"
                                           placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_to">Date To
                                    <span style="color:red">*</span>

                                    <span class="label_right">الى تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="date" name="date_to" required="required"  t-att-value="permission.date_to"
                                           class="form-control  "
                                           placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group col-md-6">
                                <div class="form-group">
                                    <label class="col-md-12 col-form-label">Supporting Document
                                        <span class="label_right">المرفقات
                                        </span>
                                    </label>
                                    <input class="form-control" type="file" name="document" required="required"/>
                                </div>
                            </div>
                        </div>


                    </div>


                    <!-- /.card-body -->
                    <div class="card-footer">

                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-paper-plane"></i>
                            Save
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="history.go(-1)">
                            <i class="fa fa-arrow-circle-left"></i>Back
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>
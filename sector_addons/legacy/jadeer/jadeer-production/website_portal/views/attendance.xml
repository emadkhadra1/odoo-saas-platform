<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--  breadcrumbs template-->
    <template id="portal_my_home_attendances" name="Portal layout :  menu entries"
              inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'Attendance' or page_name == 'NewAttendance'"
                t-attf-class="breadcrumb-item #{'active ' if not attendance else ''}">
                <a t-if="attendance or page_name == 'NewAttendance'" t-attf-href="/my/attendances?{{ keep_query() }}">
                    Attendances
                </a>
                <t t-else="">Attendances</t>
            </li>
            <li t-if="attendance" class="breadcrumb-item active">
                <span t-field="attendance.display_name"/>

            </li>
        </xpath>
    </template>
    <!--  breadcrumbs template-->
    <!--  list template-->
    <template id="portal_my_attendances" name="My Quotations">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-set="additional_title">Attendances </t>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Attendances  </t>
            </t>
            <t t-if="not attendances">
                <p>There are currently no Attendances Request for your account.</p>
            </t>
            <t t-if="attendances" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>#</th>
                        <th class="text-left">PIN</th>
                        <th class="text-left">Check In</th>
                        <th class="text-left">Check Out</th>
                        <th class="text-left">Late</th>
                        <th class="text-left">Early</th>
                        <th class="text-left">Over Time</th>
                        <th class="text-left">Work Hours</th>
                        <th class="text-left">Action</th>
                    </tr>
                </thead>
                <t t-set="count" t-value="1"/>
                <t t-foreach="attendances" t-as="payslip">
                    <tr>
                        <td class="text-left">
                            <a t-attf-href="/my/attendances/#{payslip.id}">
                                <t t-esc="count"/>
                                <t t-set="count" t-value="count+1"/>
                            </a>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/attendances/#{payslip.id}">
                                <span t-field="payslip.pin"/>
                            </a>
                        </td>
                        <td class="text-left">
                            <span t-field="payslip.check_in"/>
                        </td>

                        <td class="text-left">
                            <span t-field="payslip.check_out"/>
                        </td>
                                      <td class="text-left">
                            <span t-field="payslip.late"  t-options='{"widget": "float_time"}'/>
                        </td>
                                      <td class="text-left">
                            <span t-field="payslip.early" t-options='{"widget": "float_time"}' />
                        </td>
                                      <td class="text-left">
                            <span t-field="payslip.over_time" t-options='{"widget": "float_time"}'/>
                        </td>
                                      <td class="text-left">
                            <span t-field="payslip.worked_hours" t-options='{"widget": "float_time"}'/>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/attendances/#{payslip.id}" class="btn btn-primary btn-sm">
                                <i class="fa fa-eye"></i>
                                View
                            </a>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>
    <!--  list template-->
    <!--  view template-->
    <template id="portal_my_attendances_view" name="My  attendance">
        <t t-call="portal.portal_layout">
            <br/>
            <div class="card card-info card-outline">

                <div class="card-body">
                    <div style="padding: 4px;" class="callout callout-info">
                        <h5 style="margin: 0;">Attendance Details</h5>
                        <span  class="float-right">
                            <span class="badge badge-light"
                                  t-field="attendance.pin"/>
                        </span>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="border-bottom d-flex justify-content-between py-2 mb-3 align-items-center">

                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Check In :</strong>
                                    <span t-if="attendance.check_in" t-field="attendance.check_in"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Check Out :</strong>
                                    <span t-if="attendance.check_out" t-field="attendance.check_out"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                            </div>
                             <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Late :</strong>
                                    <span t-if="attendance.late" t-field="attendance.late"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Early :</strong>
                                    <span t-if="attendance.early" t-field="attendance.early"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Over Time :</strong>
                                    <span t-if="attendance.over_time" t-field="attendance.over_time"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Work Hours :</strong>
                                    <span t-if="attendance.worked_hours" t-field="attendance.worked_hours"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </t>
    </template>
    <!--  view template-->

</odoo>
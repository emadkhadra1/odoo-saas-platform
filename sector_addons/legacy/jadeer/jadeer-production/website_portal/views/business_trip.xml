<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--  breadcrumbs template-->
    <template id="portal_my_home_business_trip" name="Portal layout :  menu entries"
              inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'BusinessTrip' or page_name == 'NewBusinessTrip'"
                t-attf-class="breadcrumb-item #{'active ' if not trip else ''}">
                <a t-if="trip or page_name == 'NewBusinessTrip'" t-attf-href="/my/business-trip?{{ keep_query() }}">
                    Business Trip Request
                </a>
                <t t-else="">Business Trip Request</t>
            </li>
            <li t-if="page_name == 'NewBusinessTrip'" class="breadcrumb-item active">
                <t>Add New</t>
            </li>
            <li t-if="trip" class="breadcrumb-item active">
                <span t-field="trip.display_name"/>

            </li>
        </xpath>
    </template>
    <!--  breadcrumbs template-->
    <!--  list template-->
    <template id="portal_my_business_trip" name="My Quotations">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-set="additional_title">Business Trip Request</t>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Business Trip Request</t>
            </t>
            <div class="row mt-2 mb-2">
                <div class="col-12">
                    <a href="/my/business-trip/new" class=" btn bg-primary">
                        <i class="fa fa-plus-circle"></i> New Trip Request
                    </a>
                </div>
            </div>
            <t t-if="not trips">
                <p>There are currently no Business Trip Request for your account.</p>
            </t>
            <t t-if="trips" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>#</th>
                        <th class="text-left">Date From</th>
                        <th class="text-left">Date To</th>
                        <th class="text-left">Destination</th>
                        <th class="text-left">Reason</th>
                        <th class="text-left">State</th>
                        <th class="text-left">Action</th>
                    </tr>
                </thead>
                <t t-set="count" t-value="1"/>
                <t t-foreach="trips" t-as="trip">
                    <tr>
                        <td class="text-left">
                            <a t-attf-href="/my/business-trip/#{trip.id}">
                                <t t-esc="count"/>
                                <t t-set="count" t-value="count+1"/>
                            </a>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/business-trip/#{trip.id}">
                                <span t-field="trip.date_from"   t-options='{"widget": "date"}'/>
                            </a>
                        </td>
                        <td class="text-left">
                            <span t-field="trip.date_to"   t-options='{"widget": "date"}'/>
                        </td>
                        <td class="text-left">
                            <span t-field="trip.destination"/>
                        </td>
                        <td class="text-left">
                            <span t-field="trip.reason"/>
                        </td>

                        <td class="text-left">
                            <span t-field="trip.state"/>
                        </td>
                        <td class="text-left">
                            <a t-attf-href="/my/business-trip/#{trip.id}" class="btn btn-primary btn-sm">
                                <i class="fa fa-eye"></i>
                                View
                            </a>
                            <a t-attf-href="/my/business-trip/edit/#{trip.id}" class="btn btn-info btn-sm" t-if="trip.state == 'draft'">
                                <i class="fa fa-edit"></i>
                                Edit
                            </a>
                               <a t-attf-href="/my/business-trip/submit/#{trip.id}" class="btn btn-success btn-sm" t-if="trip.state == 'draft'">
                                <i class="fa fa-check"></i>
                                Submit
                            </a>
                            <a  onclick="return confirm('Are you sure you want to delete this request?');" t-if="trip.state == 'draft'" t-attf-href="/my/business-trip/delete/#{trip.id}"
                               class="btn btn-warning btn-sm">
                                <i class="fa fa-trash"></i>
                                Delete
                            </a>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>
    <!--  list template-->
    <!--  form template-->
    <template id="website_portal.portal_my_business_trip_new" name="Business Trip: Submit a BusinessTrip">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title">New Business Trip Request</t>
            <br/>
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title">New Business Trip Request</h3>
                </div>
                <form action="/my/business-trip/new" method="post" class="container-fluid mt32" id="pd_form"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="card-body">
                        <div class="row">

                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_from">Date From
                                    <span style="color:red">*</span>

                                    <span class="label_right">من تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="date_from" required="required" id="date_from_btrip"
                                           class="form-control"
                                           placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_to">Date To
                                    <span style="color:red">*</span>

                                    <span class="label_right">الى تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input  name="date_to" required="required" id="date_to_btrip"
                                            class="form-control    "
                                            placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="destination">Destination
                                    <span style="color:red">*</span>

                                    <span class="label_right">جهة السفر
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="destination" required="required"
                                           class="form-control    "/>

                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="reason">Reason
                                    <span style="color:red">*</span>

                                    <span class="label_right">سبب السفر
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="reason" required="required"
                                           class="form-control    "/>

                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="col-md-12 col-form-label">Supporting Document
                                <span style="color:red">*</span>

                                <span class="label_right">المرفقات
                                    <span style="color:red">*</span>
                                </span>
                            </label>
                            <input class="form-control" type="file" name="document" required="required"/>
                        </div>
                        <div class="col-lg">
                            <label class="col-md-12 col-form-label">Notes

                                <span class="label_right">ملاحظات</span>
                            </label>
                            <textarea class="form-control" name="notes" placeholder="Textarea" rows="3"></textarea>
                        </div>

                    </div>


                    <!-- /.card-body -->
                    <div class="card-footer">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-paper-plane"></i> Save
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="history.go(-1)">
                            <i class="fa fa-arrow-circle-left"></i> Back
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
    <!--  form template-->
    <!--  view template-->
    <template id="portal_my_business_trip_view" name="My  Business Trip">
        <t t-call="portal.portal_layout">
            <br/>
            <div class="card card-info card-outline">

                <div class="card-body">
                    <div style="padding: 4px;" class="callout callout-info">
                        <h5 style="margin: 0;">Business Trip Details</h5>
                        <span t-foreach="trip" t-as="tf" class="float-right">
                            <span class="badge badge-light"
                                  t-field="tf.state"/>
                        </span>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="border-bottom d-flex justify-content-between py-2 mb-3 align-items-center">

                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Date From :</strong>
                                    <span t-if="trip.date_from" t-field="trip.date_from"   t-options='{"widget": "date"}'/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Date To :</strong>
                                    <span t-if="trip.date_to" t-field="trip.date_to"   t-options='{"widget": "date"}'/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Destination :</strong>
                                    <span t-if="trip.destination" t-field="trip.destination"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>
                                <div class="col-md-6">
                                    <strong class="col-12">Reason :</strong>
                                    <span t-if="trip.reason" t-field="trip.reason"/>
                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>
                            <div class="row mb-2">

                                <div class="col-md-6">
                                    <strong class="col-12">Supporting Document :</strong>

                                    <a t-if="trip.document" class="btn btn-primary "
                                       t-attf-href="/web/content/business.trip.request/{{trip.id}}/document?download=1">
                                        <i class="fas fa-download"></i>
                                        Download
                                    </a>

                                    <span t-else="" class="text-muted"></span>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-12">
                                    <strong class="col-12">Notes :</strong>
                                    <span t-if="trip.notes" t-field="trip.notes"/>
                                    <span t-else="" class="text-muted">-</span>
                                </div>

                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </t>
    </template>
    <!--  view template-->
    <!--  edit template-->
    <template id="website_portal.portal_my_business_trip_edit" name="Business Trip: Edit a BusinessTrip">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title">Edit Business Trip Request</t>
            <br/>
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title">Edit Business Trip Request</h3>
                </div>
                <form t-att-action="'/my/business-trip/edit/%s' % (trip.id)" method="post" class="container-fluid mt32"
                      id="pd_form"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="card-body">
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_from">Date From
                                    <span style="color:red">*</span>

                                    <span class="label_right">من تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="date" name="date_from" required="required"
                                           class="form-control   " t-att-value="trip.date_from"
                                           placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="date_to">Date To
                                    <span style="color:red">*</span>

                                    <span class="label_right">الى تاريخ
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="date" name="date_to" required="required"
                                           class="form-control    " t-att-value="trip.date_to"
                                           placeholder="DD/MM/YYYY"/>
                                    <div class="input-group-append">
                                        <span class="input-group-text">
                                            <span class="fa fa-calendar" role="img" aria-label="Calendar"></span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="destination">Destination
                                    <span style="color:red">*</span>

                                    <span class="label_right">جهة السفر
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="destination" required="required"
                                           t-att-value="trip.destination"
                                           class="form-control    "/>

                                </div>
                            </div>
                            <div class="form-group col-md-6">
                                <label class="col-md-12 col-form-label" for="reason">Reason
                                    <span style="color:red">*</span>

                                    <span class="label_right">سبب السفر
                                        <span style="color:red">*</span>
                                    </span>
                                </label>
                                <div class="input-group date">
                                    <input type="text" name="reason" required="required" class="form-control"
                                           t-att-value="trip.reason"/>

                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="col-md-12 col-form-label">Supporting Document


                                <span class="label_right">المرفقات

                                </span>
                            </label>
                            <input class="form-control" type="file" t-att-value="trip.document" name="document" required="required"
                                    />
                        </div>
                        <div class="col-lg">
                            <label class="col-md-12 col-form-label">Notes

                                <span class="label_right">ملاحظات</span>
                            </label>
                            <textarea class="form-control" name="notes" placeholder="Textarea" rows="3"><t t-if="trip" t-esc="trip.notes"/></textarea>
                        </div>

                    </div>


                    <!-- /.card-body -->
                    <div class="card-footer">

                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-paper-plane"></i>
                            Save
                        </button>
                        <button type="button" class="btn btn-secondary" onclick="history.go(-1)">
                            <i class="fa fa-arrow-circle-left"></i>Back
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>
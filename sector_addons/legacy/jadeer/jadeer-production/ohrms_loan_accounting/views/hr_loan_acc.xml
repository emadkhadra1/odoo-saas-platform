<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_loan_inherited" model="ir.ui.view">
            <field name="name">HR LOAN</field>
            <field name="model">hr.loan</field>
            <field name="inherit_id" ref="ohrms_loan.hr_loan_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="manager_approve_request" class="btin btn-success" string="Approve" type="object"
                            attrs="{'invisible':['|',('same_user','!=',True),('state','!=','waiting_approval_1')]}"
                    />
                    <button name="hr_manager_approve_request" class="btin btn-success" string="Approve" type="object"
                            attrs="{'invisible':['|',('same_user','!=',True),('state','!=','waiting_hr_approval')]}"
                    />
                    <button name="cfo_manager_approve_request" class="btin btn-success" string="Approve" type="object"
                            attrs="{'invisible':['|',('same_user','!=',True),('state','!=','waiting_approval_cfo')]}"

                    />
                    <button name="ceo_manager_approve_request" class="btin btn-success" string="Approve" type="object"
                            attrs="{'invisible':['|',('same_user','!=',True),('state','!=','waiting_approval_ceo')]}"

                    />
                    <button name="action_double_approve" type="object" string="Approve" states="waiting_approval_2"
                            class="oe_highlight" groups="account.group_account_user,account.group_account_manager"/>
                    <button name="action_loan_pay" type="object" string="Register Payment" states="approve"
                            class="oe_highlight" groups="account.group_account_user,account.group_account_manager"/>
                </xpath>
                <xpath expr="//header/button[@name='action_approve']" position="attributes">
                    <!--                    <attribute name="groups">hr.group_hr_manager,hr.group_hr_user</attribute>-->
                    <attribute name="invisible">True</attribute>
                </xpath>
                <xpath expr="//header/button[@name='action_refuse']" position="attributes">
                    <attribute name="groups">hr.group_hr_manager,hr.group_hr_user</attribute>
                    <attribute name="states">
                        waiting_approval_1,waiting_hr_approval,waiting_approval_cfo,waiting_approval_ceo</attribute>
                </xpath>
                <xpath expr="//field[@name='state']" position="replace">
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,waiting_approval_1,waiting_hr_approval,waiting_approval_cfo,waiting_approval_ceo,approve"/>

                </xpath>
                <xpath expr="//notebook" position="before">
                    <group>
                        <field name="same_user" invisible="1"/>
                        <field name="current_user" invisible="1" widget="many2one_avatar_user" />
                        <field name="manager_id" widget="many2one_avatar_user" force_save="1"/>
                        <field name="hr_manager_id" widget="many2one_avatar_user" force_save="1"/>
                        <field name="cfo_manager_id" widget="many2one_avatar_user" force_save="1"/>
                        <field name="ceo_manager_id" widget="many2one_avatar_user" force_save="1"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='loan_amount']" position="after">
                    <field name="employee_account_id"
                           domain="['|', ('company_id', '=', company_id), ('company_id', '=', False)]"
                           attrs="{'invisible':[('state', '=','draft')],'readonly':[('state','in',('approve', 'refuse','cancel'))]}"/>
                    <field name="treasury_account_id"
                           domain="['|', ('company_id', '=', company_id), ('company_id', '=', False)]"
                           attrs="{'invisible':[('state', '=','draft')],'readonly':[('state','in',('approve', 'refuse','cancel'))]}"/>
                    <field name="journal_id" domain="['|', ('company_id', '=', company_id), ('company_id', '=', False)]"
                           attrs="{'invisible':[('state', '=','draft')],'readonly':[('state','in',('approve', 'refuse','cancel'))]}"/>
                </xpath>
                <xpath expr="//field[@name='loan_lines']/tree/field[@name='amount']" position="after">
                    <field name="paid_amount" sum="Total"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
            <field name="name">res.config.settings.inherit</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="1"/>
            <field name="inherit_id" ref="res_documents.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='emp_docs']" position="after">
                   <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="expiry_duration"/>
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific."
                                  role="img" aria-label="Values set here are company-specific."
                                  groups="base.group_multi_company"/>
                            <div class="row">
                                <div class="text-muted col-lg-8">
                                    set Expiry Duration documents.
                                </div>
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="expiry_duration"
                                           class="o_light_label"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
        <record id="view_account_analytic_account_search_project" model="ir.ui.view">
            <field name="name">account.analytic.account.search</field>
            <field name="model">account.analytic.account</field>
            <field name="arch" type="xml">
                <search string="Analytic Account">
                    <field name="name" filter_domain="['|', ('name','ilike',self), ('code','ilike',self)]"
                           string="Analytic Account"/>
                    <field name="partner_id"/>
<!--                    <field name="is_unit_project"/>-->
<!--                    <filter string="Unit Project" domain="[('is_unit_project', '=', True)]" name="project"/>-->
                    <filter string="Archived" domain="[('active', '=', False)]" name="inactive"/>
                    <group expand="0" string="Group By...">
                        <filter string="Associated Partner" name="associatedpartner" domain="[]"
                                context="{'group_by':'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>


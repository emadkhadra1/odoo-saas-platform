<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_access_lead" model="res.groups">
            <field name="name">Access lead</field>
        </record>
        <record id="group_leads_create" model="res.groups">
            <field name="name">Create Leads &amp; Opportunities</field>
        </record>
        <record id="group_leads_edit" model="res.groups">
            <field name="name">Edit Leads &amp; Opportunities</field>
        </record>

        <record id="edit_customer_data" model="res.groups">
            <field name="name">Edit Customer Data</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="won_opportunity_access_group" model="res.groups">
            <field name="name">Access Won Opportunity</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="sale.sale_order_personal_rule" model="ir.rule">
            <field name="name">Personal Orders</field>
            <field ref="sale.model_sale_order" name="model_id"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), '|', ('user_id', '=', False), '|',
                                        ('sales_person3_id', '=', user.id), '|', ('sales_person2_id', '=', user.id), '|',
                                        ('team_id.user_id', '=', user.id), '|',
                                        ('sale_person2_sale_team.user_id', '=', user.id),
                                        ('sale_person3_sale_team.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>

        </record>

        <record id="account_order_personal_rule" model="ir.rule">
            <field name="name">account All Orders</field>
            <field ref="sale.model_sale_order" name="model_id"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_invoice')),(4, ref('account.group_account_user')),(4, ref('account.group_account_manager'))]"/>

        </record>

        <record id="crm.crm_rule_personal_lead" model="ir.rule">
            <field name="name">Personal Leads</field>
            <field ref="crm.model_crm_lead" name="model_id"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), '|', ('user_id', '=', False), '|',
                                        ('sale_person3_id', '=', user.id), '|', ('sale_person2_id', '=', user.id),
                                        '|',
                                        ('team_id.user_id', '=', user.id), '|',
                                        ('sales_person2_sale_team.user_id', '=', user.id),
                                        ('sales_person3_sale_team.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>
    </data>
</odoo>
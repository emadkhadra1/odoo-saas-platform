<odoo>
    <record id="select_unit_wizard_form" model="ir.ui.view">
        <field name="name">select.unit.wizard.form</field>
        <field name="model">select.unit.wizard</field>
        <field name="arch" type="xml">
            <form string="Units">
                <field name="lead_id" invisible="1"/>
                <field name="unit_ids">
                    <tree editable="bottom" create="0">
                        <field name="is_select"/>
                        <field name="unit_id" readonly="1" force_save="1"/>
                        <field name="project_id"/>
                        <field name="total_Area"/>
                        <field name="list_price"/>
                    </tree>
                </field>
                <footer>
                    <button name="confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
<odoo>

    <record id="sale_order_view_tree_inherit_crm_inherit" model="ir.ui.view">
        <field name="name">sale_order_view_tree_inherit_crm_inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="confirm_reschedule" type="object"
                        string="Confirm Reschedule" class="oe_highlight"
                        attrs="{'invisible':['|',('request_reschedule','=',False),('reschedule_confirmed','=',True)]}"/>

            </xpath>
            <xpath expr="//field[@name='unit_delivery_date']" position="after">
                <field name="request_downgrade" invisible="1"/>
                <field name="request_upgrade" invisible="1"/>
                <field name="request_reschedule" invisible="1"/>
                <field name="contract_rescheduled" invisible="1"/>
                <field name="reschedule_confirmed" invisible="1"/>
                <field name="original_contract_id" readonly="1" force_save="1"
                       context="{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}"
                       attrs="{'invisible':[('request_downgrade','=',False),('request_upgrade','=',False),('request_reschedule','=',False)]}"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <widget name="web_ribbon" text="Downgraded" bg_color="bg-info"
                        attrs="{'invisible': [('request_downgrade', '=', False)]}"/>
                <widget name="web_ribbon" text="Upgraded" bg_color="bg-info"
                        attrs="{'invisible': [('request_upgrade', '=', False)]}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="rescheduled_contract_id"
                       context="{'form_view_ref': 'real_estate.sale_order_view_tree_inherit_crm'}"
                       attrs="{'invisible':[('contract_rescheduled','=',False)]}"/>
            </xpath>

        </field>
    </record>

    <record id="contract_form_view" model="ir.ui.view">
        <field name="name">sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="real_estate.sale_order_view_tree_inherit_crm"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">0</attribute>
                <!--                <attribute name="edit">0</attribute>-->
            </xpath>
            <xpath expr="//header" position="replace">
                <header>
                    <button name="action_sales_director_cancel"
                            string="Sale director Approve"
                            class="btn btn-info" type="object"
                            attrs="{'invisible':[('state','!=','sales_director_cancel')]}"
                            groups="archer_realestate_notification.group_sale_director"/>
                    <!--                    <button name="action_accounting_cancel" string="Accounting Approve"-->
                    <!--                            class="btn btn-info" type="object" attrs="{'invisible':[('state','!=','cfo_cancel')]}"-->
                    <!--                            groups="real_estate_security.group_manager,account.group_account_invoice,account.group_account_manager,account.group_account_user"-->

                    <!--                    />-->
                    <button name="action_accounting_approve" string="Accounting Approve"
                            class="btn btn-info" type="object"
                            attrs="{'invisible':[('state','!=','accounting_approve')]}"
                            groups="real_estate_security.group_manager,account.group_account_invoice,account.group_account_manager,account.group_account_user"

                    />
                    <button name="action_cancel_request" states="sale,reservation" type="object"
                            string="Cancel Request"/>

<!--                    <button name="action_cancel" states="cancel_request" type="object"-->
<!--                            groups="archer_realestate_notification.group_cfo_director"-->
<!--                            attrs="{'invisible':['|',('state','not in',('cancel_request','cfo_cancel')),'|',('is_upgrade','=',True),('is_downgrade','=',True)]}"-->
<!--                            string="CFO Approve"/>-->
                    <button name="action_cfo_approve_upgrade" type="object" states="cfo_cancel"
                            groups="archer_realestate_notification.group_cfo_director" class="btn btn-primary"
                            string="CFO Approve"/>
                    <button name="action_rufus_cancel" states="cancel_request,cfo_cancel,accounting_approve"
                            type="object"
                            class="btn-danger"
                            groups="real_estate_security.group_manager,account.group_account_invoice,account.group_account_manager,account.group_account_user"
                            string="Rufus Cancel"/>

                    <button name="action_downgrade" type="object"
                            attrs="{'invisible':['|',('state','not in',['sale','reservation']),('rescheduled_contract_id','!=',False)]}"
                            string="Downgrade"/>


                    <button name="action_upgrade"
                            attrs="{'invisible':['|',('state','not in',['sale','reservation']),('rescheduled_contract_id','!=',False)]}"
                            type="object"
                            string="Upgrade" class="oe_highlight"/>
                    <!--                    <button name="action_reschedule_contract" type="object"-->
                    <!--                            string="Reschedule" class="oe_highlight"-->
                    <!--                            attrs="{'invisible':['|',('state','not in',['sale','reservation']),('rescheduled_contract_id','!=',False)]}"-->
                    <!--                    />-->
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,sale"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='unit_delivery_date']" position="after">
                <field name="is_upgrade" invisible="1"/>
                <field name="is_downgrade" invisible="1"/>
                <field name="penalty_id"/>
                <field name="new_unit_id"/>
                <field name="penalty_type" attrs="{'invisible':[('penalty_id','=',False)]}"/>
                <field name="penalty_percentage"
                       attrs="{'invisible':[('penalty_type','!=','percentage')],'required':[('penalty_type','=','percentage')]}"/>
                <field name="penalty_amount"
                       attrs="{'invisible':[('penalty_type','!=','amount')],'required':[('penalty_type','=','amount')]}"/>
                <field name="total_penality"/>
                <field name="cancellation_reason_id" readonly="1" force_save="1"
                       attrs="{'invisible':[('cancellation_reason_id','=',False)]}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cancellation_credit_note_id"
                       attrs="{'invisible':[('cancellation_credit_note_id','=',False)]}"/>
            </xpath>
        </field>
    </record>

    <record id="contract_tree_view" model="ir.ui.view">
        <field name="name">sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="real_estate.sale_order_view_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="edit">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_contract_menu" model="ir.actions.act_window">
        <field name="name">Contract</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'form_view_ref': 'customer_care.contract_form_view'}</field>
        <field name="view_id" ref="customer_care.contract_tree_view"/>
        <field name="domain">[('state', 'in', ['sale', 'reservation', 'upgraded', 'downgraded', 'rescheduled', 'cancel',
                                               'cancel_request','accounting_approve','cfo_cancel','sales_director_cancel']), ('unit_id', '!=',
                                                                    False)]
        </field>
    </record>

    <menuitem id="customer_care_root"
              name="Customer Care"
              web_icon="customer_care,static/description/icon.png"
              sequence="7"
    />

    <menuitem id="contract_menu" name="Contracts"
              parent="customer_care.customer_care_root"
              action="customer_care.action_contract_menu" sequence="1"/>

    <menuitem id="customer_care_config" name="Configuration"
              parent="customer_care_root" sequence="100"/>


</odoo>